++		    args->id == U32_MAX ||
++		    args->engine_count > I915_CRIU_MAX_CONTEXT_ENGINES ||
++		    (args->engine_count && !args->engines_ptr)) {
++			ret = -EINVAL;
++			goto out;
++		}
++		ret = check_session(fpriv, args->cookie, I915_CRIU_MODE_DUMP);
++		if (ret)
