index 0000000000000000000000000000000000000000..5dea1d004ffc56d9c1fccaf385a77f47d9157c24
--- /dev/null
+++ b/test/others/i915-criu/run-sharing-criu.sh
@@ -0,0 +1,146 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+if (( EUID != 0 )); then
+    echo "run as root: sudo $0" >&2
+    exit 2
+fi
+
+repo=$(cd "$(dirname "$0")/../../.." && pwd)
+work=${I915_CRIU_TEST_DIR:-/tmp/i915-criu-sharing}
+criu=${CRIU:-/run/current-system/sw/bin/criu}
+plugin_dir=${CRIU_PLUGIN_DIR:-}
+plugin_args=()
+[[ -n $plugin_dir ]] && plugin_args+=(--libdir "$plugin_dir")
+expect_unsupported=${I915_CRIU_EXPECT_UNSUPPORTED:-0}
+external_peer=${I915_CRIU_EXTERNAL_PEER:-0}
+retained_dmabuf=${I915_CRIU_RETAINED_DMABUF:-0}
+external_dmabuf=${I915_CRIU_EXTERNAL_DMABUF_PEER:-0}
+cc=${CC:-gcc}
+fixture="$work/i915-gem-sharing"
+fixture_source=${FIXTURE:-/tmp/i915-gem-sharing}
+images="$work/images"
+log="$work/fixture.log"
+
+cleanup() {
+    if [[ -n ${fixture_pid:-} ]]; then
+        kill -KILL "$fixture_pid" 2>/dev/null || true
+    fi
+    if [[ -n ${child_pid:-} ]]; then
+        kill -KILL "$child_pid" 2>/dev/null || true
+    fi
+    if [[ -n ${external_dmabuf_pid:-} && $external_dmabuf_pid != 0 ]]; then
+        kill -KILL "$external_dmabuf_pid" 2>/dev/null || true
+    fi
+}
+trap cleanup EXIT
+rm -rf "$work"
+mkdir -p "$images"
+
+if [[ -x $fixture_source ]]; then
+    cp "$fixture_source" "$fixture"
+elif command -v "$cc" >/dev/null; then
+    "$cc" -std=c11 -Wall -Wextra -Werror -I"$repo" \
+        "$repo/test/others/i915-criu/i915-gem-sharing.c" -o "$fixture"
+else
+    echo "no prebuilt fixture at $fixture_source and compiler $cc is unavailable" >&2
+    exit 2
+fi
+
+fixture_args=()
+if (( external_peer + retained_dmabuf + external_dmabuf > 1 )); then
+    echo 'external-peer, retained-dmabuf, and external-dmabuf-peer modes are mutually exclusive' >&2
+    exit 2
+elif [[ $external_peer == 1 ]]; then
+    fixture_args+=(--external-peer)
+    expect_unsupported=1
+elif [[ $retained_dmabuf == 1 ]]; then
+    fixture_args+=(--retained-dmabuf)
+elif [[ $external_dmabuf == 1 ]]; then
+    fixture_args+=(--external-dmabuf-peer)
+    expect_unsupported=1
+fi
+"$fixture" "${fixture_args[@]}" >"$log" 2>&1 &
+fixture_pid=$!
+for _ in $(seq 1 100); do
+    grep -q '^READY ' "$log" && break
+    kill -0 "$fixture_pid"
+    sleep 0.05
+done
+grep -q '^READY ' "$log"
+original_pid=$fixture_pid
+original_address=$(sed -n 's/^READY .* address=\([^ ]*\).*/\1/p' "$log")
+child_pid=$(sed -n 's/^READY .* child=\([0-9]*\).*/\1/p' "$log")
+external_dmabuf_pid=$(sed -n 's/^READY .* external_dmabuf=\([0-9]*\).*/\1/p' "$log")
+child_address=$(sed -n 's/^CHILD .* address=\([^ ]*\).*/\1/p' "$log")
+
+if [[ $expect_unsupported == 1 ]]; then
+    set +e
+    "$criu" dump -t "$original_pid" -D "$images" --shell-job \
+        "${plugin_args[@]}" --log-file dump.log -v4
+    dump_status=$?
+    set -e
+    if (( dump_status == 0 || dump_status >= 128 )); then
+        echo "sharing dump did not fail safely: status=$dump_status" >&2
+        exit 1
+    fi
+    grep -q 'Dumping FAILED' "$images/dump.log"
+    if [[ $external_peer == 1 ]]; then
+        grep -q 'captured handles but .* exist' "$images/dump.log"
+        printf 'PASS: external sharing peer refused before dump completion (status=%s)\n' \
+            "$dump_status"
+    elif [[ $external_dmabuf == 1 ]]; then
+        grep -q 'captured dma-buf fds but refcount .* is not complete' \
+            "$images/dump.log"
+        printf 'PASS: external dma-buf peer refused before dump completion (status=%s)\n' \
+            "$dump_status"
+    else
+        printf 'PASS: unsupported sharing dump refused without a CRIU crash (status=%s)\n' \
+            "$dump_status"
+    fi
+    exit 0
+fi
+
+"$criu" dump -t "$original_pid" -D "$images" --shell-job \
+    "${plugin_args[@]}" --log-file dump.log -v4
+wait "$fixture_pid" 2>/dev/null || true
+fixture_pid=
+for _ in $(seq 1 200); do
+    [[ $(cat "/proc/$child_pid/comm" 2>/dev/null || true) != i915-gem-sharin ]] && break
+    sleep 0.05
+done
+if [[ $(cat "/proc/$child_pid/comm" 2>/dev/null || true) == i915-gem-sharin ]]; then
+    echo "dumped child pid $child_pid was not reaped before restore" >&2
+    exit 1
+fi
+
+i915_images=("$images"/i915-criu-*.img)
+(( ${#i915_images[@]} >= 2 ))
+for image in "${i915_images[@]}"; do
+    test -s "$image"
+done
+"$criu" restore -D "$images" --shell-job --restore-detached \
+    "${plugin_args[@]}" --log-file restore.log -v4
+fixture_pid=$original_pid
+kill -USR1 "$fixture_pid"
+
+for _ in $(seq 1 100); do
+    grep -q '^PASS: two-process dma-buf identity, mappings, CPU sharing, and GPU execution$' "$log" && break
+    kill -0 "$fixture_pid" 2>/dev/null || true
+    sleep 0.05
+done
+grep -q '^PASS: two-process dma-buf identity, mappings, CPU sharing, and GPU execution$' "$log"
+for pid in "$original_pid" "$child_pid"; do
+    for _ in $(seq 1 100); do
+        [[ $(cat "/proc/$pid/comm" 2>/dev/null || true) != i915-gem-sharin ]] && break
+        sleep 0.05
+    done
+    if [[ $(cat "/proc/$pid/comm" 2>/dev/null || true) == i915-gem-sharin ]]; then
+        echo "restored sharing fixture pid $pid did not exit" >&2
+        exit 1
+    fi
+done
+fixture_pid=
+
+printf 'PASS: CRIU restored parent=%s child=%s parent_address=%s child_address=%s\n' \
+    "$original_pid" "$child_pid" "$original_address" "$child_address"
