++		/* Version 1 relies only on the pristine context created at open. */
++		if (!has_only_untouched_default_context(fpriv)) {
++			ret = -EOPNOTSUPP;
++			break;
++		}
++		fpriv->criu_mode = I915_CRIU_MODE_DUMP;
++		fpriv->criu_cookie = get_random_u64();
++		if (!fpriv->criu_cookie)
++			fpriv->criu_cookie = 1;
++		args->cookie = fpriv->criu_cookie;
++		break;
++	case I915_CRIU_SESSION_RESTORE_BEGIN:
++		if (!capable(CAP_SYS_ADMIN)) {
++			ret = -EPERM;
++			break;
++		}
++		if (args->target_pid || fpriv->criu_mode != I915_CRIU_MODE_NONE) {
++			ret = -EINVAL;
++			break;
++		}
++		fpriv->criu_mode = I915_CRIU_MODE_RESTORE;
++		fpriv->criu_cookie = get_random_u64();
++		if (!fpriv->criu_cookie)
