+static int refresh_dump_relationship(struct object_relationship *relationship)
+{
+	struct drm_i915_criu_object query = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_OBJECT_QUERY,
+		.handle = relationship->verification_handle - 1,
+	};
+	uint64_t cookie = 0;
+	int ret;
+
+	if (relationship->verification_fd < 0 ||
+	    !relationship->verification_handle)
+		return -EINVAL;
+	ret = session_ioctl(relationship->verification_fd,
+			    I915_CRIU_SESSION_DUMP_BEGIN,
+			    checkpoint_pid, &cookie);
+	if (ret)
+		goto out;
+	query.cookie = cookie;
+	if (ioctl(relationship->verification_fd,
+		  DRM_IOCTL_I915_CRIU_OBJECT, &query) < 0)
+		ret = -errno;
+	else if (query.handle != relationship->verification_handle ||
+		 query.object_id != relationship->object_id ||
+		 query.handle_count != relationship->expected_handles ||
+		 query.dma_buf_attachment_count)
+		ret = -EXDEV;
+	else
+		relationship->expected_dma_buf_refcount =
+			query.dma_buf_refcount;
+	if (session_ioctl(relationship->verification_fd,
+			  ret ? I915_CRIU_SESSION_ABORT :
+				I915_CRIU_SESSION_COMMIT,
+			  0, &cookie) && !ret)
+		ret = -EIO;
+out:
+	close(relationship->verification_fd);
+	relationship->verification_fd = -1;
+	return ret;
+}
+
+static int patch_dump_image_refcounts(int file_id)
+{
+	struct i915_image_header header;
+	int fd = image_fd(file_id, O_RDWR);
+	int ret;
+
+	if (fd < 0)
+		return fd;
+	ret = read_all(fd, &header, sizeof(header));
+	if (ret || header.magic != I915_IMAGE_MAGIC ||
+	    header.version != I915_IMAGE_VERSION ||
+	    header.file_id != (uint32_t)file_id ||
+	    header.kind != I915_IMAGE_KIND_DRM_FILE) {
+		close(fd);
+		return ret ? ret : -EINVAL;
+	}
+	for (uint32_t i = 0; i < header.object_count; i++) {
+		struct i915_image_object object;
+		off_t offset = lseek(fd, 0, SEEK_CUR);
+		struct object_relationship *relationship;
+
+		if (offset < 0 || read_all(fd, &object, sizeof(object))) {
+			close(fd);
+			return -EIO;
+		}
+		relationship = dump_relationship(object.object_id);
+		if (!relationship || !relationship->metadata_seen) {
+			close(fd);
+			return -ENOENT;
+		}
+		object.dma_buf_refcount =
+			relationship->expected_dma_buf_refcount;
+		ret = pwrite_all(fd, &object, sizeof(object), offset);
+		if (ret || lseek(fd, object.size, SEEK_CUR) < 0) {
+			close(fd);
+			return ret ? ret : -EIO;
+		}
+	}
+	close(fd);
+	return 0;
+}
+
+static int patch_dump_images(void)
+{
+	DIR *directory;
+	struct dirent *entry;
+	int directory_fd = dup(criu_get_image_dir());
+	int ret = 0;
+
+	if (directory_fd < 0)
+		return -errno;
+	directory = fdopendir(directory_fd);
+	if (!directory) {
+		close(directory_fd);
+		return -errno;
+	}
+	while ((entry = readdir(directory))) {
+		char trailing;
+		int id;
+
+		if (sscanf(entry->d_name, "i915-criu-%d.img%c", &id,
+			   &trailing) != 1)
+			continue;
+		ret = patch_dump_image_refcounts(id);
+		if (ret)
+			break;
+	}
+	closedir(directory);
+	return ret;
+}
+
+int i915_plugin_finalize_devices(void)
+{
+	for (size_t i = 0; i < dump_relationship_count; i++) {
+		struct object_relationship *relationship = &dump_relationships[i];
+		uint64_t expected_dma_buf_refcount;
+
+		if (!relationship->metadata_seen) {
+			pr_err("i915 dma-buf object %#" PRIx64
+			       " has no captured GEM handle\n",
+			       relationship->object_id);
+			return -EXDEV;
+		}
+		if (refresh_dump_relationship(relationship)) {
+			pr_err("failed final i915 relationship query for object %#" PRIx64
+			       "\n", relationship->object_id);
+			return -EXDEV;
+		}
+		if (relationship->seen_handles != relationship->expected_handles) {
+			pr_err("i915 object %#" PRIx64
+			       " has %u captured handles but %u exist\n",
+			       relationship->object_id,
+			       relationship->seen_handles,
+			       relationship->expected_handles);
+			return -EXDEV;
+		}
+		expected_dma_buf_refcount = relationship->expected_dma_buf_refcount;
+		if (!expected_dma_buf_refcount &&
+		    relationship->seen_dma_buf_fds) {
+			pr_err("i915 object %#" PRIx64
+			       " has dma-buf fds but no exported dma-buf\n",
+			       relationship->object_id);
+			return -EXDEV;
+		}
+		if (expected_dma_buf_refcount &&
+		    expected_dma_buf_refcount !=
+			1 + (uint64_t)relationship->expected_handles +
+			relationship->seen_dma_buf_fds) {
+			pr_err("i915 object %#" PRIx64
+			       " has %u captured dma-buf fds but refcount %u is not complete\n",
+			       relationship->object_id,
+			       relationship->seen_dma_buf_fds,
+			       relationship->expected_dma_buf_refcount);
+			return -EXDEV;
+		}
+	}
+	if (patch_dump_images())
+		return -EIO;
+	for (size_t i = 0; i < dump_dmabuf_file_count; i++) {
+		struct dump_dmabuf_file *file = &dump_dmabuf_files[i];
+		int ret = write_dmabuf_image(file->file_id, file->object_id,
+					     file->fd_count);
+
+		if (ret)
+			return ret;
+	}
+	return 0;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__FINALIZE_DEVICES,
+			 i915_plugin_finalize_devices)
+
+static int validate_image_object(const struct i915_image_object *image)
+{
+	if (!image->object_id || !image->size ||
+	    image->size > I915_MAX_OBJECT_SIZE ||
+	    image->flags != I915_CRIU_OBJECT_SHMEM ||
+	    image->mmap_type != I915_MMAP_OFFSET_WB ||
+	    !image->mmap_offset || !image->handle_count ||
+	    image->sharing_flags & ~I915_CRIU_OBJECT_SHARED ||
+	    image->dma_buf_attachment_count ||
+	    (image->dma_buf_refcount &&
+	     !(image->sharing_flags & I915_CRIU_OBJECT_SHARED)))
+		return -EINVAL;
+
+	for (size_t i = 0; i < restore_object_count; i++) {
+		if (restore_objects[i].object_id == image->object_id) {
+			if (restore_objects[i].old_mmap_offset != image->mmap_offset ||
+			    restore_objects[i].size != image->size ||
+			    restore_objects[i].handle_count != image->handle_count ||
+			    restore_objects[i].sharing_flags != image->sharing_flags ||
+			    restore_objects[i].dma_buf_refcount !=
+				image->dma_buf_refcount)
+				return -EINVAL;
+			return 0;
+		}
+		if (restore_objects[i].old_mmap_offset == image->mmap_offset)
+			return -EEXIST;
+	}
+	return 0;
+}
+
+static int restore_object(int fd, uint64_t cookie,
+			  const struct i915_image_object *image,
+			  const void *contents)
+{
+	struct drm_i915_criu_object create = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_OBJECT_CREATE,
+		.cookie = cookie,
+		.flags = image->flags,
+		.object_id = image->object_id,
+		.size = image->size,
+		.handle_count = image->handle_count,
+		.sharing_flags = image->sharing_flags,
+	};
+	struct drm_i915_criu_data write_data;
+	struct drm_i915_gem_mmap_offset mmap_offset;
+
+	for (size_t i = 0; i < restore_object_count; i++) {
+		struct restore_object *existing = &restore_objects[i];
+		struct drm_i915_gem_pread pread;
+		void *verify;
+		uint32_t handle;
+		int object_fd;
+		int prime_fd;
+		int ret;
+
+		if (existing->object_id != image->object_id)
+			continue;
+		if (existing->prime_fdstore_id < 0)
+			return -EINVAL;
+		object_fd = existing->transient_fd >= 0 ? existing->transient_fd :
+			criu_plugin_fdstore_get(existing->fdstore_id);
+		prime_fd = criu_plugin_fdstore_get(existing->prime_fdstore_id);
+		if (object_fd < 0 || prime_fd < 0) {
+			if (existing->transient_fd < 0 && object_fd >= 0)
+				close(object_fd);
+			if (prime_fd >= 0)
+				close(prime_fd);
+			return -EIO;
+		}
+		verify = xmalloc(image->size);
+		if (!verify) {
+			if (existing->transient_fd < 0)
+				close(object_fd);
+			close(prime_fd);
+			return -ENOMEM;
+		}
+		pread = (struct drm_i915_gem_pread) {
+			.handle = existing->handle,
+			.size = image->size,
+			.data_ptr = (uintptr_t)verify,
+		};
+		if (ioctl(object_fd, DRM_IOCTL_I915_GEM_PREAD, &pread) < 0)
+			ret = -errno;
+		else
+			ret = memcmp(verify, contents, image->size) ? -EILSEQ : 0;
+		xfree(verify);
+		if (existing->transient_fd < 0)
+			close(object_fd);
+		if (!ret)
+			ret = drmPrimeFDToHandle(fd, prime_fd, &handle);
+		close(prime_fd);
+		if (ret)
+			return ret;
+		create.op = I915_CRIU_OBJECT_IMPORT;
+		create.handle = handle;
+		if (ioctl(fd, DRM_IOCTL_I915_CRIU_OBJECT, &create) < 0) {
+			ret = -errno;
+			struct drm_gem_close close_handle = { .handle = handle };
+			ioctl(fd, DRM_IOCTL_GEM_CLOSE, &close_handle);
+			return ret;
+		}
+		existing->restored_handles++;
+		return 0;
+	}
+
+	if (restore_object_count == I915_MAX_RESTORE_OBJECTS)
+		return -E2BIG;
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_OBJECT, &create) < 0)
+		return -errno;
+
+	write_data = (struct drm_i915_criu_data) {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_DATA_WRITE,
+		.cookie = cookie,
+		.handle = create.handle,
+		.size = image->size,
+		.data_ptr = (uintptr_t)contents,
+	};
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_DATA, &write_data) < 0)
+		return -errno;
+
+	mmap_offset = (struct drm_i915_gem_mmap_offset) {
+		.handle = create.handle,
+		.flags = image->mmap_type,
+	};
+	if (ioctl(fd, DRM_IOCTL_I915_GEM_MMAP_OFFSET, &mmap_offset) < 0)
+		return -errno;
+
+	restore_objects[restore_object_count] = (struct restore_object) {
+		.object_id = image->object_id,
+		.old_mmap_offset = image->mmap_offset,
+		.new_mmap_offset = mmap_offset.offset,
+		.size = image->size,
+		.handle_count = image->handle_count,
+		.sharing_flags = image->sharing_flags,
+		.dma_buf_refcount = image->dma_buf_refcount,
+		.handle = create.handle,
+		.restored_handles = 1,
+		.transient_fd = fd,
+		.fdstore_id = -1,
+		.prime_fdstore_id = -1,
+	};
+	if (image->handle_count > 1 ||
+	    image->sharing_flags & I915_CRIU_OBJECT_SHARED) {
+		int prime_fd;
+		int ret = drmPrimeHandleToFD(fd, create.handle,
+					     DRM_CLOEXEC | DRM_RDWR, &prime_fd);
+		if (ret)
+			return ret;
+		ret = criu_plugin_fdstore_add(prime_fd);
+		close(prime_fd);
+		if (ret < 0)
+			return -EIO;
+		restore_objects[restore_object_count].prime_fdstore_id = ret;
+	}
+	restore_object_count++;
+	return 0;
+}
+
+static int restore_syncobj(int fd, uint64_t cookie,
+			   const struct i915_image_syncobj *image,
+			   uint32_t previous_handle)
+{
+	const uint32_t supported = I915_CRIU_SYNCOBJ_EMPTY |
+		I915_CRIU_SYNCOBJ_BINARY_SIGNALED |
+		I915_CRIU_SYNCOBJ_TIMELINE;
+	struct drm_i915_criu_syncobj create = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_SYNCOBJ_CREATE,
+		.handle = image->handle,
+		.flags = image->flags,
+		.point = image->point,
+	};
+
+	if (!image->handle || image->handle <= previous_handle ||
+	    !image->flags || (image->flags & ~supported) ||
+	    (image->flags & (image->flags - 1)) ||
+	    (image->flags != I915_CRIU_SYNCOBJ_TIMELINE && image->point) ||
+	    (image->flags == I915_CRIU_SYNCOBJ_TIMELINE && !image->point))
+		return -EINVAL;
+	create.cookie = cookie;
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_SYNCOBJ, &create) < 0)
+		return -errno;
+	if (image->flags == I915_CRIU_SYNCOBJ_TIMELINE) {
+		uint32_t handle = create.handle;
+		uint64_t point = image->point;
+		struct drm_syncobj_timeline_array signal = {
+			.handles = (uintptr_t)&handle,
+			.points = (uintptr_t)&point,
+			.count_handles = 1,
+		};
+
+		if (ioctl(fd, DRM_IOCTL_SYNCOBJ_TIMELINE_SIGNAL, &signal) < 0)
+			return -errno;
+	}
+	return 0;
+}
+
+static int restore_context_state(int fd, uint64_t cookie,
+				 const struct i915_image_context *image,
+				 uint32_t op, uint32_t previous_id)
+{
+	const uint32_t supported = I915_CRIU_CONTEXT_SINGLE_TIMELINE |
+		I915_CRIU_CONTEXT_NO_ERROR_CAPTURE |
+		I915_CRIU_CONTEXT_BANNABLE | I915_CRIU_CONTEXT_RECOVERABLE |
+		I915_CRIU_CONTEXT_PERSISTENCE;
+	struct drm_i915_criu_context create = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = op,
+		.cookie = cookie,
+		.id = image->id,
+		.flags = image->flags,
+		.vm_id = image->vm_id,
+		.priority = image->priority,
+	};
+
+	if (!image->id || image->id <= previous_id)
+		return -EINVAL;
+	if (op == I915_CRIU_CONTEXT_CREATE_VM) {
+		if (image->flags || image->vm_id || image->priority)
+			return -EINVAL;
+	} else if (op == I915_CRIU_CONTEXT_CREATE_CONTEXT) {
+		if (image->flags & ~supported)
+			return -EINVAL;
+	} else {
+		return -EINVAL;
+	}
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_CONTEXT, &create) < 0)
+		return -errno;
+	return 0;
+}
+
+static int restore_binding(int fd, uint64_t cookie,
+			   const struct i915_image_binding *image,
+			   uint32_t previous_vm, uint64_t previous_address)
+{
+	struct drm_i915_criu_binding create = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_BINDING_CREATE,
+		.cookie = cookie,
+		.vm_id = image->vm_id,
+		.flags = image->flags,
+		.object_id = image->object_id,
+		.address = image->address,
+		.size = image->size,
+	};
+	bool object_found = false;
+
+	if (!image->vm_id || !image->object_id || !image->size ||
+	    image->flags != I915_CRIU_BINDING_LOCAL ||
+	    image->vm_id < previous_vm ||
+	    (image->vm_id == previous_vm && image->address <= previous_address))
+		return -EINVAL;
+	for (size_t i = 0; i < restore_object_count; i++) {
+		if (restore_objects[i].object_id == image->object_id) {
+			object_found = restore_objects[i].size == image->size;
+			break;
+		}
+	}
+	if (!object_found)
+		return -ENOENT;
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_BINDING, &create) < 0)
+		return -errno;
+	return 0;
+}
+
+static int restore_file_image(int id)
+{
+	struct i915_image_header header;
+	struct restore_file *restore_file;
+	uint64_t cookie = 0;
+	int image;
+	int fd;
+	int ret;
+
+	image = image_fd(id, O_RDONLY);
+	if (image < 0)
+		return -ENOTSUP;
+	ret = read_all(image, &header, sizeof(header));
+	if (ret || header.magic != I915_IMAGE_MAGIC ||
+	    header.version != I915_IMAGE_VERSION || header.file_id != (uint32_t)id ||
+	    header.object_count > I915_MAX_RESTORE_OBJECTS ||
+	    header.syncobj_count > I915_MAX_RESTORE_SYNCOBJS ||
+	    header.vm_count > I915_MAX_RESTORE_VMS ||
+	    header.context_count > I915_MAX_RESTORE_CONTEXTS ||
+	    header.binding_count > I915_MAX_RESTORE_BINDINGS ||
+	    header.kind != I915_IMAGE_KIND_DRM_FILE) {
+		close(image);
+		return ret ? ret : -EINVAL;
+	}
+
+	fd = open(render_node(), O_RDWR | O_CLOEXEC);
+	if (fd < 0) {
+		close(image);
+		return -errno;
+	}
+	if (restore_file_count == I915_MAX_RESTORE_FILES) {
+		close(image);
+		close(fd);
+		return -E2BIG;
+	}
+
+	ret = session_ioctl(fd, I915_CRIU_SESSION_RESTORE_BEGIN, 0, &cookie);
+	if (ret) {
+		close(image);
+		close(fd);
+		return ret;
+	}
+	for (uint32_t i = 0; i < header.object_count; i++) {
+		struct i915_image_object object;
+		void *contents;
+
+		ret = read_all(image, &object, sizeof(object));
+		if (ret)
+			break;
+		ret = validate_image_object(&object);
+		if (ret)
+			break;
+		contents = xmalloc(object.size);
+		if (!contents) {
+			ret = -ENOMEM;
+			break;
+		}
+		ret = read_all(image, contents, object.size);
+		if (!ret)
+			ret = restore_object(fd, cookie, &object, contents);
+		xfree(contents);
+		if (ret)
+			break;
+	}
+	for (uint32_t i = 0, previous = 0;
+	     !ret && i < header.syncobj_count; i++) {
+		struct i915_image_syncobj syncobj;
+
+		ret = read_all(image, &syncobj, sizeof(syncobj));
+		if (!ret)
+			ret = restore_syncobj(fd, cookie, &syncobj, previous);
+		if (!ret)
+			previous = syncobj.handle;
+	}
+	for (uint32_t i = 0, previous = 0;
+	     !ret && i < header.vm_count; i++) {
+		struct i915_image_context vm;
+
+		ret = read_all(image, &vm, sizeof(vm));
+		if (!ret)
+			ret = restore_context_state(fd, cookie, &vm,
+						    I915_CRIU_CONTEXT_CREATE_VM,
+						    previous);
+		if (!ret)
+			previous = vm.id;
+	}
+	for (uint32_t i = 0, previous = 0;
+	     !ret && i < header.context_count; i++) {
+		struct i915_image_context context;
+
+		ret = read_all(image, &context, sizeof(context));
+		if (!ret)
+			ret = restore_context_state(fd, cookie, &context,
+						    I915_CRIU_CONTEXT_CREATE_CONTEXT,
+						    previous);
+		if (!ret)
+			previous = context.id;
+	}
+	{
+		uint32_t previous_vm = 0;
+		uint64_t previous_address = 0;
+
+		for (uint32_t i = 0; !ret && i < header.binding_count; i++) {
+			struct i915_image_binding binding;
+
+			ret = read_all(image, &binding, sizeof(binding));
+			if (!ret && binding.vm_id != previous_vm)
+				previous_address = 0;
+			if (!ret)
+				ret = restore_binding(fd, cookie, &binding,
+						      previous_vm,
+						      previous_address);
+			if (!ret) {
+				previous_vm = binding.vm_id;
+				previous_address = binding.address;
+			}
+		}
+	}
+	if (!ret) {
+		char trailing;
+		ssize_t got;
+
+		do {
+			got = read(image, &trailing, sizeof(trailing));
+		} while (got < 0 && errno == EINTR);
+		if (got != 0)
+			ret = got < 0 ? -errno : -EINVAL;
+	}
+	close(image);
+	if (ret) {
+		session_ioctl(fd, I915_CRIU_SESSION_ABORT, 0, &cookie);
+		abort_restore_sessions();
+		close(fd);
+		return ret;
+	}
+
+	ret = criu_plugin_fdstore_add(fd);
+	if (ret < 0) {
+		session_ioctl(fd, I915_CRIU_SESSION_ABORT, 0, &cookie);
+		abort_restore_sessions();
+		close(fd);
+		return -EIO;
+	}
+	restore_file = &restore_files[restore_file_count++];
+	*restore_file = (struct restore_file) {
+		.fdstore_id = ret,
+		.cookie = cookie,
+		.active = true,
+	};
+	for (size_t i = 0; i < restore_object_count; i++) {
+		if (restore_objects[i].transient_fd != fd)
+			continue;
+		restore_objects[i].transient_fd = -1;
+		restore_objects[i].fdstore_id = ret;
+	}
+	close(fd);
+	ret = criu_plugin_fdstore_get(restore_file->fdstore_id);
+	return ret < 0 ? -EIO : ret;
+}
+static int restore_dmabuf_image(int id)
+{
+	struct i915_image_header header;
+	struct i915_image_dmabuf image;
+	int fd;
+	int ret;
+
+	fd = image_fd(id, O_RDONLY);
+	if (fd < 0)
+		return -ENOTSUP;
+	ret = read_all(fd, &header, sizeof(header));
+	if (!ret)
+		ret = read_all(fd, &image, sizeof(image));
+	if (!ret && (header.magic != I915_IMAGE_MAGIC ||
+		     header.version != I915_IMAGE_VERSION ||
+		     header.file_id != (uint32_t)id ||
+		     header.kind != I915_IMAGE_KIND_DMABUF ||
+		     header.object_count || header.syncobj_count ||
+		     header.vm_count || header.context_count ||
+		     header.binding_count || !image.object_id || !image.fd_count ||
+		     image.reserved))
+		ret = -EINVAL;
+	if (!ret) {
+		char trailing;
+		ssize_t got;
+
+		do {
+			got = read(fd, &trailing, sizeof(trailing));
+		} while (got < 0 && errno == EINTR);
+		if (got != 0)
+			ret = got < 0 ? -errno : -EINVAL;
+	}
+	close(fd);
+	if (ret)
+		return ret;
+	for (size_t i = 0; i < restore_object_count; i++) {
+		struct restore_object *object = &restore_objects[i];
+
+		if (object->object_id != image.object_id)
+			continue;
+		if (object->prime_fdstore_id < 0 ||
+		    image.fd_count > UINT32_MAX - object->restored_dma_buf_fds)
+			return -EINVAL;
+		object->restored_dma_buf_fds += image.fd_count;
+		fd = criu_plugin_fdstore_get(object->prime_fdstore_id);
+		return fd < 0 ? -EIO : fd;
+	}
+	return -ENOENT;
+}
+
+struct restore_image {
+	int id;
+	uint32_t kind;
+};
+
+static int read_image_kind(int id, uint32_t *kind)
+{
+	struct i915_image_header header;
+	int fd = image_fd(id, O_RDONLY);
+	int ret;
+
+	if (fd < 0)
+		return fd;
+	ret = read_all(fd, &header, sizeof(header));
+	close(fd);
+	if (ret)
+		return ret;
+	if (header.magic != I915_IMAGE_MAGIC ||
+	    header.version != I915_IMAGE_VERSION ||
+	    header.file_id != (uint32_t)id ||
+	    (header.kind != I915_IMAGE_KIND_DRM_FILE &&
+	     header.kind != I915_IMAGE_KIND_DMABUF))
+		return -EINVAL;
+	*kind = header.kind;
+	return 0;
+}
+
+static int compare_restore_images(const void *left, const void *right)
+{
+	const struct restore_image *a = left;
+	const struct restore_image *b = right;
+
+	if (a->kind != b->kind)
+		return (a->kind > b->kind) - (a->kind < b->kind);
+	return (a->id > b->id) - (a->id < b->id);
+}
+
+int i915_plugin_prepare_restore(void)
+{
+	DIR *directory;
+	struct dirent *entry;
+	struct restore_image images[I915_MAX_RESTORE_FILES];
+	size_t image_count = 0;
+	int directory_fd;
+
+	directory_fd = dup(criu_get_image_dir());
+	if (directory_fd < 0)
+		return -errno;
+	directory = fdopendir(directory_fd);
+	if (!directory) {
+		close(directory_fd);
+		return -errno;
+	}
+	while ((entry = readdir(directory))) {
+		char trailing;
+		int id;
+
+		if (sscanf(entry->d_name, "i915-criu-%d.img%c", &id,
+			   &trailing) != 1)
+			continue;
+		if (id < 0 || image_count == I915_MAX_RESTORE_FILES) {
+			closedir(directory);
+			return -E2BIG;
+		}
+		images[image_count].id = id;
+		if (read_image_kind(id, &images[image_count].kind)) {
+			closedir(directory);
+			return -EINVAL;
+		}
+		image_count++;
+	}
+	closedir(directory);
+	qsort(images, image_count, sizeof(images[0]), compare_restore_images);
+
+	for (size_t i = 0; i < image_count; i++) {
+		int fd = images[i].kind == I915_IMAGE_KIND_DRM_FILE ?
+			restore_file_image(images[i].id) :
+			restore_dmabuf_image(images[i].id);
+		int fdstore_id;
+
+		if (fd < 0) {
+			pr_err("failed to prepare i915 image %d: %d\n",
+			       images[i].id, fd);
+			return fd;
+		}
+		fdstore_id = criu_plugin_fdstore_add(fd);
+		close(fd);
+		if (fdstore_id < 0)
+			return -EIO;
+		prepared_files[prepared_file_count++] = (struct prepared_file) {
+			.file_id = images[i].id,
+			.fdstore_id = fdstore_id,
+		};
+	}
+	for (size_t i = 0; i < restore_object_count; i++) {
+		struct restore_object *object = &restore_objects[i];
+		uint64_t expected_fds;
+
+		if (!object->dma_buf_refcount)
+			continue;
+		if (object->dma_buf_refcount < 1 + object->handle_count)
+			return -EINVAL;
+		expected_fds = object->dma_buf_refcount - 1 - object->handle_count;
+		if (expected_fds != object->restored_dma_buf_fds)
+			return -EXDEV;
+	}
+	return 0;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__PREPARE_RESTORE,
+			 i915_plugin_prepare_restore)
+
+int i915_plugin_restore_file(int id)
+{
+	for (size_t i = 0; i < prepared_file_count; i++) {
+		if (prepared_files[i].file_id == id)
+			return criu_plugin_fdstore_get(prepared_files[i].fdstore_id);
+	}
+	return -ENOTSUP;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__RESTORE_EXT_FILE,
+			 i915_plugin_restore_file)
+
+int i915_plugin_update_vma_map(const char *path, uint64_t addr,
+			       uint64_t old_pgoff, uint64_t *new_pgoff,
+			       int *plugin_fd)
+{
+	(void)path;
+	(void)addr;
+	for (size_t i = 0; i < restore_object_count; i++) {
+		if (restore_objects[i].old_mmap_offset != old_pgoff)
+			continue;
+		*new_pgoff = restore_objects[i].new_mmap_offset;
+		*plugin_fd = criu_plugin_fdstore_get(restore_objects[i].fdstore_id);
+		return *plugin_fd < 0 ? -EIO : 1;
+	}
+	return 0;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__UPDATE_VMA_MAP,
+			 i915_plugin_update_vma_map)
+
+int i915_plugin_resume_devices_late(int pid)
+{
+	(void)pid;
+	for (size_t i = 0; i < restore_object_count; i++) {
+		if (restore_objects[i].restored_handles !=
+		    restore_objects[i].handle_count) {
+			pr_err("i915 object %#" PRIx64
+			       " restored %u handles but image requires %u\n",
+			       restore_objects[i].object_id,
+			       restore_objects[i].restored_handles,
+			       restore_objects[i].handle_count);
+			return -EXDEV;
+		}
+	}
+	for (size_t i = 0; i < restore_file_count; i++) {
+		int fd;
+		int ret;
+
+		if (!restore_files[i].active)
+			continue;
+		fd = criu_plugin_fdstore_get(restore_files[i].fdstore_id);
+		if (fd < 0)
+			return -EIO;
+		ret = session_ioctl(fd, I915_CRIU_SESSION_COMMIT,
+				    0, &restore_files[i].cookie);
+		close(fd);
+		if (ret)
+			return ret;
+		restore_files[i].active = false;
+	}
+	return 0;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__RESUME_DEVICES_LATE,
+			 i915_plugin_resume_devices_late)
diff --git a/test/others/i915-criu/i915-context-sync.c b/test/others/i915-criu/i915-context-sync.c
new file mode 100644
