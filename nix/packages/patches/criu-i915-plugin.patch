+#include <errno.h>
+#include <fcntl.h>
+#include <poll.h>
+#include <signal.h>
+#include <stdbool.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/ioctl.h>
+#include <sys/mman.h>
+#include <unistd.h>
+
+#include <drm/drm.h>
+#include <drm/drm_fourcc.h>
+#include <drm/drm_mode.h>
+#include <drm/i915_drm.h>
+#include <xf86drm.h>
+#include <xf86drmMode.h>
+
+#define MODE_ID_RESERVATIONS 128
+
+struct dumb_buffer {
+	uint32_t handle;
+	uint32_t pitch;
+	uint64_t size;
+	uint32_t fb_id;
+	uint32_t *mapping;
+};
+
+struct kms_properties {
+	uint32_t connector_crtc_id;
+	uint32_t crtc_active;
+	uint32_t crtc_mode_id;
+	uint32_t plane_fb_id;
+	uint32_t plane_crtc_id;
+	uint32_t crtc_x;
+	uint32_t crtc_y;
+	uint32_t crtc_w;
+	uint32_t crtc_h;
+	uint32_t src_x;
+	uint32_t src_y;
+	uint32_t src_w;
+	uint32_t src_h;
+};
+
+static volatile sig_atomic_t resumed;
+
+static void on_signal(int signo)
+{
+	(void)signo;
+	resumed = 1;
+}
+
+static void die(const char *what)
+{
+	perror(what);
+	exit(EXIT_FAILURE);
+}
+
+static void fail(const char *what)
+{
+	fprintf(stderr, "%s\n", what);
+	exit(EXIT_FAILURE);
+}
+
+static int open_i915_node(int node_type)
+{
+	char path[64];
+	unsigned int first = node_type == DRM_NODE_RENDER ? 128 : 0;
+	unsigned int last = node_type == DRM_NODE_RENDER ? 192 : 64;
+
+	for (unsigned int index = first; index < last; index++) {
+		drmVersionPtr version;
+		int fd;
+
+		snprintf(path, sizeof(path),
+			 node_type == DRM_NODE_RENDER ? "/dev/dri/renderD%u" :
+							"/dev/dri/card%u",
+			 index);
+		fd = open(path, O_RDWR | O_CLOEXEC);
+		if (fd < 0)
+			continue;
+		version = drmGetVersion(fd);
+		if (version && version->name && !strcmp(version->name, "i915") &&
+		    drmGetNodeTypeFromFd(fd) == node_type) {
+			drmFreeVersion(version);
+			return fd;
+		}
+		if (version)
+			drmFreeVersion(version);
+		close(fd);
+	}
+	errno = ENODEV;
+	return -1;
+}
+
+static int open_i915_primary(void)
+{
+	return open_i915_node(DRM_NODE_PRIMARY);
+}
+
+static int run_reset_load(void)
+{
+	enum { LOAD_SIZE = 4 * 1024 * 1024 };
+	struct drm_i915_gem_create create = { .size = LOAD_SIZE };
+	struct drm_i915_gem_mmap_offset mmap_offset = {
+		.flags = I915_MMAP_OFFSET_WB,
+	};
+	struct drm_i915_gem_exec_object2 object = { 0 };
+	struct drm_i915_gem_execbuffer2 execbuf = {
+		.buffers_ptr = (uintptr_t)&object,
+		.buffer_count = 1,
+		.batch_len = LOAD_SIZE,
+		.flags = I915_EXEC_RENDER,
+	};
+	uint32_t *batch;
+	int fd = open_i915_node(DRM_NODE_RENDER);
+
+	if (fd < 0)
+		die("open i915 render node");
+	if (ioctl(fd, DRM_IOCTL_I915_GEM_CREATE, &create) < 0)
+		die("reset load GEM_CREATE");
+	mmap_offset.handle = create.handle;
+	if (ioctl(fd, DRM_IOCTL_I915_GEM_MMAP_OFFSET, &mmap_offset) < 0)
+		die("reset load GEM_MMAP_OFFSET");
+	batch = mmap(NULL, LOAD_SIZE, PROT_READ | PROT_WRITE, MAP_SHARED,
+		     fd, mmap_offset.offset);
+	if (batch == MAP_FAILED)
+		die("reset load mmap");
+	memset(batch, 0, LOAD_SIZE);
+	batch[LOAD_SIZE / sizeof(*batch) - 1] = 0x05000000;
+	object.handle = create.handle;
+	if (ioctl(fd, DRM_IOCTL_I915_GEM_EXECBUFFER2, &execbuf) < 0)
+		die("reset load first EXECBUFFER2");
+	puts("RESET_LOAD_READY");
+	fflush(stdout);
+	for (;;) {
+		if (ioctl(fd, DRM_IOCTL_I915_GEM_EXECBUFFER2, &execbuf) == 0)
+			continue;
+		if (errno == EINTR)
+			continue;
+		if (errno == EIO || errno == ENODEV)
+			return EXIT_SUCCESS;
+		die("reset load EXECBUFFER2");
+	}
+}
+
+static uint32_t property_id(int fd, uint32_t object_id, uint32_t object_type,
+			    const char *name, uint64_t *value)
+{
+	drmModeObjectPropertiesPtr object =
+		drmModeObjectGetProperties(fd, object_id, object_type);
+	uint32_t id = 0;
+
+	if (!object)
+		die("drmModeObjectGetProperties");
+	for (uint32_t i = 0; i < object->count_props; i++) {
+		drmModePropertyPtr property = drmModeGetProperty(fd, object->props[i]);
+
+		if (!property)
+			die("drmModeGetProperty");
+		if (!strcmp(property->name, name)) {
+			id = property->prop_id;
+			if (value)
+				*value = object->prop_values[i];
+			drmModeFreeProperty(property);
+			break;
+		}
+		drmModeFreeProperty(property);
+	}
+	drmModeFreeObjectProperties(object);
+	if (!id) {
+		fprintf(stderr, "missing property %s on object %u\n", name, object_id);
+		exit(EXIT_FAILURE);
+	}
+	return id;
+}
+
+static void find_pipeline(int fd, drmModeResPtr resources,
+			  uint32_t *connector_id, uint32_t *crtc_id,
+			  uint32_t *crtc_index, drmModeModeInfo *mode)
+{
+	for (int i = 0; i < resources->count_connectors; i++) {
+		drmModeConnectorPtr connector =
+			drmModeGetConnector(fd, resources->connectors[i]);
+		drmModeEncoderPtr encoder = NULL;
+
+		if (!connector)
+			continue;
+		if (connector->connection != DRM_MODE_CONNECTED ||
+		    connector->count_modes == 0 || connector->count_encoders == 0) {
+			drmModeFreeConnector(connector);
+			continue;
+		}
+		for (int encoder_index = -1;
+		     encoder_index < connector->count_encoders; encoder_index++) {
+			uint32_t encoder_id = encoder_index < 0 ? connector->encoder_id :
+								  connector->encoders[encoder_index];
+
+			if (!encoder_id)
+				continue;
+			encoder = drmModeGetEncoder(fd, encoder_id);
+			if (!encoder)
+				continue;
+			for (int j = 0; j < resources->count_crtcs; j++) {
+				if (encoder->crtc_id) {
+					if (resources->crtcs[j] != encoder->crtc_id)
+						continue;
+				} else if (!(encoder->possible_crtcs & (1u << j))) {
+					continue;
+				}
+				*connector_id = connector->connector_id;
+				*crtc_id = resources->crtcs[j];
+				*crtc_index = (uint32_t)j;
+				*mode = connector->modes[0];
+				for (int k = 0; k < connector->count_modes; k++) {
+					if (connector->modes[k].type & DRM_MODE_TYPE_PREFERRED) {
+						*mode = connector->modes[k];
+						break;
+					}
+				}
+				drmModeFreeEncoder(encoder);
+				drmModeFreeConnector(connector);
+				return;
+			}
+			drmModeFreeEncoder(encoder);
+			encoder = NULL;
+		}
+		drmModeFreeConnector(connector);
+	}
+	fail("no connected connector with an assigned CRTC");
+}
+
+static uint32_t find_primary_plane(int fd, uint32_t crtc_index)
+{
+	drmModePlaneResPtr planes = drmModeGetPlaneResources(fd);
+
+	if (!planes)
+		die("drmModeGetPlaneResources");
+	for (uint32_t i = 0; i < planes->count_planes; i++) {
+		drmModePlanePtr plane = drmModeGetPlane(fd, planes->planes[i]);
+		uint64_t type = 0;
+
+		if (!plane)
+			continue;
+		if (!(plane->possible_crtcs & (1u << crtc_index))) {
+			drmModeFreePlane(plane);
+			continue;
+		}
+		(void)property_id(fd, plane->plane_id, DRM_MODE_OBJECT_PLANE,
+				  "type", &type);
+		if (type == DRM_PLANE_TYPE_PRIMARY) {
+			uint32_t id = plane->plane_id;
+
+			drmModeFreePlane(plane);
+			drmModeFreePlaneResources(planes);
+			return id;
+		}
+		drmModeFreePlane(plane);
+	}
+	drmModeFreePlaneResources(planes);
+	fail("no compatible primary plane");
+	return 0;
+}
+
+static void fill_buffer(struct dumb_buffer *buffer, uint32_t width,
+			uint32_t height, uint32_t phase)
+{
+	for (uint32_t y = 0; y < height; y++) {
+		uint32_t *row = (uint32_t *)((char *)buffer->mapping +
+					     (uint64_t)y * buffer->pitch);
+
+		for (uint32_t x = 0; x < width; x++)
+			row[x] = UINT32_C(0xff000000) |
+				 (((x + phase * 31) & 0xff) << 16) |
+				 (((y + phase * 17) & 0xff) << 8) |
+				 ((x ^ y ^ phase) & 0xff);
+	}
+}
+
+static void verify_buffer(const struct dumb_buffer *buffer, uint32_t width,
+			  uint32_t height, uint32_t phase)
+{
+	for (uint32_t y = 0; y < height; y++) {
+		const uint32_t *row = (const uint32_t *)((const char *)buffer->mapping +
+							 (uint64_t)y * buffer->pitch);
+
+		for (uint32_t x = 0; x < width; x++) {
+			uint32_t expected = UINT32_C(0xff000000) |
+					    (((x + phase * 31) & 0xff) << 16) |
+					    (((y + phase * 17) & 0xff) << 8) |
+					    ((x ^ y ^ phase) & 0xff);
+
+			if (row[x] != expected)
+				fail("restored scanout contents differ");
+		}
+	}
+}
+
+static void create_dumb_buffer(int fd, uint32_t width, uint32_t height,
+			       uint32_t phase, struct dumb_buffer *buffer)
+{
+	struct drm_mode_create_dumb create = {
+		.width = width,
+		.height = height,
+		.bpp = 32,
+	};
+	struct drm_mode_map_dumb map = { 0 };
+	uint32_t handles[4] = { 0 };
+	uint32_t pitches[4] = { 0 };
+	uint32_t offsets[4] = { 0 };
+
+	if (ioctl(fd, DRM_IOCTL_MODE_CREATE_DUMB, &create) < 0)
+		die("DRM_IOCTL_MODE_CREATE_DUMB");
+	buffer->handle = create.handle;
+	buffer->pitch = create.pitch;
+	buffer->size = create.size;
+	map.handle = create.handle;
+	if (ioctl(fd, DRM_IOCTL_MODE_MAP_DUMB, &map) < 0)
+		die("DRM_IOCTL_MODE_MAP_DUMB");
+	buffer->mapping = mmap(NULL, create.size, PROT_READ | PROT_WRITE,
+			       MAP_SHARED, fd, map.offset);
+	if (buffer->mapping == MAP_FAILED)
+		die("mmap dumb buffer");
+	fill_buffer(buffer, width, height, phase);
+	handles[0] = create.handle;
+	pitches[0] = create.pitch;
+	if (drmModeAddFB2(fd, width, height, DRM_FORMAT_XRGB8888,
+			  handles, pitches, offsets, &buffer->fb_id, 0))
+		die("drmModeAddFB2");
+}
+
+static struct kms_properties get_properties(int fd, uint32_t connector_id,
+					    uint32_t crtc_id,
+					    uint32_t plane_id)
+{
+	return (struct kms_properties){
+		.connector_crtc_id = property_id(fd, connector_id,
+						 DRM_MODE_OBJECT_CONNECTOR, "CRTC_ID", NULL),
+		.crtc_active = property_id(fd, crtc_id, DRM_MODE_OBJECT_CRTC,
+					   "ACTIVE", NULL),
+		.crtc_mode_id = property_id(fd, crtc_id, DRM_MODE_OBJECT_CRTC,
+					    "MODE_ID", NULL),
+		.plane_fb_id = property_id(fd, plane_id, DRM_MODE_OBJECT_PLANE,
+					   "FB_ID", NULL),
+		.plane_crtc_id = property_id(fd, plane_id, DRM_MODE_OBJECT_PLANE,
+					     "CRTC_ID", NULL),
+		.crtc_x = property_id(fd, plane_id, DRM_MODE_OBJECT_PLANE,
+				      "CRTC_X", NULL),
+		.crtc_y = property_id(fd, plane_id, DRM_MODE_OBJECT_PLANE,
+				      "CRTC_Y", NULL),
+		.crtc_w = property_id(fd, plane_id, DRM_MODE_OBJECT_PLANE,
+				      "CRTC_W", NULL),
+		.crtc_h = property_id(fd, plane_id, DRM_MODE_OBJECT_PLANE,
+				      "CRTC_H", NULL),
+		.src_x = property_id(fd, plane_id, DRM_MODE_OBJECT_PLANE,
+				     "SRC_X", NULL),
+		.src_y = property_id(fd, plane_id, DRM_MODE_OBJECT_PLANE,
+				     "SRC_Y", NULL),
+		.src_w = property_id(fd, plane_id, DRM_MODE_OBJECT_PLANE,
+				     "SRC_W", NULL),
+		.src_h = property_id(fd, plane_id, DRM_MODE_OBJECT_PLANE,
+				     "SRC_H", NULL),
+	};
+}
+
+static void add_property(drmModeAtomicReqPtr request, uint32_t object,
+			 uint32_t property, uint64_t value)
+{
+	if (drmModeAtomicAddProperty(request, object, property, value) < 0)
+		die("drmModeAtomicAddProperty");
+}
+
+static void commit_initial_state(int fd, uint32_t connector_id,
+				 uint32_t crtc_id, uint32_t plane_id,
+				 const struct kms_properties *properties,
+				 uint32_t mode_blob, uint32_t fb_id,
+				 uint32_t width, uint32_t height)
+{
+	drmModeAtomicReqPtr request = drmModeAtomicAlloc();
+
+	if (!request)
+		die("drmModeAtomicAlloc");
+	add_property(request, connector_id, properties->connector_crtc_id, crtc_id);
+	add_property(request, crtc_id, properties->crtc_active, 1);
+	add_property(request, crtc_id, properties->crtc_mode_id, mode_blob);
+	add_property(request, plane_id, properties->plane_fb_id, fb_id);
+	add_property(request, plane_id, properties->plane_crtc_id, crtc_id);
+	add_property(request, plane_id, properties->crtc_x, 0);
+	add_property(request, plane_id, properties->crtc_y, 0);
+	add_property(request, plane_id, properties->crtc_w, width);
+	add_property(request, plane_id, properties->crtc_h, height);
+	add_property(request, plane_id, properties->src_x, 0);
+	add_property(request, plane_id, properties->src_y, 0);
+	add_property(request, plane_id, properties->src_w, (uint64_t)width << 16);
+	add_property(request, plane_id, properties->src_h, (uint64_t)height << 16);
+	if (drmModeAtomicCommit(fd, request, DRM_MODE_ATOMIC_ALLOW_MODESET, NULL))
+		die("initial drmModeAtomicCommit");
+	drmModeAtomicFree(request);
+}
+
+static void expect_property(int fd, uint32_t object_id, uint32_t object_type,
+			    const char *name, uint64_t expected)
+{
+	uint64_t actual = 0;
+
+	(void)property_id(fd, object_id, object_type, name, &actual);
+	if (actual != expected) {
+		fprintf(stderr, "%s value %#llx != %#llx\n", name,
+			(unsigned long long)actual, (unsigned long long)expected);
+		exit(EXIT_FAILURE);
+	}
+}
+
+static void verify_framebuffer(int fd, const struct dumb_buffer *buffer,
+			       uint32_t width, uint32_t height)
+{
+	drmModeFB2Ptr fb = drmModeGetFB2(fd, buffer->fb_id);
+
+	if (!fb)
+		die("drmModeGetFB2");
+	if (fb->fb_id != buffer->fb_id || fb->width != width ||
+	    fb->height != height || fb->pixel_format != DRM_FORMAT_XRGB8888 ||
+	    fb->pitches[0] != buffer->pitch)
+		fail("restored framebuffer metadata differs");
+	for (unsigned int i = 0; i < 4; i++) {
+		if (!fb->handles[i])
+			continue;
+		struct drm_gem_close close_handle = { .handle = fb->handles[i] };
+
+		(void)ioctl(fd, DRM_IOCTL_GEM_CLOSE, &close_handle);
+	}
+	drmModeFreeFB2(fb);
+}
+
+static void post_restore_page_flip(int fd, uint32_t plane_id,
+				   const struct kms_properties *properties,
+				   uint32_t fb_id)
+{
+	drmModeAtomicReqPtr request = drmModeAtomicAlloc();
+	struct pollfd pollfd = { .fd = fd, .events = POLLIN };
+	char events[4096];
+
+	if (!request)
+		die("drmModeAtomicAlloc post-restore");
+	add_property(request, plane_id, properties->plane_fb_id, fb_id);
+	if (drmModeAtomicCommit(fd, request,
+				DRM_MODE_ATOMIC_NONBLOCK | DRM_MODE_PAGE_FLIP_EVENT,
+				(void *)(uintptr_t)UINT64_C(0x9158)))
+		die("post-restore drmModeAtomicCommit");
+	drmModeAtomicFree(request);
+	if (poll(&pollfd, 1, 5000) != 1)
+		die("post-restore page-flip poll");
+	if (read(fd, events, sizeof(events)) <= 0)
+		die("post-restore page-flip event");
+}
+
+static void acquire_master(int fd)
+{
+	for (unsigned int attempt = 0; attempt < 100; attempt++) {
+		if (drmIsMaster(fd) || drmSetMaster(fd) == 0)
+			return;
+		if (errno != EBUSY)
+			die("drmSetMaster (stop the graphical session before this test)");
+		if (poll(NULL, 0, 20) < 0 && errno != EINTR)
+			die("poll waiting for prior DRM master release");
+	}
+	errno = EBUSY;
+	die("drmSetMaster remained busy after prior fixture exit");
+}
+
+int main(int argc, char **argv)
+{
+	struct sigaction action = { .sa_handler = on_signal };
+
+	if (argc == 2 && !strcmp(argv[1], "--reset-load"))
+		return run_reset_load();
+	if (argc != 1)
+		fail("usage: i915-kms-atomic [--reset-load]");
+	struct dumb_buffer buffers[2] = { 0 };
+	struct kms_properties properties;
+	drmModeResPtr resources;
+	drmModeModeInfo mode;
+	uint32_t connector_id = 0;
+	uint32_t crtc_id = 0;
+	uint32_t crtc_index = 0;
+	uint32_t plane_id;
+	uint32_t mode_blob;
+	uint32_t reservations[MODE_ID_RESERVATIONS];
+	uint8_t reservation_data = 0;
+	int fd = open_i915_primary();
+
+	if (fd < 0)
+		die("open i915 primary node");
+	acquire_master(fd);
+	if (drmSetClientCap(fd, DRM_CLIENT_CAP_UNIVERSAL_PLANES, 1) ||
+	    drmSetClientCap(fd, DRM_CLIENT_CAP_ATOMIC, 1))
+		die("drmSetClientCap atomic");
+	resources = drmModeGetResources(fd);
+	if (!resources)
+		die("drmModeGetResources");
+	find_pipeline(fd, resources, &connector_id, &crtc_id, &crtc_index, &mode);
+	plane_id = find_primary_plane(fd, crtc_index);
+	properties = get_properties(fd, connector_id, crtc_id, plane_id);
+	/*
+	 * Dynamic MST connectors consume low holes in DRM's global mode-object
+	 * IDR during lastclose. Place the fixture-owned identities above a bounded
+	 * set of temporary allocations, then release those low IDs before dump.
+	 * This keeps the positive exact-ID case independent from unrelated hotplug
+	 * churn without weakening restore's EEXIST refusal for real conflicts.
+	 */
+	for (size_t i = 0; i < MODE_ID_RESERVATIONS; i++)
+		if (drmModeCreatePropertyBlob(fd, &reservation_data,
+					      sizeof(reservation_data),
+					      &reservations[i]))
+			die("drmModeCreatePropertyBlob reservation");
+	create_dumb_buffer(fd, mode.hdisplay, mode.vdisplay, 1, &buffers[0]);
+	create_dumb_buffer(fd, mode.hdisplay, mode.vdisplay, 2, &buffers[1]);
+	if (drmModeCreatePropertyBlob(fd, &mode, sizeof(mode), &mode_blob))
+		die("drmModeCreatePropertyBlob");
+	commit_initial_state(fd, connector_id, crtc_id, plane_id, &properties,
+			     mode_blob, buffers[0].fb_id,
+			     mode.hdisplay, mode.vdisplay);
+	for (size_t i = 0; i < MODE_ID_RESERVATIONS; i++)
+		if (drmModeDestroyPropertyBlob(fd, reservations[i]))
+			die("drmModeDestroyPropertyBlob reservation");
+	drmModeFreeResources(resources);
+
+	if (sigaction(SIGUSR1, &action, NULL))
+		die("sigaction");
+	printf("READY fd=%d connector=%u crtc=%u plane=%u mode_blob=%u fb=%u,%u size=%ux%u\n",
+	       fd, connector_id, crtc_id, plane_id, mode_blob,
+	       buffers[0].fb_id, buffers[1].fb_id, mode.hdisplay, mode.vdisplay);
+	fflush(stdout);
+	while (!resumed)
+		pause();
+
+	if (!drmIsMaster(fd))
+		fail("restored DRM file did not retain master ownership");
+	verify_buffer(&buffers[0], mode.hdisplay, mode.vdisplay, 1);
+	verify_buffer(&buffers[1], mode.hdisplay, mode.vdisplay, 2);
+	verify_framebuffer(fd, &buffers[0], mode.hdisplay, mode.vdisplay);
+	verify_framebuffer(fd, &buffers[1], mode.hdisplay, mode.vdisplay);
+	expect_property(fd, connector_id, DRM_MODE_OBJECT_CONNECTOR,
+			"CRTC_ID", crtc_id);
+	expect_property(fd, crtc_id, DRM_MODE_OBJECT_CRTC, "ACTIVE", 1);
+	expect_property(fd, crtc_id, DRM_MODE_OBJECT_CRTC, "MODE_ID", mode_blob);
+	expect_property(fd, plane_id, DRM_MODE_OBJECT_PLANE,
+			"FB_ID", buffers[0].fb_id);
+	expect_property(fd, plane_id, DRM_MODE_OBJECT_PLANE, "CRTC_ID", crtc_id);
+	post_restore_page_flip(fd, plane_id, &properties, buffers[1].fb_id);
+	expect_property(fd, plane_id, DRM_MODE_OBJECT_PLANE,
+			"FB_ID", buffers[1].fb_id);
+	puts("PASS: exact DRM master, blob/framebuffer IDs, atomic scanout, contents, and post-restore page flip");
+	return EXIT_SUCCESS;
+}
