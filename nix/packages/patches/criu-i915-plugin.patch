+
+static int write_all(int fd, const void *data, size_t size)
+{
+	const char *cursor = data;
+
+	while (size) {
+		ssize_t written = write(fd, cursor, size);
+		if (written < 0) {
+			if (errno == EINTR)
+				continue;
+			return -errno;
+		}
+		cursor += written;
+		size -= written;
+	}
+	return 0;
+}
+
+static int pwrite_all(int fd, const void *data, size_t size, off_t offset)
+{
+	const char *cursor = data;
+
+	while (size) {
+		ssize_t written = pwrite(fd, cursor, size, offset);
+		if (written < 0) {
+			if (errno == EINTR)
+				continue;
+			return -errno;
+		}
+		if (!written)
+			return -EIO;
+		cursor += written;
+		offset += written;
+		size -= written;
+	}
+	return 0;
+}
+
+static int read_all(int fd, void *data, size_t size)
+{
+	char *cursor = data;
+
+	while (size) {
+		ssize_t got = read(fd, cursor, size);
+		if (got == 0)
+			return -EIO;
+		if (got < 0) {
+			if (errno == EINTR)
+				continue;
+			return -errno;
+		}
+		cursor += got;
+		size -= got;
+	}
+	return 0;
+}
+
+static int session_ioctl(int fd, uint32_t op, int pid, uint64_t *cookie)
+{
+	struct drm_i915_criu_session session = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = op,
+		.target_pid = pid,
+		.cookie = *cookie,
+	};
+
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_SESSION, &session) < 0)
+		return -errno;
+	*cookie = session.cookie;
+	return 0;
+}
+
+static int resolve_dmabuf_object(int dmabuf_fd, uint64_t *object_id)
+{
+	struct drm_i915_criu_object query = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_OBJECT_QUERY,
+	};
+	struct drm_gem_close close_handle;
+	uint64_t cookie = 0;
+	uint32_t handle;
+	int fd;
+	int ret;
+
+	fd = open(render_node(), O_RDWR | O_CLOEXEC);
+	if (fd < 0)
+		return errno == ENOENT || errno == ENODEV ? -ENOTSUP : -errno;
+	if (!is_i915_fd(fd)) {
+		close(fd);
+		return -ENOTSUP;
+	}
+	ret = drmPrimeFDToHandle(fd, dmabuf_fd, &handle);
+	if (ret)
+		goto out;
+	close_handle = (struct drm_gem_close){ .handle = handle };
+	ret = session_ioctl(fd, I915_CRIU_SESSION_DUMP_BEGIN,
+			    checkpoint_pid, &cookie);
+	if (ret)
+		goto close_handle;
+	query.cookie = cookie;
+	query.handle = handle - 1;
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_OBJECT, &query) < 0)
+		ret = -errno;
+	else if (query.handle != handle || !query.object_id ||
+		 !(query.sharing_flags & I915_CRIU_OBJECT_SHARED))
+		ret = -EXDEV;
+	else
+		*object_id = query.object_id;
+	if (session_ioctl(fd, ret ? I915_CRIU_SESSION_ABORT : I915_CRIU_SESSION_COMMIT,
+			  0, &cookie) &&
+	    !ret)
+		ret = -EIO;
+close_handle:
+	ioctl(fd, DRM_IOCTL_GEM_CLOSE, &close_handle);
+out:
+	close(fd);
+	return ret;
+}
+
+static int write_dmabuf_image(int file_id, uint64_t object_id,
+			      uint32_t fd_count)
+{
+	struct i915_image_header header = {
+		.magic = I915_IMAGE_MAGIC,
+		.version = I915_IMAGE_VERSION,
+		.file_id = file_id,
+		.kind = I915_IMAGE_KIND_DMABUF,
+	};
+	struct i915_image_dmabuf image = {
+		.object_id = object_id,
+		.fd_count = fd_count,
+	};
+	int fd = image_fd(file_id, O_WRONLY | O_CREAT | O_EXCL);
+	int ret;
+
+	if (fd < 0)
+		return fd;
+	ret = write_all(fd, &header, sizeof(header));
+	if (!ret)
+		ret = write_all(fd, &image, sizeof(image));
+	if (close(fd) && !ret)
+		ret = -errno;
+	return ret;
+}
+
+static int write_sync_file_image(const struct dump_sync_file *file)
+{
+	struct i915_image_header header = {
+		.magic = I915_IMAGE_MAGIC,
+		.version = I915_IMAGE_VERSION,
+		.file_id = file->file_id,
+		.kind = I915_IMAGE_KIND_SYNC_FILE,
+	};
+	struct i915_image_sync_file image = {
+		.source_file_id = file->source_file_id,
+		.handle = file->handle,
+		.flags = file->flags,
+		.fd_count = file->fd_count,
+		.point = file->point,
+	};
+	int fd = image_fd(file->file_id, O_WRONLY | O_CREAT | O_EXCL);
+	int ret;
+
+	if (fd < 0)
+		return fd;
+	ret = write_all(fd, &header, sizeof(header));
+	if (!ret)
+		ret = write_all(fd, &image, sizeof(image));
+	if (close(fd) && !ret)
+		ret = -errno;
+	return ret;
+}
