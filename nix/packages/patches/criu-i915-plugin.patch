++int i915_criu_file_ioctl(struct drm_device *dev, void *data,
++			 struct drm_file *file)
++{
++	const u32 supported =
++		I915_CRIU_FILE_PRIMARY | I915_CRIU_FILE_RENDER |
++		I915_CRIU_FILE_AUTHENTICATED | I915_CRIU_FILE_MASTER |
++		I915_CRIU_FILE_ATOMIC | I915_CRIU_FILE_UNIVERSAL_PLANES |
++		I915_CRIU_FILE_ASPECT_RATIO | I915_CRIU_FILE_STEREO |
++		I915_CRIU_FILE_WRITEBACK_CONNECTORS;
++	struct drm_i915_criu_file *args = data;
++	struct drm_i915_file_private *fpriv = file->driver_priv;
++	struct pci_dev *pdev = to_pci_dev(dev->dev);
++	u32 actual;
++	int ret;
++
++	if (args->version != I915_CRIU_ABI_VERSION ||
++	    args->flags & ~supported ||
++	    memchr_inv(args->reserved, 0, sizeof(args->reserved)))
++		return -EINVAL;
++
++	mutex_lock(&fpriv->criu_lock);
++	actual = checkpoint_file_flags(file);
++	if (args->op == I915_CRIU_FILE_QUERY) {
++		if (args->flags || args->vendor_id || args->device_id ||
++		    args->subsystem_vendor_id || args->subsystem_device_id ||
++		    args->revision) {
++			ret = -EINVAL;
++			goto out;
++		}
++		ret = check_session(fpriv, args->cookie, I915_CRIU_MODE_DUMP);
++		if (!ret)
++			ret = validate_kms_file_state(dev, file);
++		if (!ret) {
++			args->flags = actual;
++			args->vendor_id = pdev->vendor;
++			args->device_id = pdev->device;
++			args->subsystem_vendor_id = pdev->subsystem_vendor;
++			args->subsystem_device_id = pdev->subsystem_device;
++			args->revision = pdev->revision;
++		}
++	} else if (args->op == I915_CRIU_FILE_RESTORE) {
++		ret = check_session(fpriv, args->cookie,
++				    I915_CRIU_MODE_RESTORE);
++		if (!ret &&
++		    (args->flags != actual || args->vendor_id != pdev->vendor ||
++		     args->device_id != pdev->device ||
++		     args->subsystem_vendor_id != pdev->subsystem_vendor ||
++		     args->subsystem_device_id != pdev->subsystem_device ||
++		     args->revision != pdev->revision))
++			ret = -EXDEV;
++		if (!ret)
++			ret = validate_kms_file_state(dev, file);
++	} else {
++		ret = -EINVAL;
++	}
++out:
++	mutex_unlock(&fpriv->criu_lock);
++	return ret;
++}
