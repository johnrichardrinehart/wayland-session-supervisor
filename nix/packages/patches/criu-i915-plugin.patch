+static const char *render_node(void)
+{
+	const char *configured = getenv("I915_CRIU_DRM_DEVICE");
+
+	return configured && configured[0] ? configured : "/dev/dri/renderD128";
+}
+
+static int open_dump_render_node(int pid)
+{
+	const char *node = render_node();
+	char path[PATH_MAX];
+	int length;
+	int fd;
+
+	if (pid <= 0 || node[0] != '/')
+		return -EINVAL;
+	length = snprintf(path, sizeof(path), "/proc/%d/root%s", pid, node);
+	if (length < 0 || (size_t)length >= sizeof(path))
+		return -ENAMETOOLONG;
+	fd = open(path, O_RDWR | O_CLOEXEC);
+	return fd < 0 ? -errno : fd;
+}
+
+static bool sysfs_fd_uses_i915(int fd)
+{
+	char path[PATH_MAX];
+	char driver[PATH_MAX];
+	struct stat st;
+	const char *name;
+	ssize_t length;
+	int written;
+
+	if (fstat(fd, &st) || !S_ISCHR(st.st_mode))
+		return false;
+	written = snprintf(path, sizeof(path),
+			   "/sys/dev/char/%u:%u/device/driver",
+			   major(st.st_rdev), minor(st.st_rdev));
+	if (written < 0 || (size_t)written >= sizeof(path))
+		return false;
+	length = readlink(path, driver, sizeof(driver) - 1);
+	if (length < 0)
+		return false;
+	driver[length] = '\0';
+	name = strrchr(driver, '/');
+	name = name ? name + 1 : driver;
+	return !strcmp(name, "i915");
+}
+
+static bool is_i915_fd(int fd)
+{
+	drmVersionPtr version = drmGetVersion(fd);
+	int version_errno = errno;
+	bool match;
+
+	if (version) {
+		match = version->name && !strcmp(version->name, "i915");
+		pr_debug("i915_plugin: fd %d reports DRM driver %.*s\n", fd,
+			 version->name_len, version->name ? version->name : "");
+		drmFreeVersion(version);
+		return match;
+	}
+	match = sysfs_fd_uses_i915(fd);
+	pr_debug("i915_plugin: fd %d DRM version unavailable (%d); sysfs i915=%d\n",
+		 fd, version_errno, match);
+	return match;
+}
+
+static int open_i915_primary(void)
+{
+	char path[64];
+
+	for (unsigned int index = 0; index < 64; index++) {
+		int fd;
+
+		snprintf(path, sizeof(path), "/dev/dri/card%u", index);
+		fd = open(path, O_RDWR | O_CLOEXEC);
+		if (fd < 0)
+			continue;
+		if (is_i915_fd(fd) && drmGetNodeTypeFromFd(fd) == DRM_NODE_PRIMARY)
+			return fd;
+		close(fd);
+	}
+	return -ENODEV;
+}
+
+static int configure_restore_file(int fd, uint32_t flags)
+{
+	const uint32_t node_flags = I915_CRIU_FILE_PRIMARY |
+				    I915_CRIU_FILE_RENDER;
+	int node_type = drmGetNodeTypeFromFd(fd);
+
+	if ((flags & node_flags) != I915_CRIU_FILE_PRIMARY &&
+	    (flags & node_flags) != I915_CRIU_FILE_RENDER)
+		return -EINVAL;
+	if ((flags & I915_CRIU_FILE_PRIMARY && node_type != DRM_NODE_PRIMARY) ||
+	    (flags & I915_CRIU_FILE_RENDER && node_type != DRM_NODE_RENDER))
+		return -EXDEV;
+	if (flags & I915_CRIU_FILE_PRIMARY) {
+		if (flags & I915_CRIU_FILE_MASTER && !drmIsMaster(fd) &&
+		    drmSetMaster(fd))
+			return -errno;
+		if (!(flags & I915_CRIU_FILE_MASTER) && drmIsMaster(fd))
+			return -EXDEV;
+	}
+	if (flags & I915_CRIU_FILE_STEREO &&
+	    drmSetClientCap(fd, DRM_CLIENT_CAP_STEREO_3D, 1))
+		return -errno;
+	if (flags & I915_CRIU_FILE_UNIVERSAL_PLANES &&
+	    drmSetClientCap(fd, DRM_CLIENT_CAP_UNIVERSAL_PLANES, 1))
+		return -errno;
+	if (flags & I915_CRIU_FILE_ATOMIC &&
+	    drmSetClientCap(fd, DRM_CLIENT_CAP_ATOMIC, 1))
+		return -errno;
+	if (flags & I915_CRIU_FILE_ASPECT_RATIO &&
+	    drmSetClientCap(fd, DRM_CLIENT_CAP_ASPECT_RATIO, 1))
+		return -errno;
+	if (flags & I915_CRIU_FILE_WRITEBACK_CONNECTORS &&
+	    drmSetClientCap(fd, DRM_CLIENT_CAP_WRITEBACK_CONNECTORS, 1))
+		return -errno;
+	return 0;
+}
+
+static bool is_dmabuf_fd(int fd)
+{
+	struct statfs statfs;
+
+	return !fstatfs(fd, &statfs) &&
+	       (uint64_t)statfs.f_type == (uint64_t)DMA_BUF_MAGIC;
+}
