++static int reassign_mode_object_id(struct drm_device *dev,
++				   struct drm_mode_object *object, u32 target)
++{
++	int ret;
++
++	if (!target || target == U32_MAX)
++		return -EINVAL;
++	mutex_lock(&dev->mode_config.idr_mutex);
++	if (object->id == target) {
++		ret = 0;
++		goto out;
++	}
++	if (idr_find(&dev->mode_config.object_idr, target)) {
++		ret = -EEXIST;
++		goto out;
++	}
++	ret = idr_alloc(&dev->mode_config.object_idr, object, target,
++			target + 1, GFP_KERNEL);
++	if (ret == target) {
++		idr_remove(&dev->mode_config.object_idr, object->id);
++		object->id = target;
++		ret = 0;
++	} else if (ret >= 0) {
++		idr_remove(&dev->mode_config.object_idr, ret);
++		ret = -ERANGE;
++	}
++out:
++	mutex_unlock(&dev->mode_config.idr_mutex);
++	return ret;
++}
