+++ b/test/others/i915-criu/run-kms-criu.sh
@@ -0,0 +1,207 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+if (( EUID != 0 )); then
+    echo "run as root from a text console with the graphical session stopped: sudo $0" >&2
+    exit 2
+fi
+
+umask 077
+repo=$(cd "$(dirname "$0")/../../.." && pwd)
+work=${I915_CRIU_TEST_DIR:-/tmp/i915-criu-kms}
+criu=${CRIU:-/run/current-system/sw/bin/criu}
+plugin_dir=${CRIU_PLUGIN_DIR:-}
+plugin_args=()
+[[ -n $plugin_dir ]] && plugin_args+=(--libdir "$plugin_dir")
+cc=${CC:-gcc}
+fixture="$work/i915-kms-atomic"
+fixture_source=${FIXTURE:-/tmp/i915-kms-atomic}
+images="$work/images"
+log="$work/fixture.log"
+corrupt_mode=${I915_CRIU_KMS_CORRUPT_MODE:-}
+reset_fault=${I915_CRIU_KMS_RESET_FAULT:-0}
+expected='PASS: exact DRM master, blob/framebuffer IDs, atomic scanout, contents, and post-restore page flip'
+
+cleanup() {
+    if [[ -n ${reset_load_pid:-} ]]; then
+        kill -KILL "$reset_load_pid" 2>/dev/null || true
+    fi
+    if [[ -n ${fixture_pid:-} ]]; then
+        kill -KILL "$fixture_pid" 2>/dev/null || true
+    fi
+}
+trap cleanup EXIT
+rm -rf "$work"
+mkdir -p "$images"
+
+if [[ -x $fixture_source ]]; then
+    cp "$fixture_source" "$fixture"
+elif command -v "$cc" >/dev/null && command -v pkg-config >/dev/null; then
+    # shellcheck disable=SC2046
+    "$cc" -std=c11 -Wall -Wextra -Werror \
+        $(pkg-config --cflags libdrm) \
+        "$repo/test/others/i915-criu/i915-kms-atomic.c" -o "$fixture" \
+        $(pkg-config --libs libdrm)
+else
+    echo "no prebuilt fixture at $fixture_source and no libdrm compiler environment" >&2
+    exit 2
+fi
+
+"$fixture" >"$log" 2>&1 &
+fixture_pid=$!
+for _ in $(seq 1 200); do
+    grep -q '^READY ' "$log" && break
+    if ! kill -0 "$fixture_pid" 2>/dev/null; then
+        cat "$log" >&2
+        exit 1
+    fi
+    sleep 0.05
+done
+grep -q '^READY ' "$log"
+original_pid=$fixture_pid
+ready=$(grep '^READY ' "$log")
+printf '%s\n' "$ready"
+
+if [[ $reset_fault == 1 ]]; then
+    reset_file=$(find /sys/kernel/debug/dri -path '*/i915_wedged' -print -quit)
+    if [[ -z $reset_file ]]; then
+        echo 'i915 reset fault injection is unavailable in debugfs' >&2
+        exit 2
+    fi
+    set +e
+    I915_CRIU_TEST_PAUSE_AFTER_FILE_QUERY_MS=3000 \
+        "$criu" dump -t "$original_pid" -D "$images" --shell-job \
+        "${plugin_args[@]}" --log-file dump.log -v4 &
+    dump_pid=$!
+    set -e
+    for _ in $(seq 1 200); do
+        grep -q 'i915 test pause after file query' "$images/dump.log" 2>/dev/null && break
+        kill -0 "$dump_pid" 2>/dev/null || break
+        sleep 0.02
+    done
+    grep -q 'i915 test pause after file query' "$images/dump.log"
+    # An engine reset against an idle engine is deliberately a no-op in i915.
+    # Keep render work queued so this debugfs request performs a real reset and
+    # advances the transaction's reset epoch rather than merely capturing an
+    # empty error state.
+    reset_load_log="$work/reset-load.log"
+    "$fixture" --reset-load >"$reset_load_log" 2>&1 &
+    reset_load_pid=$!
+    for _ in $(seq 1 200); do
+        grep -q '^RESET_LOAD_READY$' "$reset_load_log" && break
+        if ! kill -0 "$reset_load_pid" 2>/dev/null; then
+            cat "$reset_load_log" >&2
+            exit 1
+        fi
+        sleep 0.01
+    done
+    grep -q '^RESET_LOAD_READY$' "$reset_load_log"
+    reset_journal_since=$(date --iso-8601=seconds)
+    printf '1\n' >"$reset_file"
+    kill -KILL "$reset_load_pid" 2>/dev/null || true
+    wait "$reset_load_pid" 2>/dev/null || true
+    reset_load_pid=
+    set +e
+    wait "$dump_pid"
+    dump_status=$?
+    set -e
+    if (( dump_status == 0 || dump_status >= 128 )); then
+        echo "GPU reset during dump did not fail safely: status=$dump_status" >&2
+        exit 1
+    fi
+    grep -q 'Dumping FAILED' "$images/dump.log"
+    journalctl -b -k --since "$reset_journal_since" --no-pager \
+        | grep -E 'GPU HANG|Resetting .*Manually reset|context reset due to GPU hang|ban score' \
+        >"$work/reset-kernel.log"
+    grep -q 'Resetting .*Manually reset engine mask to 1' "$work/reset-kernel.log"
+    kill -0 "$fixture_pid"
+    kill -USR1 "$fixture_pid"
+    for _ in $(seq 1 200); do
+        grep -Fqx "$expected" "$log" && break
+        kill -0 "$fixture_pid" 2>/dev/null || break
+        sleep 0.05
+    done
+    grep -Fqx "$expected" "$log"
+    wait "$fixture_pid"
+    fixture_pid=
+    printf 'PASS: GPU reset during the i915 transaction refused dump; DRM master, exact KMS state, scanout contents, and page flip remained functional (status=%s)\n' \
+        "$dump_status"
+    exit 0
+fi
+
+"$criu" dump -t "$original_pid" -D "$images" --shell-job \
+    "${plugin_args[@]}" --log-file dump.log -v4
+wait "$fixture_pid" 2>/dev/null || true
+fixture_pid=
+if [[ -n $corrupt_mode ]]; then
+    i915_images=("$images"/i915-criu-*.img)
+    if (( ${#i915_images[@]} != 1 )); then
+        echo "expected one i915 image, found ${#i915_images[@]}" >&2
+        exit 1
+    fi
+    case $corrupt_mode in
+        role)
+            printf '\002\000\000\000' | dd of="${i915_images[0]}" \
+                bs=1 seek=48 conv=notrunc status=none
+            ;;
+        framebuffer-count)
+            printf '\377\377\377\377' | dd of="${i915_images[0]}" \
+                bs=1 seek=36 conv=notrunc status=none
+            ;;
+        mapping-count)
+            printf '\377\377\377\377' | dd of="${i915_images[0]}" \
+                bs=1 seek=64 conv=notrunc status=none
+            ;;
+        device)
+            printf '\206\200\377\377' | dd of="${i915_images[0]}" \
+                bs=1 seek=52 conv=notrunc status=none
+            ;;
+        truncated)
+            truncate -s -1 "${i915_images[0]}"
+            ;;
+        *)
+            echo "unknown KMS corruption mode: $corrupt_mode" >&2
+            exit 2
+            ;;
+    esac
+    set +e
+    "$criu" restore -D "$images" --shell-job --restore-detached \
+        "${plugin_args[@]}" --log-file restore.log -v4
+    restore_status=$?
+    set -e
+    if (( restore_status == 0 || restore_status >= 128 )); then
+        echo "corrupt KMS image did not fail safely: status=$restore_status" >&2
+        exit 1
+    fi
+    for _ in $(seq 1 100); do
+        ! kill -0 "$original_pid" 2>/dev/null && break
+        sleep 0.05
+    done
+    if kill -0 "$original_pid" 2>/dev/null; then
+        echo "partially restored KMS fixture survived refusal" >&2
+        kill -KILL "$original_pid" 2>/dev/null || true
+        exit 1
+    fi
+    grep -Eq 'Restoring FAILED|Failed to prepare restore plugins' \
+        "$images/restore.log"
+    printf 'PASS: corrupt KMS image mode=%s refused transactionally (status=%s)\n' \
+        "$corrupt_mode" "$restore_status"
+    exit 0
+fi
+"$criu" restore -D "$images" --shell-job --restore-detached \
+    "${plugin_args[@]}" --log-file restore.log -v4
+fixture_pid=$original_pid
+kill -USR1 "$fixture_pid"
+for _ in $(seq 1 200); do
+    grep -Fqx "$expected" "$log" && break
+    kill -0 "$fixture_pid" 2>/dev/null || true
+    sleep 0.05
+done
+grep -Fqx "$expected" "$log"
+# The focused test has proved resumed scanout and a new page flip. Reap the
+# restored fixture so later fault cases can acquire DRM master independently.
+kill -KILL "$fixture_pid"
+wait "$fixture_pid" 2>/dev/null || true
+fixture_pid=
+printf 'PASS: CRIU restored physical atomic KMS pid=%s (%s)\n' \
+    "$original_pid" "$ready"
