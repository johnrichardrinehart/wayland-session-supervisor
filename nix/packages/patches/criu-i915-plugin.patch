++int i915_criu_data_ioctl(struct drm_device *dev, void *data,
++			 struct drm_file *file)
++{
++	struct drm_i915_criu_data *args = data;
++	struct drm_i915_file_private *fpriv = file->driver_priv;
++	int ret;
++
++	if (args->version != I915_CRIU_ABI_VERSION || args->pad ||
++	    memchr_inv(args->reserved, 0, sizeof(args->reserved)) ||
++	    !args->size || !args->data_ptr)
++		return -EINVAL;
++
++	mutex_lock(&fpriv->criu_lock);
++	if (args->op == I915_CRIU_DATA_READ) {
++		struct drm_i915_gem_pread pread = {
++			.handle = args->handle,
++			.offset = args->offset,
++			.size = args->size,
++			.data_ptr = args->data_ptr,
++		};
++
++		ret = check_session(fpriv, args->cookie, I915_CRIU_MODE_DUMP);
++		if (!ret)
++			ret = i915_gem_pread_ioctl(dev, &pread, file);
++	} else if (args->op == I915_CRIU_DATA_WRITE) {
++		struct drm_i915_gem_pwrite pwrite = {
++			.handle = args->handle,
++			.offset = args->offset,
++			.size = args->size,
++			.data_ptr = args->data_ptr,
++		};
++
++		ret = check_session(fpriv, args->cookie,
++				    I915_CRIU_MODE_RESTORE);
++		if (!ret)
++			ret = i915_gem_pwrite_ioctl(dev, &pwrite, file);
++	} else {
++		ret = -EINVAL;
++	}
++	mutex_unlock(&fpriv->criu_lock);
++
++	return ret;
++}
