++	} else if (args->op == I915_CRIU_CONTEXT_CREATE_CONTEXT) {
++		struct drm_i915_gem_context_create_ext create = {
++			.flags =
++				args->flags & I915_CRIU_CONTEXT_SINGLE_TIMELINE ?
++					I915_CONTEXT_CREATE_FLAGS_SINGLE_TIMELINE :
++					0,
++		};
++		struct drm_i915_gem_context_destroy destroy;
++
++		if (!args->id || args->flags & ~supported_flags ||
++		    args->vm_id == U32_MAX ||
++		    args->engine_count > I915_CRIU_MAX_CONTEXT_ENGINES ||
++		    (!(args->flags & I915_CRIU_CONTEXT_USER_ENGINES) &&
++		     (args->engine_count || args->engines_ptr)) ||
++		    (args->flags & I915_CRIU_CONTEXT_USER_ENGINES &&
++		     args->engine_count && !args->engines_ptr)) {
++			ret = -EINVAL;
++			goto out;
++		}
++		ret = check_session(fpriv, args->cookie,
++				    I915_CRIU_MODE_RESTORE);
++		if (ret)
++			goto out;
++		if (args->vm_id &&
++		    !xa_load(&fpriv->criu_restore_vms, args->vm_id)) {
++			ret = -ENOENT;
++			goto out;
++		}
++		ret = i915_gem_context_create_ioctl(dev, &create, file);
++		if (ret)
++			goto out;
++		if (create.ctx_id != args->id) {
++			ret = -ERANGE;
++			goto destroy_context;
++		}
++		ret = restore_context_engines(fpriv, args);
++		if (ret)
++			goto destroy_context;
++		if (!(args->flags & I915_CRIU_CONTEXT_RECOVERABLE)) {
++			ret = restore_context_param(
++				dev, file, args->id,
++				I915_CONTEXT_PARAM_RECOVERABLE, 0);
++			if (ret)
++				goto destroy_context;
++		}
++		ret = restore_context_param(
++			dev, file, args->id, I915_CONTEXT_PARAM_BANNABLE,
++			!!(args->flags & I915_CRIU_CONTEXT_BANNABLE));
++		if (ret)
++			goto destroy_context;
++		ret = restore_context_param(
