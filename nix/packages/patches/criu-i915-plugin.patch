++	__u32 flags;
++	__u64 object_id;
++	/* Zero starts query; incremented on output. Must be zero for create. */
++	__u64 cursor;
++	/* Previous query address on input; exact address on output/create. */
++	__u64 address;
++	__u64 size;
++	__u64 reserved[3];
++};
