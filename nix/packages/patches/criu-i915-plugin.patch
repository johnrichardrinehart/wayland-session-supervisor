+static int collect_dump_framebuffers(int fd, uint64_t cookie,
+				     struct i915_image_framebuffer **result,
+				     size_t *result_count)
+{
+	struct i915_image_framebuffer *framebuffers = NULL;
+	size_t count = 0;
+	u32 cursor = 0;
+
+	for (;;) {
+		struct drm_i915_criu_framebuffer query = {
+			.version = I915_CRIU_ABI_VERSION,
+			.op = I915_CRIU_FRAMEBUFFER_QUERY,
+			.cookie = cookie,
+			.id = cursor,
+		};
+		struct i915_image_framebuffer *grown;
+
+		if (ioctl(fd, DRM_IOCTL_I915_CRIU_FRAMEBUFFER, &query) < 0) {
+			if (errno == ENOENT)
+				break;
+			xfree(framebuffers);
+			return -errno;
+		}
+		if (count == I915_MAX_RESTORE_FRAMEBUFFERS || query.id <= cursor) {
+			xfree(framebuffers);
+			return -E2BIG;
+		}
+		grown = xrealloc(framebuffers,
+				 (count + 1) * sizeof(*framebuffers));
+		if (!grown) {
+			xfree(framebuffers);
+			return -ENOMEM;
+		}
+		framebuffers = grown;
+		framebuffers[count++] = (struct i915_image_framebuffer){
+			.id = query.id,
+			.flags = query.flags,
+			.object_id = query.object_id,
+			.width = query.width,
+			.height = query.height,
+			.pixel_format = query.pixel_format,
+			.pitch = query.pitch,
+			.offset = query.offset,
+			.modifier = query.modifier,
+		};
+		cursor = query.id;
+	}
+	*result = framebuffers;
+	*result_count = count;
+	return 0;
+}
+
+static void free_dump_blobs(struct dump_blob *blobs, size_t count)
+{
+	for (size_t i = 0; i < count; i++)
+		xfree(blobs[i].data);
+	xfree(blobs);
+}
+
+static int collect_dump_blobs(int fd, uint64_t cookie,
+			      struct dump_blob **result, size_t *result_count)
+{
+	struct dump_blob *blobs = NULL;
+	size_t count = 0;
+	u32 cursor = 0;
+
+	for (;;) {
+		struct drm_i915_criu_blob query = {
+			.version = I915_CRIU_ABI_VERSION,
+			.op = I915_CRIU_BLOB_QUERY,
+			.cookie = cookie,
+			.id = cursor,
+		};
+		struct dump_blob *grown;
+		void *contents;
+
+		if (ioctl(fd, DRM_IOCTL_I915_CRIU_BLOB, &query) < 0) {
+			if (errno == ENOENT)
+				break;
+			free_dump_blobs(blobs, count);
+			return -errno;
+		}
+		if (count == I915_MAX_RESTORE_BLOBS || query.id <= cursor ||
+		    !query.length || query.length > I915_MAX_BLOB_SIZE) {
+			free_dump_blobs(blobs, count);
+			return -E2BIG;
+		}
+		contents = xmalloc(query.length);
+		if (!contents) {
+			free_dump_blobs(blobs, count);
+			return -ENOMEM;
+		}
+		query.op = I915_CRIU_BLOB_READ;
+		query.data_ptr = (uintptr_t)contents;
+		if (ioctl(fd, DRM_IOCTL_I915_CRIU_BLOB, &query) < 0) {
+			int ret = -errno;
+
+			xfree(contents);
+			free_dump_blobs(blobs, count);
+			return ret;
+		}
+		grown = xrealloc(blobs, (count + 1) * sizeof(*blobs));
+		if (!grown) {
+			xfree(contents);
+			free_dump_blobs(blobs, count);
+			return -ENOMEM;
+		}
+		blobs = grown;
+		blobs[count++] = (struct dump_blob){
+			.image = {
+				.id = query.id,
+				.length = query.length,
+			},
+			.data = contents,
+		};
+		cursor = query.id;
+	}
+	*result = blobs;
+	*result_count = count;
+	return 0;
+}
+
+static bool ephemeral_atomic_property(const char *name)
+{
+	return !strcmp(name, "DPMS") || !strcmp(name, "FB_DAMAGE_CLIPS") ||
+	       !strcmp(name, "IN_FENCE_FD") || !strcmp(name, "OUT_FENCE_PTR") ||
+	       !strcmp(name, "WRITEBACK_OUT_FENCE_PTR");
+}
+
+static bool property_marks_active(const char *name, uint64_t value)
+{
+	return value && (!strcmp(name, "CRTC_ID") || !strcmp(name, "FB_ID") ||
+			 !strcmp(name, "ACTIVE") || !strcmp(name, "MODE_ID"));
+}
+
+static int collect_active_object_properties(
+	int fd, uint32_t object_id, uint32_t object_type,
+	struct i915_image_kms_property **properties, size_t *count)
+{
+	drmModeObjectPropertiesPtr object;
+	bool active = false;
+	int ret = 0;
+
+	object = drmModeObjectGetProperties(fd, object_id, object_type);
+	if (!object)
+		return -errno;
+	for (uint32_t i = 0; i < object->count_props; i++) {
+		drmModePropertyPtr property = drmModeGetProperty(fd,
+								 object->props[i]);
+
+		if (!property) {
+			ret = -errno;
+			goto out;
+		}
+		if (property_marks_active(property->name,
+					  object->prop_values[i]))
+			active = true;
+		drmModeFreeProperty(property);
+	}
+	if (!active)
+		goto out;
+	for (uint32_t i = 0; i < object->count_props; i++) {
+		drmModePropertyPtr property = drmModeGetProperty(fd,
+								 object->props[i]);
+		struct i915_image_kms_property *grown;
+
+		if (!property) {
+			ret = -errno;
+			goto out;
+		}
+		if (property->flags & DRM_MODE_PROP_IMMUTABLE ||
+		    ephemeral_atomic_property(property->name)) {
+			drmModeFreeProperty(property);
+			continue;
+		}
+		if (*count == I915_MAX_RESTORE_KMS_PROPERTIES) {
+			drmModeFreeProperty(property);
+			ret = -E2BIG;
+			goto out;
+		}
+		grown = xrealloc(*properties,
+				 (*count + 1) * sizeof(**properties));
+		if (!grown) {
+			drmModeFreeProperty(property);
+			ret = -ENOMEM;
+			goto out;
+		}
+		*properties = grown;
+		(*properties)[(*count)++] =
+			(struct i915_image_kms_property){
+				.object_id = object_id,
+				.object_type = object_type,
+				.property_id = object->props[i],
+				.value = object->prop_values[i],
+			};
+		drmModeFreeProperty(property);
+	}
+out:
+	drmModeFreeObjectProperties(object);
+	return ret;
+}
+
+static int collect_dump_kms_properties(
+	int fd, uint32_t file_flags,
+	struct i915_image_kms_property **result, size_t *result_count)
+{
+	struct i915_image_kms_property *properties = NULL;
+	drmModePlaneResPtr planes = NULL;
+	drmModeResPtr resources = NULL;
+	size_t count = 0;
+	int ret = 0;
+
+	if (!(file_flags & I915_CRIU_FILE_PRIMARY))
+		goto out;
+	if (!(file_flags & I915_CRIU_FILE_MASTER))
+		goto out;
+	if (!(file_flags & I915_CRIU_FILE_ATOMIC))
+		return -EOPNOTSUPP;
+	resources = drmModeGetResources(fd);
+	planes = drmModeGetPlaneResources(fd);
+	if (!resources || !planes) {
+		ret = -errno;
+		goto out;
+	}
+	for (int i = 0; !ret && i < resources->count_connectors; i++)
+		ret = collect_active_object_properties(
+			fd, resources->connectors[i], DRM_MODE_OBJECT_CONNECTOR,
+			&properties, &count);
+	for (int i = 0; !ret && i < resources->count_crtcs; i++)
+		ret = collect_active_object_properties(
+			fd, resources->crtcs[i], DRM_MODE_OBJECT_CRTC,
+			&properties, &count);
+	for (uint32_t i = 0; !ret && i < planes->count_planes; i++)
+		ret = collect_active_object_properties(
+			fd, planes->planes[i], DRM_MODE_OBJECT_PLANE,
+			&properties, &count);
+out:
+	if (resources)
+		drmModeFreeResources(resources);
+	if (planes)
+		drmModeFreePlaneResources(planes);
+	if (ret) {
+		xfree(properties);
+		return ret;
+	}
+	*result = properties;
+	*result_count = count;
+	return 0;
+}
+
+static int collect_dump_mappings(int fd, uint64_t cookie,
+				 const struct dump_object *objects,
+				 size_t object_count,
+				 struct i915_image_mapping **result,
+				 size_t *result_count)
+{
+	struct i915_image_mapping *mappings;
+	size_t count = 0;
+
+	mappings = xmalloc(dump_vma_count * sizeof(*mappings));
+	if (dump_vma_count && !mappings)
+		return -ENOMEM;
+	for (size_t i = 0; i < dump_vma_count; i++) {
+		struct drm_i915_criu_mapping query = {
+			.version = I915_CRIU_ABI_VERSION,
+			.op = I915_CRIU_MAPPING_QUERY,
+			.cookie = cookie,
+			.offset = dump_vmas[i].pgoff,
+		};
+		bool object_found = false;
+		bool duplicate = false;
+
+		if (dump_vmas[i].resolved)
+			continue;
+		if (ioctl(fd, DRM_IOCTL_I915_CRIU_MAPPING, &query) < 0) {
+			if (errno == ENOENT || errno == EACCES || errno == EXDEV)
+				continue;
+			xfree(mappings);
+			return -errno;
+		}
+		for (size_t j = 0; j < object_count; j++)
+			if (objects[j].image.object_id == query.object_id &&
+			    objects[j].image.size == query.size) {
+				object_found = true;
+				break;
+			}
+		if (!object_found || !query.offset || !query.size || query.pad ||
+		    query.mmap_type > I915_MMAP_OFFSET_UC) {
+			xfree(mappings);
+			return -EXDEV;
+		}
+		for (size_t j = 0; j < count; j++)
+			if (mappings[j].object_id == query.object_id &&
+			    mappings[j].offset == query.offset &&
+			    mappings[j].size == query.size &&
+			    mappings[j].mmap_type == query.mmap_type) {
+				duplicate = true;
+				break;
+			}
+		if (!duplicate)
+			mappings[count++] = (struct i915_image_mapping){
+				.object_id = query.object_id,
+				.offset = query.offset,
+				.size = query.size,
+				.mmap_type = query.mmap_type,
+			};
+		dump_vmas[i].resolved = true;
+	}
+	*result = mappings;
+	*result_count = count;
+	return 0;
+}
+
+static int write_image(int file_id, struct dump_object *objects, size_t count,
+		       const struct i915_image_mapping *mappings,
+		       size_t mapping_count,
+		       const struct i915_image_syncobj *syncobjs,
+		       size_t syncobj_count,
+		       const struct i915_image_context *vms, size_t vm_count,
+		       const struct i915_image_context *contexts,
+		       size_t context_count,
+		       const struct i915_image_binding *bindings,
+		       size_t binding_count,
+		       const struct i915_image_framebuffer *framebuffers,
+		       size_t framebuffer_count,
+		       const struct dump_blob *blobs, size_t blob_count,
+		       const struct i915_image_kms_property *kms_properties,
+		       size_t kms_property_count, uint32_t file_flags,
+		       const struct i915_device_identity *identity)
+{
+	struct i915_image_header header = {
+		.magic = I915_IMAGE_MAGIC,
+		.version = I915_IMAGE_VERSION,
+		.file_id = file_id,
+		.object_count = count,
+		.syncobj_count = syncobj_count,
+		.vm_count = vm_count,
+		.context_count = context_count,
+		.binding_count = binding_count,
+		.framebuffer_count = framebuffer_count,
+		.blob_count = blob_count,
+		.kms_property_count = kms_property_count,
+		.file_flags = file_flags,
+		.device_identity = identity->vendor_id |
+				   (uint32_t)identity->device_id << 16,
+		.subsystem_identity = identity->subsystem_vendor_id |
+				      (uint32_t)identity->subsystem_device_id << 16,
+		.revision = identity->revision,
+		.mapping_count = mapping_count,
+		.kind = I915_IMAGE_KIND_DRM_FILE,
+	};
+	int fd = image_fd(file_id, O_WRONLY | O_CREAT | O_EXCL);
+	int ret;
+
+	if (fd < 0)
+		return -errno;
+	ret = write_all(fd, &header, sizeof(header));
+	for (size_t i = 0; !ret && i < count; i++) {
+		ret = write_all(fd, &objects[i].image, sizeof(objects[i].image));
+		if (!ret)
+			ret = write_all(fd, objects[i].data, objects[i].image.size);
+	}
+	if (!ret && mapping_count)
+		ret = write_all(fd, mappings,
+				mapping_count * sizeof(*mappings));
+	if (!ret && syncobj_count)
+		ret = write_all(fd, syncobjs,
+				syncobj_count * sizeof(*syncobjs));
+	if (!ret && vm_count)
+		ret = write_all(fd, vms, vm_count * sizeof(*vms));
+	if (!ret && context_count)
+		ret = write_all(fd, contexts,
+				context_count * sizeof(*contexts));
+	if (!ret && binding_count)
+		ret = write_all(fd, bindings,
+				binding_count * sizeof(*bindings));
+	if (!ret && framebuffer_count)
+		ret = write_all(fd, framebuffers,
+				framebuffer_count * sizeof(*framebuffers));
+	for (size_t i = 0; !ret && i < blob_count; i++) {
+		ret = write_all(fd, &blobs[i].image, sizeof(blobs[i].image));
+		if (!ret)
+			ret = write_all(fd, blobs[i].data,
+					blobs[i].image.length);
+	}
+	if (!ret && kms_property_count)
+		ret = write_all(fd, kms_properties,
+				kms_property_count * sizeof(*kms_properties));
+	if (close(fd) && !ret)
+		ret = -errno;
+	return ret;
+}
+
+static int i915_plugin_init(int stage)
+{
+	if (stage == CR_PLUGIN_STAGE__RESTORE &&
+	    !check_and_remove_inventory_plugin(CR_PLUGIN_DESC.name,
+					       strlen(CR_PLUGIN_DESC.name)))
+		return 0;
+
+	checkpoint_pid = -1;
+	inventory_added = false;
+	dump_relationship_count = 0;
+	dump_vma_count = 0;
+	dump_dmabuf_file_count = 0;
+	dump_sync_file_count = 0;
+	dump_drm_file_count = 0;
+	restore_object_count = 0;
+	restore_mapping_count = 0;
+	restore_file_count = 0;
+	restore_kms_property_count = 0;
+	prepared_file_count = 0;
+	return 0;
+}
+
+static void abort_restore_sessions(void)
+{
+	for (size_t i = 0; i < restore_file_count; i++) {
+		if (!restore_files[i].active)
+			continue;
+		int fd = criu_plugin_fdstore_get(restore_files[i].fdstore_id);
+
+		if (fd < 0 ||
+		    session_ioctl(fd, I915_CRIU_SESSION_ABORT, 0,
+				  &restore_files[i].cookie))
+			pr_err("failed to abort i915 restore transaction\n");
+		if (fd >= 0)
+			close(fd);
+		restore_files[i].active = false;
+	}
+}
+
+static void i915_plugin_fini(int stage, int ret)
+{
+	for (size_t i = 0; i < dump_relationship_count; i++) {
+		if (dump_relationships[i].verification_fd >= 0)
+			close(dump_relationships[i].verification_fd);
+		dump_relationships[i].verification_fd = -1;
+	}
+	for (size_t i = 0; i < dump_sync_file_count; i++) {
+		if (dump_sync_files[i].retained_fd >= 0)
+			close(dump_sync_files[i].retained_fd);
+		dump_sync_files[i].retained_fd = -1;
+	}
+	for (size_t i = 0; i < dump_drm_file_count; i++) {
+		if (dump_drm_files[i].retained_fd >= 0)
+			close(dump_drm_files[i].retained_fd);
+		dump_drm_files[i].retained_fd = -1;
+	}
+	if (stage == CR_PLUGIN_STAGE__RESTORE && ret)
+		abort_restore_sessions();
+}
+
+CR_PLUGIN_REGISTER("i915_plugin", i915_plugin_init, i915_plugin_fini)
