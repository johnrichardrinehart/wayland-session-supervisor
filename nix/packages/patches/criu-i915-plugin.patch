++			ret = -EEXIST;
++		else {
++			obj->criu_id = args->object_id;
++			if (atomic64_read(&i915_criu_next_object_id) <
++			    args->object_id)
++				atomic64_set(&i915_criu_next_object_id,
++					     args->object_id);
++		}
++		mutex_unlock(&i915_criu_object_id_lock);
++		if (ret)
++			goto put_restore_obj;
++
++		old = xa_store(&fpriv->criu_restore_handles, args->object_id,
++			       xa_mk_value(handle), GFP_KERNEL);
++		if (xa_is_err(old) || old) {
++			ret = old ? -EEXIST : xa_err(old);
