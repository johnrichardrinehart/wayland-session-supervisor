++static int user_gem_handle_count(struct drm_device *dev,
++				 struct drm_gem_object *object, u32 *count)
++{
++	struct drm_framebuffer *fb;
++	u32 framebuffer_refs = 0;
++	unsigned int total;
++
++	mutex_lock(&dev->mode_config.fb_lock);
++	list_for_each_entry(fb, &dev->mode_config.fb_list, head) {
++		for (unsigned int plane = 0;
++		     plane < fb->format->num_planes; plane++) {
++			if (fb->obj[plane] == object &&
++			    fb->internal_flags &
++				    DRM_FRAMEBUFFER_HAS_HANDLE_REF(plane))
++				framebuffer_refs++;
++		}
++	}
++	mutex_unlock(&dev->mode_config.fb_lock);
++
++	mutex_lock(&dev->object_name_lock);
++	total = object->handle_count;
++	mutex_unlock(&dev->object_name_lock);
++	if (framebuffer_refs >= total)
++		return -EUCLEAN;
++	*count = total - framebuffer_refs;
++	return 0;
++}
