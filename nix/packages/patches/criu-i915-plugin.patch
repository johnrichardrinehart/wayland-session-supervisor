++static int validate_kms_file_state(struct drm_device *dev,
++				   struct drm_file *file)
++{
++	unsigned long irqflags;
++	bool has_events;
++	bool has_leases = false;
++
++	spin_lock_irqsave(&dev->event_lock, irqflags);
++	has_events = !list_empty(&file->pending_event_list) ||
++		     !list_empty(&file->event_list);
++	spin_unlock_irqrestore(&dev->event_lock, irqflags);
++	if (has_events)
++		return -EBUSY;
++
++	mutex_lock(&dev->mode_config.idr_mutex);
++	if (file->master)
++		has_leases = file->master->lessor ||
++			     !list_empty(&file->master->lessees);
++	mutex_unlock(&dev->mode_config.idr_mutex);
++	return has_leases ? -EOPNOTSUPP : 0;
++}
