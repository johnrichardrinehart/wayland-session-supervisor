--- /dev/null
+++ b/test/others/i915-criu/i915-context-sync.c
@@ -0,0 +1,264 @@
+// SPDX-License-Identifier: GPL-2.0
+#define _GNU_SOURCE
+#include <errno.h>
+#include <fcntl.h>
+#include <inttypes.h>
+#include <signal.h>
+#include <stdbool.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/eventfd.h>
+#include <sys/ioctl.h>
+#include <sys/mman.h>
+#include <unistd.h>
+
+#include <drm/drm.h>
+#include <drm/i915_drm.h>
+
+#define OBJECT_SIZE (4 * 4096u)
+#define TIMELINE_POINT UINT64_C(5)
+#define POST_RESTORE_POINT UINT64_C(9)
+
+static volatile sig_atomic_t resume_test;
+
+static void die(const char *what)
+{
+	perror(what);
+	exit(EXIT_FAILURE);
+}
+
+static void on_signal(int signo)
+{
+	(void)signo;
+	resume_test = 1;
+}
+
+static void xioctl(int fd, unsigned long request, void *arg, const char *what)
+{
+	if (ioctl(fd, request, arg) < 0)
+		die(what);
+}
+
+static void signal_binary(int fd, uint32_t handle)
+{
+	struct drm_syncobj_array signal = {
+		.handles = (uintptr_t)&handle,
+		.count_handles = 1,
+	};
+
+	xioctl(fd, DRM_IOCTL_SYNCOBJ_SIGNAL, &signal, "SYNCOBJ_SIGNAL");
+}
+
+static void wait_binary(int fd, uint32_t handle)
+{
+	struct drm_syncobj_wait wait = {
+		.handles = (uintptr_t)&handle,
+		.timeout_nsec = INT64_MAX,
+		.count_handles = 1,
+		.flags = DRM_SYNCOBJ_WAIT_FLAGS_WAIT_ALL,
+	};
+
+	xioctl(fd, DRM_IOCTL_SYNCOBJ_WAIT, &wait, "SYNCOBJ_WAIT");
+}
+
+static void signal_timeline(int fd, uint32_t handle, uint64_t point)
+{
+	struct drm_syncobj_timeline_array signal = {
+		.handles = (uintptr_t)&handle,
+		.points = (uintptr_t)&point,
+		.count_handles = 1,
+	};
+
+	xioctl(fd, DRM_IOCTL_SYNCOBJ_TIMELINE_SIGNAL, &signal,
+	       "SYNCOBJ_TIMELINE_SIGNAL");
+}
+
+static void wait_timeline(int fd, uint32_t handle, uint64_t point)
+{
+	struct drm_syncobj_timeline_wait wait = {
+		.handles = (uintptr_t)&handle,
+		.points = (uintptr_t)&point,
+		.timeout_nsec = INT64_MAX,
+		.count_handles = 1,
+		.flags = DRM_SYNCOBJ_WAIT_FLAGS_WAIT_ALL,
+	};
+
+	xioctl(fd, DRM_IOCTL_SYNCOBJ_TIMELINE_WAIT, &wait,
+	       "SYNCOBJ_TIMELINE_WAIT");
+}
+
+static void submit(int fd, uint32_t context, uint32_t handle, void *mapping,
+		   uint64_t *gpu_address, bool *gpu_address_valid,
+		   bool require_exact_address)
+{
+	uint32_t *batch = (uint32_t *)((char *)mapping + OBJECT_SIZE - 8);
+	uint32_t saved[2] = { batch[0], batch[1] };
+	struct drm_i915_gem_exec_object2 object = {
+		.handle = handle,
+		.offset = *gpu_address,
+		.flags = require_exact_address ? EXEC_OBJECT_PINNED : 0,
+	};
+	struct drm_i915_gem_execbuffer2 execbuf = {
+		.buffers_ptr = (uintptr_t)&object,
+		.buffer_count = 1,
+		.batch_start_offset = OBJECT_SIZE - 8,
+		.batch_len = 8,
+		.flags = I915_EXEC_RENDER,
+		.rsvd1 = context,
+	};
+	struct drm_i915_gem_wait wait = {
+		.bo_handle = handle,
+		.timeout_ns = 5 * INT64_C(1000000000),
+	};
+
+	batch[0] = 0x05000000;
+	batch[1] = 0;
+	fprintf(stderr, "SUBMIT context=%u gpu_address=%#" PRIx64 " exact=%u\n",
+		context, *gpu_address, require_exact_address);
+	xioctl(fd, DRM_IOCTL_I915_GEM_EXECBUFFER2, &execbuf, "EXECBUFFER2 context");
+	fprintf(stderr, "SUBMITTED context=%u gpu_address=%#" PRIx64 "\n",
+		context, (uint64_t)object.offset);
+	if (require_exact_address && object.offset != *gpu_address) {
+		errno = EADDRNOTAVAIL;
+		die("EXECBUFFER2 changed restored GPU address");
+	}
+	*gpu_address = object.offset;
+	*gpu_address_valid = true;
+	xioctl(fd, DRM_IOCTL_I915_GEM_WAIT, &wait, "GEM_WAIT context");
+	fprintf(stderr, "QUIESCED context=%u\n", context);
+	batch[0] = saved[0];
+	batch[1] = saved[1];
+}
+
+int main(int argc, char **argv)
+{
+	struct sigaction action = { .sa_handler = on_signal };
+	bool sync_only = argc == 2 && !strcmp(argv[1], "--sync-only");
+	bool idle_context = argc == 2 && !strcmp(argv[1], "--idle-context");
+	bool callback = argc == 2 && !strcmp(argv[1], "--callback");
+	bool custom_engine = argc == 2 && !strcmp(argv[1], "--custom-engine");
+	struct drm_i915_gem_vm_control vm = { 0 };
+	struct drm_i915_gem_context_create context = { 0 };
+	struct drm_i915_gem_context_param context_vm;
+	struct drm_i915_gem_create object = { .size = OBJECT_SIZE };
+	struct drm_i915_gem_mmap_offset mmap_offset;
+	struct drm_syncobj_create binary = { 0 };
+	struct drm_syncobj_create timeline = { 0 };
+	void *mapping;
+	uint64_t gpu_address = 0;
+	bool gpu_address_valid = false;
+	int callback_fd = -1;
+	int fd;
+
+	if (argc > 2 || (argc == 2 && !sync_only && !idle_context &&
+				 !callback && !custom_engine)) {
+		fprintf(stderr, "usage: %s [--sync-only|--idle-context|--callback|--custom-engine]\n",
+			argv[0]);
+		return EXIT_FAILURE;
+	}
+	fd = open("/dev/dri/renderD128", O_RDWR | O_CLOEXEC);
+	if (fd < 0)
+		die("open render node");
+	if (!sync_only && !callback) {
+		xioctl(fd, DRM_IOCTL_I915_GEM_VM_CREATE, &vm, "GEM_VM_CREATE");
+		if (custom_engine) {
+			I915_DEFINE_CONTEXT_PARAM_ENGINES(engines, 1) = {
+				.engines = { { I915_ENGINE_CLASS_RENDER, 0 } },
+			};
+			struct drm_i915_gem_context_create_ext_setparam set_engines = {
+				.base.name = I915_CONTEXT_CREATE_EXT_SETPARAM,
+				.param = {
+					.param = I915_CONTEXT_PARAM_ENGINES,
+					.value = (uintptr_t)&engines,
+					.size = sizeof(engines),
+				},
+			};
+			struct drm_i915_gem_context_create_ext create = {
+				.flags = I915_CONTEXT_CREATE_FLAGS_USE_EXTENSIONS,
+				.extensions = (uintptr_t)&set_engines,
+			};
+
+			xioctl(fd, DRM_IOCTL_I915_GEM_CONTEXT_CREATE_EXT, &create,
+			       "GEM_CONTEXT_CREATE_EXT engines");
+			context.ctx_id = create.ctx_id;
+		} else {
+			xioctl(fd, DRM_IOCTL_I915_GEM_CONTEXT_CREATE, &context,
+			       "GEM_CONTEXT_CREATE");
+		}
+		context_vm = (struct drm_i915_gem_context_param) {
+			.ctx_id = context.ctx_id,
+			.param = I915_CONTEXT_PARAM_VM,
+			.value = vm.vm_id,
+		};
+		xioctl(fd, DRM_IOCTL_I915_GEM_CONTEXT_SETPARAM, &context_vm,
+		       "GEM_CONTEXT_SETPARAM VM");
+	}
+	xioctl(fd, DRM_IOCTL_I915_GEM_CREATE, &object, "GEM_CREATE");
+	mmap_offset = (struct drm_i915_gem_mmap_offset) {
+		.handle = object.handle,
+		.flags = I915_MMAP_OFFSET_WB,
+	};
+	xioctl(fd, DRM_IOCTL_I915_GEM_MMAP_OFFSET, &mmap_offset,
+	       "GEM_MMAP_OFFSET");
+	mapping = mmap(NULL, OBJECT_SIZE, PROT_READ | PROT_WRITE, MAP_SHARED,
+		       fd, mmap_offset.offset);
+	if (mapping == MAP_FAILED)
+		die("mmap GEM object");
+
+	xioctl(fd, DRM_IOCTL_SYNCOBJ_CREATE, &binary, "binary SYNCOBJ_CREATE");
+	xioctl(fd, DRM_IOCTL_SYNCOBJ_CREATE, &timeline,
+	       "timeline SYNCOBJ_CREATE");
+	if (callback) {
+		struct drm_syncobj_eventfd registration;
+
+		callback_fd = eventfd(0, EFD_CLOEXEC);
+		if (callback_fd < 0)
+			die("eventfd");
+		registration = (struct drm_syncobj_eventfd) {
+			.handle = binary.handle,
+			.fd = callback_fd,
+		};
+		xioctl(fd, DRM_IOCTL_SYNCOBJ_EVENTFD, &registration,
+		       "SYNCOBJ_EVENTFD");
+	} else {
+		signal_binary(fd, binary.handle);
+	}
+	signal_timeline(fd, timeline.handle, TIMELINE_POINT);
+	if (!idle_context && !sync_only && !callback && !custom_engine)
+		submit(fd, context.ctx_id, object.handle, mapping, &gpu_address,
+		       &gpu_address_valid, false);
+
+	if (sigaction(SIGUSR1, &action, NULL) < 0)
+		die("sigaction");
+	printf("READY pid=%d context=%u vm=%u binary=%u timeline=%u address=%p mmap_offset=%#" PRIx64 " gpu_address=%#" PRIx64 " gpu_address_valid=%u\n",
+	       getpid(), context.ctx_id, vm.vm_id, binary.handle,
+	       timeline.handle, mapping, (uint64_t)mmap_offset.offset,
+	       gpu_address, gpu_address_valid);
+	fflush(stdout);
+	while (!resume_test)
+		pause();
+
+	if (callback || custom_engine) {
+		fprintf(stderr, "unsupported mode must be refused before resume\n");
+		return EXIT_FAILURE;
+	}
+	fprintf(stderr, "RESUMED pid=%d\n", getpid());
+	wait_binary(fd, binary.handle);
+	fprintf(stderr, "BINARY-SIGNALED handle=%u\n", binary.handle);
+	wait_timeline(fd, timeline.handle, TIMELINE_POINT);
+	fprintf(stderr, "TIMELINE-SIGNALED handle=%u point=%" PRIu64 "\n",
+		timeline.handle, (uint64_t)TIMELINE_POINT);
+	submit(fd, context.ctx_id, object.handle, mapping, &gpu_address,
+	       &gpu_address_valid, gpu_address_valid);
+	signal_timeline(fd, timeline.handle, POST_RESTORE_POINT);
+	wait_timeline(fd, timeline.handle, POST_RESTORE_POINT);
+	if (sync_only)
+		puts("PASS: binary syncobj, timeline, and GPU submission");
+	else if (idle_context)
+		puts("PASS: idle context, explicit VM, binary syncobj, timeline, and GPU submission");
+	else
+		puts("PASS: materialized context, explicit VM, exact GPU address, binary syncobj, timeline, and GPU submission");
+	return EXIT_SUCCESS;
+}
diff --git a/test/others/i915-criu/i915-gem-minimal.c b/test/others/i915-criu/i915-gem-minimal.c
new file mode 100644
index 000000000..f770602df
--- /dev/null
+++ b/test/others/i915-criu/i915-gem-minimal.c
@@ -0,0 +1,247 @@
+// SPDX-License-Identifier: GPL-2.0
+#define _GNU_SOURCE
+#include <errno.h>
+#include <fcntl.h>
+#include <inttypes.h>
+#include <signal.h>
+#include <stdbool.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/ioctl.h>
+#include <sys/mman.h>
+#include <unistd.h>
+
+#include <drm/i915_drm.h>
+#include "../../../contrib/i915-criu/i915_criu_uapi.h"
+
+#define OBJECT_SIZE (4 * 4096u)
+#define PATTERN_SEED UINT64_C(0x915c7100d15ea5e)
+
+static volatile sig_atomic_t resume_test;
+
+static void on_signal(int signo)
+{
+	(void)signo;
+	resume_test = 1;
+}
+
+static void die(const char *what)
+{
+	perror(what);
+	exit(EXIT_FAILURE);
+}
+
+static void xioctl(int fd, unsigned long request, void *arg, const char *what)
+{
+	if (ioctl(fd, request, arg) < 0)
+		die(what);
+}
+
+static uint64_t pattern_word(size_t index)
+{
+	uint64_t value = PATTERN_SEED ^ (uint64_t)index * UINT64_C(0x9e3779b97f4a7c15);
+	value ^= value >> 29;
+	value *= UINT64_C(0xbf58476d1ce4e5b9);
+	return value ^ (value >> 31);
+}
+
+static void fill_pattern(void *mapping, size_t size)
+{
+	uint64_t *words = mapping;
+
+	for (size_t i = 0; i < size / sizeof(*words); i++)
+		words[i] = pattern_word(i);
+}
+
+static void verify_pattern(const void *mapping, size_t size)
+{
+	const uint64_t *words = mapping;
+
+	for (size_t i = 0; i < size / sizeof(*words); i++) {
+		uint64_t expected = pattern_word(i);
+		if (words[i] != expected) {
+			fprintf(stderr, "pattern mismatch at %zu: %#" PRIx64 " != %#" PRIx64 "\n",
+				i, words[i], expected);
+			exit(EXIT_FAILURE);
+		}
+	}
+}
+
+static void exercise_gpu(int fd, uint32_t handle, void *mapping, uint64_t size)
+{
+	uint32_t *batch = (uint32_t *)((char *)mapping + size - 8);
+	uint32_t saved[2] = { batch[0], batch[1] };
+	struct drm_i915_gem_exec_object2 object = { .handle = handle };
+	struct drm_i915_gem_execbuffer2 execbuf = {
+		.buffers_ptr = (uintptr_t)&object,
+		.buffer_count = 1,
+		.batch_start_offset = size - 8,
+		.batch_len = 8,
+		.flags = I915_EXEC_RENDER,
+	};
+	struct drm_i915_gem_wait wait = {
+		.bo_handle = handle,
+		.timeout_ns = -1,
+	};
+
+	batch[0] = 0x05000000; /* MI_BATCH_BUFFER_END */
+	batch[1] = 0;
+	xioctl(fd, DRM_IOCTL_I915_GEM_EXECBUFFER2, &execbuf, "post-restore EXECBUFFER2");
+	xioctl(fd, DRM_IOCTL_I915_GEM_WAIT, &wait, "post-restore GEM_WAIT");
+	batch[0] = saved[0];
+	batch[1] = saved[1];
+	verify_pattern(mapping, size);
+}
+
+static uint32_t create_object(int fd, uint64_t size)
+{
+	struct drm_i915_gem_create create = { .size = size };
+	xioctl(fd, DRM_IOCTL_I915_GEM_CREATE, &create, "GEM_CREATE");
+	return create.handle;
+}
+
+static void *map_object(int fd, uint32_t handle, uint64_t size, uint64_t *offset_out)
+{
+	struct drm_i915_gem_mmap_offset mmap_offset = {
+		.handle = handle,
+		.flags = I915_MMAP_OFFSET_WB,
+	};
+	void *mapping;
+
+	xioctl(fd, DRM_IOCTL_I915_GEM_MMAP_OFFSET, &mmap_offset, "GEM_MMAP_OFFSET");
+	mapping = mmap(NULL, size, PROT_READ | PROT_WRITE, MAP_SHARED, fd, mmap_offset.offset);
+	if (mapping == MAP_FAILED)
+		die("mmap GEM object");
+	*offset_out = mmap_offset.offset;
+	return mapping;
+}
+
+static void exercise_transaction(int source_fd, uint32_t source_handle,
+				 const void *source_mapping)
+{
+	struct drm_i915_criu_session dump = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_SESSION_DUMP_BEGIN,
+		.target_pid = getpid(),
+	};
+	struct drm_i915_criu_object object = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_OBJECT_QUERY,
+	};
+	struct drm_i915_criu_data data = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_DATA_READ,
+	};
+	uint8_t *image = malloc(OBJECT_SIZE);
+	int restored_fd;
+
+	if (!image)
+		die("malloc object image");
+
+	xioctl(source_fd, DRM_IOCTL_I915_CRIU_SESSION, &dump, "CRIU DUMP_BEGIN");
+	object.cookie = dump.cookie;
+	xioctl(source_fd, DRM_IOCTL_I915_CRIU_OBJECT, &object, "CRIU OBJECT_QUERY");
+	if (object.handle != source_handle || object.size != OBJECT_SIZE ||
+	    object.flags != I915_CRIU_OBJECT_SHMEM) {
+		fprintf(stderr, "unexpected object description\n");
+		exit(EXIT_FAILURE);
+	}
+
+	data.cookie = dump.cookie;
+	data.handle = object.handle;
+	data.size = object.size;
+	data.data_ptr = (uintptr_t)image;
+	xioctl(source_fd, DRM_IOCTL_I915_CRIU_DATA, &data, "CRIU DATA_READ");
+	if (memcmp(image, source_mapping, OBJECT_SIZE)) {
+		fprintf(stderr, "checkpoint image differs from mapped object\n");
+		exit(EXIT_FAILURE);
+	}
+
+	dump.op = I915_CRIU_SESSION_COMMIT;
+	xioctl(source_fd, DRM_IOCTL_I915_CRIU_SESSION, &dump, "CRIU dump COMMIT");
+
+	restored_fd = open("/dev/dri/renderD128", O_RDWR | O_CLOEXEC);
+	if (restored_fd < 0)
+		die("open restore render node");
+
+	struct drm_i915_criu_session restore = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_SESSION_RESTORE_BEGIN,
+	};
+	xioctl(restored_fd, DRM_IOCTL_I915_CRIU_SESSION, &restore, "CRIU RESTORE_BEGIN");
+
+	object.op = I915_CRIU_OBJECT_CREATE;
+	object.cookie = restore.cookie;
+	object.handle = 0;
+	object.mmap_offset = 0;
+	xioctl(restored_fd, DRM_IOCTL_I915_CRIU_OBJECT, &object, "CRIU OBJECT_CREATE");
+
+	data.op = I915_CRIU_DATA_WRITE;
+	data.cookie = restore.cookie;
+	data.handle = object.handle;
+	xioctl(restored_fd, DRM_IOCTL_I915_CRIU_DATA, &data, "CRIU DATA_WRITE");
+
+	uint64_t restored_offset;
+	void *restored_mapping = map_object(restored_fd, object.handle, object.size,
+					    &restored_offset);
+	verify_pattern(restored_mapping, object.size);
+	munmap(restored_mapping, object.size);
+
+	restore.op = I915_CRIU_SESSION_ABORT;
+	xioctl(restored_fd, DRM_IOCTL_I915_CRIU_SESSION, &restore, "CRIU restore ABORT");
+
+	struct drm_i915_gem_busy busy = { .handle = object.handle };
+	if (ioctl(restored_fd, DRM_IOCTL_I915_GEM_BUSY, &busy) == 0 || errno != ENOENT) {
+		fprintf(stderr, "restore ABORT did not remove handle %u\n", object.handle);
+		exit(EXIT_FAILURE);
+	}
+
+	close(restored_fd);
+	free(image);
+}
+
+int main(int argc, char **argv)
+{
+	bool exercise = argc == 2 && !strcmp(argv[1], "--exercise-criu-api");
+	struct sigaction action = { .sa_handler = on_signal };
+	uint64_t mmap_offset;
+	uint32_t handle;
+	void *mapping;
+	int fd;
+
+	fd = open("/dev/dri/renderD128", O_RDWR | O_CLOEXEC);
+	if (fd < 0)
+		die("open /dev/dri/renderD128");
+
+	handle = create_object(fd, OBJECT_SIZE);
+	mapping = map_object(fd, handle, OBJECT_SIZE, &mmap_offset);
+	fill_pattern(mapping, OBJECT_SIZE);
+	verify_pattern(mapping, OBJECT_SIZE);
+
+	if (exercise) {
+		exercise_transaction(fd, handle, mapping);
+		puts("PASS: i915 CRIU transaction and rollback");
+		return EXIT_SUCCESS;
+	}
+
+	if (sigaction(SIGUSR1, &action, NULL) < 0)
+		die("sigaction");
+	printf("READY pid=%d handle=%u address=%p mmap_offset=%#" PRIx64 "\n",
+	       getpid(), handle, mapping, mmap_offset);
+	fflush(stdout);
+	while (!resume_test)
+		pause();
+
+	verify_pattern(mapping, OBJECT_SIZE);
+	struct drm_i915_gem_set_domain domain = {
+		.handle = handle,
+		.read_domains = I915_GEM_DOMAIN_CPU,
+		.write_domain = I915_GEM_DOMAIN_CPU,
+	};
+	xioctl(fd, DRM_IOCTL_I915_GEM_SET_DOMAIN, &domain, "post-restore SET_DOMAIN");
+	exercise_gpu(fd, handle, mapping, OBJECT_SIZE);
+	puts("PASS: mapping address, contents, CPU access, and GPU execution");
+	return EXIT_SUCCESS;
+}
diff --git a/test/others/i915-criu/i915-gem-sharing.c b/test/others/i915-criu/i915-gem-sharing.c
new file mode 100644
index 000000000..dfd0160de
--- /dev/null
+++ b/test/others/i915-criu/i915-gem-sharing.c
@@ -0,0 +1,340 @@
+// SPDX-License-Identifier: GPL-2.0
+#define _GNU_SOURCE
+#include <errno.h>
+#include <fcntl.h>
+#include <inttypes.h>
+#include <signal.h>
+#include <stdbool.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/ioctl.h>
+#include <sys/mman.h>
+#include <sys/wait.h>
+#include <unistd.h>
+
+#include <drm/drm.h>
+#include <drm/i915_drm.h>
+
+#define OBJECT_SIZE (4 * 4096u)
+#define PATTERN_SEED UINT64_C(0x915c7100d15ea5e)
+#define CHILD_MUTATION UINT64_C(0xdab0f00d5a4ed001)
+
+static volatile sig_atomic_t resume_test;
+
+struct child_reply {
+	char state;
+	pid_t pid;
+};
+
+static void die(const char *what)
+{
+	perror(what);
+	exit(EXIT_FAILURE);
+}
+
+static void on_signal(int signo)
+{
+	(void)signo;
+	resume_test = 1;
+}
+
+static void xioctl(int fd, unsigned long request, void *arg, const char *what)
+{
+	if (ioctl(fd, request, arg) < 0)
+		die(what);
+}
+
+static void xread(int fd, void *data, size_t size, const char *what)
+{
+	char *cursor = data;
+
+	while (size) {
+		ssize_t got = read(fd, cursor, size);
+		if (got < 0 && errno == EINTR)
+			continue;
+		if (got <= 0)
+			die(what);
+		cursor += got;
+		size -= got;
+	}
+}
+
+static void xwrite(int fd, const void *data, size_t size, const char *what)
+{
+	const char *cursor = data;
+
+	while (size) {
+		ssize_t written = write(fd, cursor, size);
+		if (written < 0 && errno == EINTR)
+			continue;
+		if (written <= 0)
+			die(what);
+		cursor += written;
+		size -= written;
+	}
+}
+
+static uint64_t pattern_word(size_t index)
+{
+	uint64_t value = PATTERN_SEED ^ (uint64_t)index * UINT64_C(0x9e3779b97f4a7c15);
+	value ^= value >> 29;
+	value *= UINT64_C(0xbf58476d1ce4e5b9);
+	return value ^ (value >> 31);
+}
+
+static void fill_pattern(void *mapping)
+{
+	uint64_t *words = mapping;
+
+	for (size_t i = 0; i < OBJECT_SIZE / sizeof(*words); i++)
+		words[i] = pattern_word(i);
+}
+
+static void verify_pattern(const void *mapping)
+{
+	const uint64_t *words = mapping;
+
+	for (size_t i = 0; i < OBJECT_SIZE / sizeof(*words); i++) {
+		if (words[i] != pattern_word(i)) {
+			fprintf(stderr, "pattern mismatch at %zu\n", i);
+			exit(EXIT_FAILURE);
+		}
+	}
+}
+
+static void *map_object(int fd, uint32_t handle, uint64_t *offset_out)
+{
+	struct drm_i915_gem_mmap_offset request = {
+		.handle = handle,
+		.flags = I915_MMAP_OFFSET_WB,
+	};
+	void *mapping;
+
+	xioctl(fd, DRM_IOCTL_I915_GEM_MMAP_OFFSET, &request, "GEM_MMAP_OFFSET");
+	mapping = mmap(NULL, OBJECT_SIZE, PROT_READ | PROT_WRITE, MAP_SHARED,
+		       fd, request.offset);
+	if (mapping == MAP_FAILED)
+		die("mmap GEM object");
+	*offset_out = request.offset;
+	return mapping;
+}
+
+static void exercise_gpu(int fd, uint32_t handle, void *mapping)
+{
+	uint32_t *batch = (uint32_t *)((char *)mapping + OBJECT_SIZE - 8);
+	uint32_t saved[2] = { batch[0], batch[1] };
+	struct drm_i915_gem_exec_object2 object = { .handle = handle };
+	struct drm_i915_gem_execbuffer2 execbuf = {
+		.buffers_ptr = (uintptr_t)&object,
+		.buffer_count = 1,
+		.batch_start_offset = OBJECT_SIZE - 8,
+		.batch_len = 8,
+		.flags = I915_EXEC_RENDER,
+	};
+	struct drm_i915_gem_wait wait = { .bo_handle = handle, .timeout_ns = -1 };
+
+	batch[0] = 0x05000000;
+	batch[1] = 0;
+	xioctl(fd, DRM_IOCTL_I915_GEM_EXECBUFFER2, &execbuf, "post-restore EXECBUFFER2");
+	xioctl(fd, DRM_IOCTL_I915_GEM_WAIT, &wait, "post-restore GEM_WAIT");
+	batch[0] = saved[0];
+	batch[1] = saved[1];
+	verify_pattern(mapping);
+}
+
+static void child_process(int source_fd, int prime_fd, int command_fd, int reply_fd)
+{
+	struct drm_prime_handle import = { .fd = prime_fd };
+	uint64_t mmap_offset;
+	void *mapping;
+	char command;
+	struct child_reply reply;
+	int fd;
+
+	close(source_fd);
+	fd = open("/dev/dri/renderD128", O_RDWR | O_CLOEXEC);
+	if (fd < 0)
+		die("child open render node");
+	xioctl(fd, DRM_IOCTL_PRIME_FD_TO_HANDLE, &import, "PRIME_FD_TO_HANDLE");
+	close(prime_fd);
+	mapping = map_object(fd, import.handle, &mmap_offset);
+	verify_pattern(mapping);
+	printf("CHILD pid=%d handle=%u address=%p mmap_offset=%#" PRIx64 "\n",
+	       getpid(), import.handle, mapping, mmap_offset);
+	fflush(stdout);
+	reply = (struct child_reply) { .state = 'R', .pid = getpid() };
+	xwrite(reply_fd, &reply, sizeof(reply), "child ready reply");
+
+	xread(command_fd, &command, 1, "child restore command");
+	if (command != 'G') {
+		fprintf(stderr, "unexpected child command\n");
+		exit(EXIT_FAILURE);
+	}
+	verify_pattern(mapping);
+	((uint64_t *)mapping)[0] = CHILD_MUTATION;
+	reply.state = 'P';
+	xwrite(reply_fd, &reply, sizeof(reply), "child pass reply");
+	_exit(EXIT_SUCCESS);
+}
+
+int main(int argc, char **argv)
+{
+	bool external_peer = argc == 2 && !strcmp(argv[1], "--external-peer");
+	bool retained_dmabuf = argc == 2 && !strcmp(argv[1], "--retained-dmabuf");
+	bool external_dmabuf = argc == 2 &&
+		!strcmp(argv[1], "--external-dmabuf-peer");
+	struct sigaction action = { .sa_handler = on_signal };
+	struct drm_i915_gem_create create = { .size = OBJECT_SIZE };
+	struct drm_prime_handle export = { .flags = DRM_CLOEXEC | DRM_RDWR };
+	int command_pipe[2];
+	int reply_pipe[2];
+	int external_pipe[2] = { -1, -1 };
+	uint64_t mmap_offset;
+	void *mapping;
+	struct child_reply reply;
+	pid_t child;
+	pid_t peer;
+	pid_t external_dmabuf_pid = 0;
+	int fd;
+	int retained_dup = -1;
+	int status;
+
+	if (argc > 2 || (argc == 2 && !external_peer && !retained_dmabuf &&
+				 !external_dmabuf)) {
+		fprintf(stderr, "usage: %s [--external-peer|--retained-dmabuf|--external-dmabuf-peer]\n",
+			argv[0]);
+		return EXIT_FAILURE;
+	}
+	fd = open("/dev/dri/renderD128", O_RDWR | O_CLOEXEC);
+	if (fd < 0)
+		die("open render node");
+	xioctl(fd, DRM_IOCTL_I915_GEM_CREATE, &create, "GEM_CREATE");
+	mapping = map_object(fd, create.handle, &mmap_offset);
+	fill_pattern(mapping);
+	export.handle = create.handle;
+	xioctl(fd, DRM_IOCTL_PRIME_HANDLE_TO_FD, &export, "PRIME_HANDLE_TO_FD");
+	if (pipe2(command_pipe, O_CLOEXEC) || pipe2(reply_pipe, O_CLOEXEC) ||
+	    (external_dmabuf && pipe2(external_pipe, O_CLOEXEC)))
+		die("pipe2");
+	if (external_dmabuf) {
+		pid_t intermediary = fork();
+
+		if (intermediary < 0)
+			die("external dma-buf fork");
+		if (!intermediary) {
+			pid_t grandchild;
+
+			close(external_pipe[0]);
+			grandchild = fork();
+			if (grandchild < 0)
+				die("external dma-buf grandchild fork");
+			if (grandchild)
+				_exit(EXIT_SUCCESS);
+			close(fd);
+			close(command_pipe[0]);
+			close(command_pipe[1]);
+			close(reply_pipe[0]);
+			close(reply_pipe[1]);
+			external_dmabuf_pid = getpid();
+			xwrite(external_pipe[1], &external_dmabuf_pid,
+			       sizeof(external_dmabuf_pid),
+			       "external dma-buf ready");
+			for (;;)
+				pause();
+		}
+		close(external_pipe[1]);
+		xread(external_pipe[0], &external_dmabuf_pid,
+		      sizeof(external_dmabuf_pid), "external dma-buf pid");
+		close(external_pipe[0]);
+		if (waitpid(intermediary, &status, 0) != intermediary ||
+		    !WIFEXITED(status) || WEXITSTATUS(status)) {
+			fprintf(stderr, "external dma-buf intermediary failed\n");
+			return EXIT_FAILURE;
+		}
+	}
+
+	child = fork();
+	if (child < 0)
+		die("fork");
+	if (!child) {
+		close(command_pipe[1]);
+		close(reply_pipe[0]);
+		if (external_peer) {
+			pid_t grandchild = fork();
+
+			if (grandchild < 0)
+				die("external peer fork");
+			if (grandchild)
+				_exit(EXIT_SUCCESS);
+		}
+		child_process(fd, export.fd, command_pipe[0], reply_pipe[1]);
+	}
+	close(command_pipe[0]);
+	close(reply_pipe[1]);
+	if (retained_dmabuf) {
+		retained_dup = dup(export.fd);
+		if (retained_dup < 0)
+			die("dup retained dma-buf");
+	}
+	if (!retained_dmabuf)
+		close(export.fd);
+	xread(reply_pipe[0], &reply, sizeof(reply), "parent ready reply");
+	if (reply.state != 'R') {
+		fprintf(stderr, "child did not become ready\n");
+		return EXIT_FAILURE;
+	}
+	peer = reply.pid;
+	if (external_peer &&
+	    (waitpid(child, &status, 0) != child || !WIFEXITED(status) ||
+	     WEXITSTATUS(status))) {
+		fprintf(stderr, "external peer intermediary failed\n");
+		return EXIT_FAILURE;
+	}
+
+	if (sigaction(SIGUSR1, &action, NULL) < 0)
+		die("sigaction");
+	printf("READY parent=%d child=%d external=%d retained_dmabuf=%d external_dmabuf=%d handle=%u address=%p mmap_offset=%#" PRIx64 "\n",
+	       getpid(), peer, external_peer, retained_dmabuf,
+	       external_dmabuf_pid, create.handle, mapping, mmap_offset);
+	fflush(stdout);
+	while (!resume_test)
+		pause();
+
+	verify_pattern(mapping);
+	if (retained_dmabuf) {
+		int retained_fds[] = { export.fd, retained_dup };
+
+		for (size_t i = 0; i < sizeof(retained_fds) / sizeof(retained_fds[0]);
+		     i++) {
+			struct drm_prime_handle import = { .fd = retained_fds[i] };
+
+			if (fcntl(retained_fds[i], F_GETFD) < 0)
+				die("retained dma-buf fd");
+			xioctl(fd, DRM_IOCTL_PRIME_FD_TO_HANDLE, &import,
+			       "retained PRIME_FD_TO_HANDLE");
+			if (import.handle != create.handle) {
+				errno = EXDEV;
+				die("retained dma-buf object identity");
+			}
+		}
+	}
+	reply.state = 'G';
+	xwrite(command_pipe[1], &reply.state, 1, "parent restore command");
+	xread(reply_pipe[0], &reply, sizeof(reply), "parent pass reply");
+	if (reply.state != 'P' || ((uint64_t *)mapping)[0] != CHILD_MUTATION) {
+		fprintf(stderr, "restored dma-buf identity was not shared\n");
+		return EXIT_FAILURE;
+	}
+	((uint64_t *)mapping)[0] = pattern_word(0);
+	exercise_gpu(fd, create.handle, mapping);
+	if (!external_peer &&
+	    (waitpid(child, &status, 0) != child || !WIFEXITED(status) ||
+	     WEXITSTATUS(status))) {
+		fprintf(stderr, "child failed after restore\n");
+		return EXIT_FAILURE;
+	}
+	puts("PASS: two-process dma-buf identity, mappings, CPU sharing, and GPU execution");
+	return EXIT_SUCCESS;
+}
diff --git a/test/others/i915-criu/run-context-sync-criu.sh b/test/others/i915-criu/run-context-sync-criu.sh
new file mode 100755
index 000000000..8c3d6902f
--- /dev/null
+++ b/test/others/i915-criu/run-context-sync-criu.sh
@@ -0,0 +1,104 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+if (( EUID != 0 )); then
+    echo "run as root: sudo $0" >&2
+    exit 2
+fi
+
+repo=$(cd "$(dirname "$0")/../../.." && pwd)
+work=${I915_CRIU_TEST_DIR:-/tmp/i915-criu-context-sync}
+criu=${CRIU:-/run/current-system/sw/bin/criu}
+plugin_dir=${CRIU_PLUGIN_DIR:-}
+plugin_args=()
+[[ -n $plugin_dir ]] && plugin_args+=(--libdir "$plugin_dir")
+expect_unsupported=${I915_CRIU_EXPECT_UNSUPPORTED:-1}
+sync_only=${I915_CRIU_SYNC_ONLY:-0}
+idle_context=${I915_CRIU_IDLE_CONTEXT:-0}
+callback=${I915_CRIU_CALLBACK:-0}
+custom_engine=${I915_CRIU_CUSTOM_ENGINE:-0}
+cc=${CC:-gcc}
+fixture="$work/i915-context-sync"
+fixture_source=${FIXTURE:-/tmp/i915-context-sync}
+images="$work/images"
+log="$work/fixture.log"
+
+cleanup() {
+    if [[ -n ${fixture_pid:-} ]]; then
+        kill -KILL "$fixture_pid" 2>/dev/null || true
+    fi
+}
+trap cleanup EXIT
+rm -rf "$work"
+mkdir -p "$images"
+
+if [[ -x $fixture_source ]]; then
+    cp "$fixture_source" "$fixture"
+elif command -v "$cc" >/dev/null; then
+    "$cc" -std=c11 -Wall -Wextra -Werror -I"$repo" \
+        "$repo/test/others/i915-criu/i915-context-sync.c" -o "$fixture"
+else
+    echo "no prebuilt fixture at $fixture_source and compiler $cc is unavailable" >&2
+    exit 2
+fi
+
+fixture_args=()
+expected_pass='PASS: materialized context, explicit VM, exact GPU address, binary syncobj, timeline, and GPU submission'
+if (( sync_only + idle_context + callback + custom_engine > 1 )); then
+    echo 'sync-only, idle-context, callback, and custom-engine modes are mutually exclusive' >&2
+    exit 2
+elif [[ $callback == 1 ]]; then
+    fixture_args+=(--callback)
+elif [[ $custom_engine == 1 ]]; then
+    fixture_args+=(--custom-engine)
+elif [[ $sync_only == 1 ]]; then
+    fixture_args+=(--sync-only)
+    expected_pass='PASS: binary syncobj, timeline, and GPU submission'
+elif [[ $idle_context == 1 ]]; then
+    fixture_args+=(--idle-context)
+    expected_pass='PASS: idle context, explicit VM, binary syncobj, timeline, and GPU submission'
+fi
+"$fixture" "${fixture_args[@]}" >"$log" 2>&1 &
+fixture_pid=$!
+for _ in $(seq 1 100); do
+    grep -q '^READY ' "$log" && break
+    kill -0 "$fixture_pid"
+    sleep 0.05
+done
+grep -q '^READY ' "$log"
+original_pid=$fixture_pid
+original_address=$(sed -n 's/^READY .* address=\([^ ]*\).*/\1/p' "$log")
+
+if [[ $expect_unsupported == 1 ]]; then
+    set +e
+    "$criu" dump -t "$original_pid" -D "$images" --shell-job \
+        "${plugin_args[@]}" --log-file dump.log -v4
+    dump_status=$?
+    set -e
+    if (( dump_status == 0 || dump_status >= 128 )); then
+        echo "context/sync dump did not fail safely: status=$dump_status" >&2
+        exit 1
+    fi
+    grep -q 'Dumping FAILED' "$images/dump.log"
+    printf 'PASS: unsupported context/VM/syncobj state refused without a CRIU crash (status=%s)\n' \
+        "$dump_status"
+    exit 0
+fi
+
+"$criu" dump -t "$original_pid" -D "$images" --shell-job \
+    "${plugin_args[@]}" --log-file dump.log -v4
+wait "$fixture_pid" 2>/dev/null || true
+fixture_pid=
+"$criu" restore -D "$images" --shell-job --restore-detached \
+    "${plugin_args[@]}" --log-file restore.log -v4
+fixture_pid=$original_pid
+kill -USR1 "$fixture_pid"
+for _ in $(seq 1 100); do
+    grep -Fqx "$expected_pass" "$log" && break
+    kill -0 "$fixture_pid" 2>/dev/null || true
+    sleep 0.05
+done
+grep -Fqx "$expected_pass" "$log"
+fixture_pid=
+printf 'PASS: CRIU restored context/sync pid=%s address=%s\n' \
+    "$original_pid" "$original_address"
