++destroy_context:
++		destroy = (struct drm_i915_gem_context_destroy){
++			.ctx_id = create.ctx_id,
++		};
++		i915_gem_context_destroy_ioctl(dev, &destroy, file);
++	} else {
++		ret = -EINVAL;
++	}
++out:
++	mutex_unlock(&fpriv->criu_lock);
++	return ret;
++}
