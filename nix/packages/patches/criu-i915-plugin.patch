++			obj->base.dma_buf || user_handles > 1 ?
++				I915_CRIU_OBJECT_SHARED :
++				0;
++put_obj:
++		i915_gem_object_put(obj);
++	} else if (args->op == I915_CRIU_OBJECT_CREATE ||
++		   args->op == I915_CRIU_OBJECT_IMPORT) {
++		struct drm_i915_gem_create create = { .size = args->size };
++		u32 handle = args->handle;
++		void *old;
++
++		ret = check_session(fpriv, args->cookie,
++				    I915_CRIU_MODE_RESTORE);
++		if (ret)
++			goto out;
++		if (args->flags != I915_CRIU_OBJECT_SHMEM || !args->object_id ||
++		    !args->size || !args->handle_count ||
++		    args->sharing_flags & ~I915_CRIU_OBJECT_SHARED) {
++			ret = -EINVAL;
++			goto out;
++		}
++
++		if (args->op == I915_CRIU_OBJECT_CREATE) {
++			ret = i915_gem_create_ioctl(dev, &create, file);
++			if (ret)
++				goto out;
++			handle = create.handle;
++		} else if (!handle) {
++			ret = -EINVAL;
++			goto out;
++		}
