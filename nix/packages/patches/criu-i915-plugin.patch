index 0000000000000000000000000000000000000000..e7f8a039148f9d756327c7841f585a4650b749bb
--- /dev/null
+++ b/test/others/input-criu/input-criu-state.c
@@ -0,0 +1,184 @@
+// SPDX-License-Identifier: GPL-2.0
+#include <errno.h>
+#include <fcntl.h>
+#include <linux/input.h>
+#include <linux/uinput.h>
+#include <poll.h>
+#include <stdbool.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/ioctl.h>
+#include <time.h>
+#include <unistd.h>
+
+#include "../../../contrib/input-criu/input_criu_uapi.h"
+
+#define FIXTURE_NAME "criu-evdev-state-fixture"
+
+static void fail(const char *what)
+{
+	perror(what);
+	exit(EXIT_FAILURE);
+}
+
+static void query_state(int fd, struct input_criu_state *state)
+{
+	memset(state, 0, sizeof(*state));
+	state->version = EVDEV_CRIU_STATE_VERSION;
+	state->size = sizeof(*state);
+	if (ioctl(fd, EVIOCGCRIUSTATE, state) < 0)
+		fail("EVIOCGCRIUSTATE");
+}
+
+static int find_fixture(void)
+{
+	char path[64];
+	char name[256];
+	int attempt;
+	int event;
+
+	for (attempt = 0; attempt < 100; attempt++) {
+		for (event = 0; event < 32; event++) {
+			int fd;
+
+			snprintf(path, sizeof(path), "/dev/input/event%d", event);
+			fd = open(path, O_RDONLY | O_NONBLOCK | O_CLOEXEC);
+			if (fd < 0)
+				continue;
+			memset(name, 0, sizeof(name));
+			if (ioctl(fd, EVIOCGNAME(sizeof(name)), name) >= 0 &&
+			    !strcmp(name, FIXTURE_NAME))
+				return fd;
+			close(fd);
+		}
+		usleep(10000);
+	}
+	errno = ENODEV;
+	return -1;
+}
+
+static void inject(int uinput_fd, uint16_t type, uint16_t code, int32_t value)
+{
+	struct input_event event = {
+		.type = type,
+		.code = code,
+		.value = value,
+	};
+
+	if (write(uinput_fd, &event, sizeof(event)) != sizeof(event))
+		fail("write uinput event");
+}
+
+int main(void)
+{
+	struct uinput_setup setup = {
+		.id = {
+			.bustype = BUS_VIRTUAL,
+			.vendor = 0x1d6b,
+			.product = 0x4352,
+			.version = 1,
+		},
+	};
+	struct input_criu_state state;
+	struct input_event events[8];
+	struct input_mask mask;
+	uint8_t key_mask[(KEY_MAX + 8) / 8];
+	int clock_id = CLOCK_MONOTONIC;
+	int one = 1;
+	int zero = 0;
+	int event_fd;
+	int uinput_fd;
+	int attempt;
+
+	uinput_fd = open("/dev/uinput", O_WRONLY | O_NONBLOCK | O_CLOEXEC);
+	if (uinput_fd < 0)
+		fail("open /dev/uinput");
+	if (ioctl(uinput_fd, UI_SET_EVBIT, EV_KEY) < 0 ||
+	    ioctl(uinput_fd, UI_SET_KEYBIT, KEY_A) < 0 ||
+	    ioctl(uinput_fd, UI_SET_EVBIT, EV_SYN) < 0)
+		fail("configure uinput");
+	strcpy(setup.name, FIXTURE_NAME);
+	if (ioctl(uinput_fd, UI_DEV_SETUP, &setup) < 0 ||
+	    ioctl(uinput_fd, UI_DEV_CREATE) < 0)
+		fail("create uinput");
+	event_fd = find_fixture();
+	if (event_fd < 0)
+		fail("find fixture event node");
+
+	query_state(event_fd, &state);
+	if (state.flags || state.queued_events)
+		return EXIT_FAILURE;
+
+	memset(&state, 0, sizeof(state));
+	state.version = EVDEV_CRIU_STATE_VERSION + 1;
+	state.size = sizeof(state);
+	errno = 0;
+	if (ioctl(event_fd, EVIOCGCRIUSTATE, &state) == 0 || errno != EINVAL)
+		return EXIT_FAILURE;
+	memset(&state, 0, sizeof(state));
+	state.version = EVDEV_CRIU_STATE_VERSION;
+	state.size = sizeof(state) - 1;
+	errno = 0;
+	if (ioctl(event_fd, EVIOCGCRIUSTATE, &state) == 0 || errno != EINVAL)
+		return EXIT_FAILURE;
+	memset(&state, 0, sizeof(state));
+	state.version = EVDEV_CRIU_STATE_VERSION;
+	state.size = sizeof(state);
+	state.reserved[0] = 1;
+	errno = 0;
+	if (ioctl(event_fd, EVIOCGCRIUSTATE, &state) == 0 || errno != EINVAL)
+		return EXIT_FAILURE;
+
+	inject(uinput_fd, EV_KEY, KEY_A, 1);
+	inject(uinput_fd, EV_SYN, SYN_REPORT, 0);
+	for (attempt = 0; attempt < 100; attempt++) {
+		query_state(event_fd, &state);
+		if (state.flags & EVDEV_CRIU_STATE_QUEUE_NONEMPTY)
+			break;
+		usleep(1000);
+	}
+	if (!(state.flags & EVDEV_CRIU_STATE_QUEUE_NONEMPTY) ||
+	    state.queued_events < 2)
+		return EXIT_FAILURE;
+	if (read(event_fd, events, sizeof(events)) < 0)
+		fail("drain events");
+	query_state(event_fd, &state);
+	if (state.flags & EVDEV_CRIU_STATE_QUEUE_NONEMPTY)
+		return EXIT_FAILURE;
+
+	memset(key_mask, 0xff, sizeof(key_mask));
+	mask.type = EV_KEY;
+	mask.codes_size = sizeof(key_mask);
+	mask.codes_ptr = (uintptr_t)key_mask;
+	if (ioctl(event_fd, EVIOCSMASK, &mask) < 0)
+		fail("EVIOCSMASK");
+	query_state(event_fd, &state);
+	if (!(state.flags & EVDEV_CRIU_STATE_FILTERED))
+		return EXIT_FAILURE;
+	close(event_fd);
+	event_fd = find_fixture();
+	if (event_fd < 0)
+		fail("reopen fixture event node");
+
+	if (ioctl(event_fd, EVIOCGRAB, one) < 0)
+		fail("EVIOCGRAB");
+	query_state(event_fd, &state);
+	if (!(state.flags & EVDEV_CRIU_STATE_GRABBED))
+		return EXIT_FAILURE;
+	if (ioctl(event_fd, EVIOCGRAB, zero) < 0)
+		fail("EVIOCGRAB release");
+	if (ioctl(event_fd, EVIOCSCLOCKID, &clock_id) < 0)
+		fail("EVIOCSCLOCKID");
+	query_state(event_fd, &state);
+	if (state.flags || state.clock_id != CLOCK_MONOTONIC)
+		return EXIT_FAILURE;
+
+	printf("evdev CRIU state ABI %u passed\n", state.version);
+	close(event_fd);
+	if (ioctl(uinput_fd, UI_DEV_DESTROY) < 0)
+		fail("destroy uinput");
+	close(uinput_fd);
+	return EXIT_SUCCESS;
+}
