+#include "../../contrib/i915-criu/i915_criu_uapi.h"
+
+#define I915_IMAGE_MAGIC UINT64_C(0x4939313543524955)
+#define I915_IMAGE_VERSION 1
+#define I915_MAX_RESTORE_OBJECTS 256
+#define I915_MAX_RESTORE_FILES 32
+#define I915_MAX_OBJECT_SIZE (UINT64_C(1) << 30)
+
+struct i915_image_header {
+	uint64_t magic;
+	uint32_t version;
+	uint32_t file_id;
+	uint32_t object_count;
+	uint32_t reserved;
+};
+
+struct i915_image_object {
+	uint64_t object_id;
+	uint64_t size;
+	uint64_t mmap_offset;
+	uint32_t mmap_type;
+	uint32_t flags;
+};
+
+struct dump_object {
+	struct i915_image_object image;
+	void *data;
+};
+
+struct restore_object {
+	uint64_t object_id;
+	uint64_t old_mmap_offset;
+	uint64_t new_mmap_offset;
+	uint64_t size;
+	int fd;
+};
+
+struct restore_file {
+	int fd;
+	uint64_t cookie;
+	bool active;
+};
+
+static int checkpoint_pid = -1;
+static bool inventory_added;
+static struct restore_object restore_objects[I915_MAX_RESTORE_OBJECTS];
+static size_t restore_object_count;
+static struct restore_file restore_files[I915_MAX_RESTORE_FILES];
+static size_t restore_file_count;
+
+static const char *render_node(void)
+{
+	const char *configured = getenv("I915_CRIU_DRM_DEVICE");
+
+	return configured && configured[0] ? configured : "/dev/dri/renderD128";
+}
+
+static bool is_i915_fd(int fd)
+{
+	drmVersionPtr version = drmGetVersion(fd);
+	bool match = version && version->name && !strcmp(version->name, "i915");
+
+	if (version)
+		drmFreeVersion(version);
+	return match;
+}
+
+static int image_fd(int file_id, int flags)
+{
+	char name[64];
+
+	snprintf(name, sizeof(name), "i915-criu-%d.img", file_id);
+	return openat(criu_get_image_dir(), name, flags, 0600);
+}
+
+static int write_all(int fd, const void *data, size_t size)
+{
+	const char *cursor = data;
+
+	while (size) {
+		ssize_t written = write(fd, cursor, size);
+		if (written < 0) {
+			if (errno == EINTR)
+				continue;
+			return -errno;
+		}
+		cursor += written;
+		size -= written;
+	}
+	return 0;
+}
+
+static int read_all(int fd, void *data, size_t size)
+{
+	char *cursor = data;
+
+	while (size) {
+		ssize_t got = read(fd, cursor, size);
+		if (got == 0)
+			return -EIO;
+		if (got < 0) {
+			if (errno == EINTR)
+				continue;
+			return -errno;
+		}
+		cursor += got;
+		size -= got;
+	}
+	return 0;
+}
+
+static int session_ioctl(int fd, uint32_t op, int pid, uint64_t *cookie)
+{
+	struct drm_i915_criu_session session = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = op,
+		.target_pid = pid,
+		.cookie = *cookie,
+	};
+
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_SESSION, &session) < 0)
+		return -errno;
+	*cookie = session.cookie;
+	return 0;
+}
+
+static void free_dump_objects(struct dump_object *objects, size_t count)
+{
+	for (size_t i = 0; i < count; i++)
+		xfree(objects[i].data);
+	xfree(objects);
+}
+
+static int collect_dump_objects(int fd, uint64_t cookie,
+				struct dump_object **result, size_t *result_count)
+{
+	struct dump_object *objects = NULL;
+	size_t count = 0;
+	uint32_t cursor = 0;
+	int ret = 0;
+
+	for (;;) {
+		struct drm_i915_criu_object query = {
+			.version = I915_CRIU_ABI_VERSION,
+			.op = I915_CRIU_OBJECT_QUERY,
+			.cookie = cookie,
+			.handle = cursor,
+		};
+		struct drm_i915_criu_data read_data;
+		struct dump_object *grown;
+
+		if (ioctl(fd, DRM_IOCTL_I915_CRIU_OBJECT, &query) < 0) {
+			if (errno == ENOENT)
+				break;
+			ret = -errno;
+			goto err;
+		}
+		if (count == I915_MAX_RESTORE_OBJECTS) {
+			ret = -E2BIG;
+			goto err;
+		}
+
+		grown = xrealloc(objects, (count + 1) * sizeof(*objects));
+		if (!grown) {
+			free_dump_objects(objects, count);
+			return -ENOMEM;
+		}
+		objects = grown;
+		memset(&objects[count], 0, sizeof(objects[count]));
+		objects[count].image.object_id = query.object_id;
+		objects[count].image.size = query.size;
+		objects[count].image.mmap_offset = query.mmap_offset;
+		objects[count].image.mmap_type = query.mmap_type;
+		objects[count].image.flags = query.flags;
+		objects[count].data = xmalloc(query.size);
+		if (!objects[count].data) {
+			ret = -ENOMEM;
+			goto err;
+		}
+
+		read_data = (struct drm_i915_criu_data) {
+			.version = I915_CRIU_ABI_VERSION,
+			.op = I915_CRIU_DATA_READ,
+			.cookie = cookie,
+			.handle = query.handle,
+			.size = query.size,
+			.data_ptr = (uintptr_t)objects[count].data,
+		};
+		if (ioctl(fd, DRM_IOCTL_I915_CRIU_DATA, &read_data) < 0) {
+			ret = -errno;
+			goto err;
+		}
+		cursor = query.handle;
+		count++;
+	}
+
+	*result = objects;
+	*result_count = count;
+	return 0;
+err:
+	free_dump_objects(objects, count + 1);
+	return ret;
+}
+
+static int write_image(int file_id, struct dump_object *objects, size_t count)
+{
+	struct i915_image_header header = {
+		.magic = I915_IMAGE_MAGIC,
+		.version = I915_IMAGE_VERSION,
+		.file_id = file_id,
+		.object_count = count,
+	};
+	int fd = image_fd(file_id, O_WRONLY | O_CREAT | O_EXCL);
+	int ret;
+
+	if (fd < 0)
+		return -errno;
+	ret = write_all(fd, &header, sizeof(header));
+	for (size_t i = 0; !ret && i < count; i++) {
+		ret = write_all(fd, &objects[i].image, sizeof(objects[i].image));
+		if (!ret)
+			ret = write_all(fd, objects[i].data, objects[i].image.size);
+	}
+	if (close(fd) && !ret)
+		ret = -errno;
+	return ret;
+}
+
+static int i915_plugin_init(int stage)
+{
+	if (stage == CR_PLUGIN_STAGE__RESTORE &&
+	    !check_and_remove_inventory_plugin(CR_PLUGIN_DESC.name,
+				       strlen(CR_PLUGIN_DESC.name)))
+		return 0;
+
+	checkpoint_pid = -1;
+	inventory_added = false;
+	restore_object_count = 0;
+	restore_file_count = 0;
+	return 0;
+}
+
+static void abort_restore_sessions(void)
+{
+	for (size_t i = 0; i < restore_file_count; i++) {
+		if (!restore_files[i].active)
+			continue;
+		if (session_ioctl(restore_files[i].fd, I915_CRIU_SESSION_ABORT, 0,
+				  &restore_files[i].cookie))
+			pr_err("failed to abort i915 restore transaction\n");
+		restore_files[i].active = false;
+	}
+}
+
+static void i915_plugin_fini(int stage, int ret)
+{
+	if (stage == CR_PLUGIN_STAGE__RESTORE && ret)
+		abort_restore_sessions();
+}
+
+CR_PLUGIN_REGISTER("i915_plugin", i915_plugin_init, i915_plugin_fini)
+
+int i915_plugin_pause_devices(int pid)
+{
+	checkpoint_pid = pid;
+	return 0;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__PAUSE_DEVICES, i915_plugin_pause_devices)
+
+int i915_plugin_handle_anon_device_vma(const char *name, int pid,
+				       uint64_t start, uint64_t pgoff,
+				       int *surrogate_fd)
+{
+	int fd;
+
+	(void)pid;
+	(void)start;
+	(void)pgoff;
+	if (strcmp(name, "anon_inode:i915.gem"))
+		return 0;
+	fd = open(render_node(), O_RDWR | O_CLOEXEC);
+	if (fd < 0)
+		return -errno;
+	if (!is_i915_fd(fd)) {
+		close(fd);
+		return -ENODEV;
+	}
+	*surrogate_fd = fd;
+	return 1;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__HANDLE_ANON_DEVICE_VMA,
+			 i915_plugin_handle_anon_device_vma)
+
+int i915_plugin_handle_device_vma(int fd, const struct stat *st)
+{
+	(void)st;
+	if (!is_i915_fd(fd))
+		return -ENOTSUP;
+	if (!inventory_added) {
+		int ret = add_inventory_plugin(CR_PLUGIN_DESC.name);
+		if (ret)
+			return ret;
+		inventory_added = true;
+	}
+	return 0;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__HANDLE_DEVICE_VMA,
+			 i915_plugin_handle_device_vma)
+
+int i915_plugin_dump_file(int fd, int id)
+{
+	struct dump_object *objects = NULL;
+	size_t count = 0;
+	uint64_t cookie = 0;
+	int ret;
+
+	if (!is_i915_fd(fd))
+		return -ENOTSUP;
+	if (checkpoint_pid <= 0)
+		return -EINVAL;
+
+	ret = session_ioctl(fd, I915_CRIU_SESSION_DUMP_BEGIN,
+			    checkpoint_pid, &cookie);
+	if (ret)
+		return ret;
+	ret = collect_dump_objects(fd, cookie, &objects, &count);
+	if (!ret)
+		ret = write_image(id, objects, count);
+	if (session_ioctl(fd, ret ? I915_CRIU_SESSION_ABORT :
+				       I915_CRIU_SESSION_COMMIT,
+			  0, &cookie) && !ret)
+		ret = -EIO;
+	free_dump_objects(objects, count);
+	return ret;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__DUMP_EXT_FILE, i915_plugin_dump_file)
+
+static int validate_image_object(const struct i915_image_object *image)
+{
+	if (!image->object_id || !image->size ||
+	    image->size > I915_MAX_OBJECT_SIZE ||
+	    image->flags != I915_CRIU_OBJECT_SHMEM ||
+	    image->mmap_type != I915_MMAP_OFFSET_WB ||
+	    !image->mmap_offset)
+		return -EINVAL;
+
+	for (size_t i = 0; i < restore_object_count; i++) {
+		if (restore_objects[i].object_id == image->object_id ||
+		    restore_objects[i].old_mmap_offset == image->mmap_offset)
+			return -EEXIST;
+	}
+	return 0;
+}
+
+static int restore_object(int fd, uint64_t cookie,
+			  const struct i915_image_object *image,
+			  const void *contents)
+{
+	struct drm_i915_criu_object create = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_OBJECT_CREATE,
+		.cookie = cookie,
+		.flags = image->flags,
+		.object_id = image->object_id,
+		.size = image->size,
+	};
+	struct drm_i915_criu_data write_data;
+	struct drm_i915_gem_mmap_offset mmap_offset;
+
+	if (restore_object_count == I915_MAX_RESTORE_OBJECTS)
+		return -E2BIG;
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_OBJECT, &create) < 0)
+		return -errno;
+
+	write_data = (struct drm_i915_criu_data) {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_DATA_WRITE,
+		.cookie = cookie,
+		.handle = create.handle,
+		.size = image->size,
+		.data_ptr = (uintptr_t)contents,
+	};
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_DATA, &write_data) < 0)
+		return -errno;
+
+	mmap_offset = (struct drm_i915_gem_mmap_offset) {
+		.handle = create.handle,
+		.flags = image->mmap_type,
+	};
+	if (ioctl(fd, DRM_IOCTL_I915_GEM_MMAP_OFFSET, &mmap_offset) < 0)
+		return -errno;
+
+	restore_objects[restore_object_count++] = (struct restore_object) {
+		.object_id = image->object_id,
+		.old_mmap_offset = image->mmap_offset,
+		.new_mmap_offset = mmap_offset.offset,
+		.size = image->size,
+		.fd = fd,
+	};
+	return 0;
+}
+
+int i915_plugin_restore_file(int id)
+{
+	struct i915_image_header header;
+	struct restore_file *restore_file;
+	uint64_t cookie = 0;
+	int image;
+	int fd;
+	int ret;
+
+	image = image_fd(id, O_RDONLY);
+	if (image < 0)
+		return -ENOTSUP;
+	ret = read_all(image, &header, sizeof(header));
+	if (ret || header.magic != I915_IMAGE_MAGIC ||
+	    header.version != I915_IMAGE_VERSION || header.file_id != (uint32_t)id ||
+	    header.reserved || header.object_count > I915_MAX_RESTORE_OBJECTS) {
+		close(image);
+		return ret ? ret : -EINVAL;
+	}
+
+	fd = open(render_node(), O_RDWR | O_CLOEXEC);
+	if (fd < 0) {
+		close(image);
+		return -errno;
+	}
+	if (!header.object_count) {
+		close(image);
+		return fd;
+	}
+	if (restore_file_count == I915_MAX_RESTORE_FILES) {
+		close(image);
+		close(fd);
+		return -E2BIG;
+	}
+
+	ret = session_ioctl(fd, I915_CRIU_SESSION_RESTORE_BEGIN, 0, &cookie);
+	if (ret) {
+		close(image);
+		close(fd);
+		return ret;
+	}
+	restore_file = &restore_files[restore_file_count++];
+	*restore_file = (struct restore_file) {
+		.fd = fd,
+		.cookie = cookie,
+		.active = true,
+	};
+
+	for (uint32_t i = 0; i < header.object_count; i++) {
+		struct i915_image_object object;
+		void *contents;
+
+		ret = read_all(image, &object, sizeof(object));
+		if (ret)
+			break;
+		ret = validate_image_object(&object);
+		if (ret)
+			break;
+		contents = xmalloc(object.size);
+		if (!contents) {
+			ret = -ENOMEM;
+			break;
+		}
+		ret = read_all(image, contents, object.size);
+		if (!ret)
+			ret = restore_object(fd, cookie, &object, contents);
+		xfree(contents);
+		if (ret)
+			break;
+	}
+	if (!ret) {
+		char trailing;
+		ssize_t got;
+
+		do {
+			got = read(image, &trailing, sizeof(trailing));
+		} while (got < 0 && errno == EINTR);
+		if (got != 0)
+			ret = got < 0 ? -errno : -EINVAL;
+	}
+	close(image);
+	if (ret) {
+		abort_restore_sessions();
+		close(fd);
+		return ret;
+	}
+
+	ret = dup(fd);
+	if (ret < 0) {
+		ret = -errno;
+		abort_restore_sessions();
+		close(fd);
+		return ret;
+	}
+	return ret;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__RESTORE_EXT_FILE,
+			 i915_plugin_restore_file)
+
+int i915_plugin_update_vma_map(const char *path, uint64_t addr,
+			       uint64_t old_pgoff, uint64_t *new_pgoff,
+			       int *plugin_fd)
+{
+	(void)path;
+	(void)addr;
+	for (size_t i = 0; i < restore_object_count; i++) {
+		if (restore_objects[i].old_mmap_offset != old_pgoff)
+			continue;
+		*new_pgoff = restore_objects[i].new_mmap_offset;
+		*plugin_fd = restore_objects[i].fd;
+		return 1;
+	}
+	return 0;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__UPDATE_VMA_MAP,
+			 i915_plugin_update_vma_map)
+
+int i915_plugin_resume_devices_late(int pid)
+{
+	(void)pid;
+	for (size_t i = 0; i < restore_file_count; i++) {
+		int ret;
+
+		if (!restore_files[i].active)
+			continue;
+		ret = session_ioctl(restore_files[i].fd, I915_CRIU_SESSION_COMMIT,
+				    0, &restore_files[i].cookie);
+		if (ret)
+			return ret;
+		restore_files[i].active = false;
+	}
+	return 0;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__RESUME_DEVICES_LATE,
+			 i915_plugin_resume_devices_late)
diff --git a/test/others/i915-criu/i915-gem-minimal.c b/test/others/i915-criu/i915-gem-minimal.c
new file mode 100644
index 000000000..f770602df
--- /dev/null
+++ b/test/others/i915-criu/i915-gem-minimal.c
@@ -0,0 +1,247 @@
+// SPDX-License-Identifier: GPL-2.0
+#define _GNU_SOURCE
+#include <errno.h>
+#include <fcntl.h>
+#include <inttypes.h>
+#include <signal.h>
+#include <stdbool.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/ioctl.h>
+#include <sys/mman.h>
+#include <unistd.h>
+
+#include <drm/i915_drm.h>
+#include "../../../contrib/i915-criu/i915_criu_uapi.h"
+
+#define OBJECT_SIZE (4 * 4096u)
+#define PATTERN_SEED UINT64_C(0x915c7100d15ea5e)
+
+static volatile sig_atomic_t resume_test;
+
+static void on_signal(int signo)
+{
+	(void)signo;
+	resume_test = 1;
+}
+
+static void die(const char *what)
+{
+	perror(what);
+	exit(EXIT_FAILURE);
+}
+
+static void xioctl(int fd, unsigned long request, void *arg, const char *what)
+{
+	if (ioctl(fd, request, arg) < 0)
+		die(what);
+}
+
+static uint64_t pattern_word(size_t index)
+{
+	uint64_t value = PATTERN_SEED ^ (uint64_t)index * UINT64_C(0x9e3779b97f4a7c15);
+	value ^= value >> 29;
+	value *= UINT64_C(0xbf58476d1ce4e5b9);
+	return value ^ (value >> 31);
+}
+
+static void fill_pattern(void *mapping, size_t size)
+{
+	uint64_t *words = mapping;
+
+	for (size_t i = 0; i < size / sizeof(*words); i++)
+		words[i] = pattern_word(i);
+}
+
+static void verify_pattern(const void *mapping, size_t size)
+{
+	const uint64_t *words = mapping;
+
+	for (size_t i = 0; i < size / sizeof(*words); i++) {
+		uint64_t expected = pattern_word(i);
+		if (words[i] != expected) {
+			fprintf(stderr, "pattern mismatch at %zu: %#" PRIx64 " != %#" PRIx64 "\n",
+				i, words[i], expected);
+			exit(EXIT_FAILURE);
+		}
+	}
+}
+
+static void exercise_gpu(int fd, uint32_t handle, void *mapping, uint64_t size)
+{
+	uint32_t *batch = (uint32_t *)((char *)mapping + size - 8);
+	uint32_t saved[2] = { batch[0], batch[1] };
+	struct drm_i915_gem_exec_object2 object = { .handle = handle };
+	struct drm_i915_gem_execbuffer2 execbuf = {
+		.buffers_ptr = (uintptr_t)&object,
+		.buffer_count = 1,
+		.batch_start_offset = size - 8,
+		.batch_len = 8,
+		.flags = I915_EXEC_RENDER,
+	};
+	struct drm_i915_gem_wait wait = {
+		.bo_handle = handle,
+		.timeout_ns = -1,
+	};
+
+	batch[0] = 0x05000000; /* MI_BATCH_BUFFER_END */
+	batch[1] = 0;
+	xioctl(fd, DRM_IOCTL_I915_GEM_EXECBUFFER2, &execbuf, "post-restore EXECBUFFER2");
+	xioctl(fd, DRM_IOCTL_I915_GEM_WAIT, &wait, "post-restore GEM_WAIT");
+	batch[0] = saved[0];
+	batch[1] = saved[1];
+	verify_pattern(mapping, size);
+}
+
+static uint32_t create_object(int fd, uint64_t size)
+{
+	struct drm_i915_gem_create create = { .size = size };
+	xioctl(fd, DRM_IOCTL_I915_GEM_CREATE, &create, "GEM_CREATE");
+	return create.handle;
+}
+
+static void *map_object(int fd, uint32_t handle, uint64_t size, uint64_t *offset_out)
+{
+	struct drm_i915_gem_mmap_offset mmap_offset = {
+		.handle = handle,
+		.flags = I915_MMAP_OFFSET_WB,
+	};
+	void *mapping;
+
+	xioctl(fd, DRM_IOCTL_I915_GEM_MMAP_OFFSET, &mmap_offset, "GEM_MMAP_OFFSET");
+	mapping = mmap(NULL, size, PROT_READ | PROT_WRITE, MAP_SHARED, fd, mmap_offset.offset);
+	if (mapping == MAP_FAILED)
+		die("mmap GEM object");
+	*offset_out = mmap_offset.offset;
+	return mapping;
+}
+
+static void exercise_transaction(int source_fd, uint32_t source_handle,
+				 const void *source_mapping)
+{
+	struct drm_i915_criu_session dump = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_SESSION_DUMP_BEGIN,
+		.target_pid = getpid(),
+	};
+	struct drm_i915_criu_object object = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_OBJECT_QUERY,
+	};
+	struct drm_i915_criu_data data = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_DATA_READ,
+	};
+	uint8_t *image = malloc(OBJECT_SIZE);
+	int restored_fd;
+
+	if (!image)
+		die("malloc object image");
+
+	xioctl(source_fd, DRM_IOCTL_I915_CRIU_SESSION, &dump, "CRIU DUMP_BEGIN");
+	object.cookie = dump.cookie;
+	xioctl(source_fd, DRM_IOCTL_I915_CRIU_OBJECT, &object, "CRIU OBJECT_QUERY");
+	if (object.handle != source_handle || object.size != OBJECT_SIZE ||
+	    object.flags != I915_CRIU_OBJECT_SHMEM) {
+		fprintf(stderr, "unexpected object description\n");
+		exit(EXIT_FAILURE);
+	}
+
+	data.cookie = dump.cookie;
+	data.handle = object.handle;
+	data.size = object.size;
+	data.data_ptr = (uintptr_t)image;
+	xioctl(source_fd, DRM_IOCTL_I915_CRIU_DATA, &data, "CRIU DATA_READ");
+	if (memcmp(image, source_mapping, OBJECT_SIZE)) {
+		fprintf(stderr, "checkpoint image differs from mapped object\n");
+		exit(EXIT_FAILURE);
+	}
+
+	dump.op = I915_CRIU_SESSION_COMMIT;
+	xioctl(source_fd, DRM_IOCTL_I915_CRIU_SESSION, &dump, "CRIU dump COMMIT");
+
+	restored_fd = open("/dev/dri/renderD128", O_RDWR | O_CLOEXEC);
+	if (restored_fd < 0)
+		die("open restore render node");
+
+	struct drm_i915_criu_session restore = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_SESSION_RESTORE_BEGIN,
+	};
+	xioctl(restored_fd, DRM_IOCTL_I915_CRIU_SESSION, &restore, "CRIU RESTORE_BEGIN");
+
+	object.op = I915_CRIU_OBJECT_CREATE;
+	object.cookie = restore.cookie;
+	object.handle = 0;
+	object.mmap_offset = 0;
+	xioctl(restored_fd, DRM_IOCTL_I915_CRIU_OBJECT, &object, "CRIU OBJECT_CREATE");
+
+	data.op = I915_CRIU_DATA_WRITE;
+	data.cookie = restore.cookie;
+	data.handle = object.handle;
+	xioctl(restored_fd, DRM_IOCTL_I915_CRIU_DATA, &data, "CRIU DATA_WRITE");
+
+	uint64_t restored_offset;
+	void *restored_mapping = map_object(restored_fd, object.handle, object.size,
+					    &restored_offset);
+	verify_pattern(restored_mapping, object.size);
+	munmap(restored_mapping, object.size);
+
+	restore.op = I915_CRIU_SESSION_ABORT;
+	xioctl(restored_fd, DRM_IOCTL_I915_CRIU_SESSION, &restore, "CRIU restore ABORT");
+
+	struct drm_i915_gem_busy busy = { .handle = object.handle };
+	if (ioctl(restored_fd, DRM_IOCTL_I915_GEM_BUSY, &busy) == 0 || errno != ENOENT) {
+		fprintf(stderr, "restore ABORT did not remove handle %u\n", object.handle);
+		exit(EXIT_FAILURE);
+	}
+
+	close(restored_fd);
+	free(image);
+}
+
+int main(int argc, char **argv)
+{
+	bool exercise = argc == 2 && !strcmp(argv[1], "--exercise-criu-api");
+	struct sigaction action = { .sa_handler = on_signal };
+	uint64_t mmap_offset;
+	uint32_t handle;
+	void *mapping;
+	int fd;
+
+	fd = open("/dev/dri/renderD128", O_RDWR | O_CLOEXEC);
+	if (fd < 0)
+		die("open /dev/dri/renderD128");
+
+	handle = create_object(fd, OBJECT_SIZE);
+	mapping = map_object(fd, handle, OBJECT_SIZE, &mmap_offset);
+	fill_pattern(mapping, OBJECT_SIZE);
+	verify_pattern(mapping, OBJECT_SIZE);
+
+	if (exercise) {
+		exercise_transaction(fd, handle, mapping);
+		puts("PASS: i915 CRIU transaction and rollback");
+		return EXIT_SUCCESS;
+	}
+
+	if (sigaction(SIGUSR1, &action, NULL) < 0)
+		die("sigaction");
+	printf("READY pid=%d handle=%u address=%p mmap_offset=%#" PRIx64 "\n",
+	       getpid(), handle, mapping, mmap_offset);
+	fflush(stdout);
+	while (!resume_test)
+		pause();
+
+	verify_pattern(mapping, OBJECT_SIZE);
+	struct drm_i915_gem_set_domain domain = {
+		.handle = handle,
+		.read_domains = I915_GEM_DOMAIN_CPU,
+		.write_domain = I915_GEM_DOMAIN_CPU,
+	};
+	xioctl(fd, DRM_IOCTL_I915_GEM_SET_DOMAIN, &domain, "post-restore SET_DOMAIN");
+	exercise_gpu(fd, handle, mapping, OBJECT_SIZE);
+	puts("PASS: mapping address, contents, CPU access, and GPU execution");
+	return EXIT_SUCCESS;
+}
diff --git a/test/others/i915-criu/run-minimal-criu.sh b/test/others/i915-criu/run-minimal-criu.sh
new file mode 100755
index 000000000..6b2acc579
--- /dev/null
+++ b/test/others/i915-criu/run-minimal-criu.sh
@@ -0,0 +1,117 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+if (( EUID != 0 )); then
+    echo "run as root: sudo $0" >&2
+    exit 2
+fi
+
+repo=$(cd "$(dirname "$0")/../../.." && pwd)
+work=${I915_CRIU_TEST_DIR:-/tmp/i915-criu-minimal}
+criu=${CRIU:-/run/current-system/sw/bin/criu}
+plugin_dir=${CRIU_PLUGIN_DIR:-/run/current-system/sw/lib/criu}
+cc=${CC:-gcc}
+fixture="$work/i915-gem-minimal"
+fixture_source=${FIXTURE:-/tmp/i915-gem-minimal}
+images="$work/images"
+log="$work/fixture.log"
+
+cleanup() {
+    if [[ -n ${fixture_pid:-} ]]; then
+        kill -KILL "$fixture_pid" 2>/dev/null || true
+    fi
+}
+trap cleanup EXIT
+rm -rf "$work"
+mkdir -p "$images"
+
+if [[ -x $fixture_source ]]; then
+    cp "$fixture_source" "$fixture"
+elif command -v "$cc" >/dev/null; then
+    "$cc" -std=c11 -Wall -Wextra -Werror -I"$repo" \
+        "$repo/test/others/i915-criu/i915-gem-minimal.c" -o "$fixture"
+else
+    echo "no prebuilt fixture at $fixture_source and compiler $cc is unavailable" >&2
+    exit 2
+fi
+
+"$fixture" >"$log" 2>&1 &
+fixture_pid=$!
+for _ in $(seq 1 100); do
+    grep -q '^READY ' "$log" && break
+    kill -0 "$fixture_pid"
+    sleep 0.05
+done
+grep -q '^READY ' "$log"
+original_pid=$fixture_pid
+original_address=$(sed -n 's/.* address=\([^ ]*\).*/\1/p' "$log")
+original_offset=$(sed -n 's/.* mmap_offset=\([^ ]*\).*/\1/p' "$log")
+
+"$criu" dump -t "$original_pid" -D "$images" --shell-job \
+    --libdir "$plugin_dir" --log-file dump.log -v4
+wait "$fixture_pid" 2>/dev/null || true
+fixture_pid=
+
+test -s "$images"/i915-criu-*.img
+"$criu" restore -D "$images" --shell-job --restore-detached \
+    --libdir "$plugin_dir" --log-file restore.log -v4
+fixture_pid=$original_pid
+kill -USR1 "$fixture_pid"
+
+for _ in $(seq 1 100); do
+    grep -q '^PASS: mapping address, contents, CPU access, and GPU execution$' "$log" && break
+    kill -0 "$fixture_pid" 2>/dev/null || true
+    sleep 0.05
+done
+grep -q '^PASS: mapping address, contents, CPU access, and GPU execution$' "$log"
+for _ in $(seq 1 100); do
+    [[ $(cat "/proc/$fixture_pid/comm" 2>/dev/null || true) != i915-gem-minima ]] && break
+    sleep 0.05
+done
+if [[ $(cat "/proc/$fixture_pid/comm" 2>/dev/null || true) == i915-gem-minima ]]; then
+    echo "restored fixture pid $fixture_pid did not exit" >&2
+    exit 1
+fi
+fixture_pid=
+
+expect_restore_failure() {
+    local label=$1
+    local mode=$2
+    local negative="$work/negative-$label"
+    local image
+
+    cp -a "$images" "$negative"
+    rm -f "$negative/restore.log"
+    image=$(printf '%s\n' "$negative"/i915-criu-*.img)
+    case "$mode" in
+        incompatible-version)
+            printf '\002\000\000\000' | dd of="$image" bs=1 seek=8 conv=notrunc status=none
+            ;;
+        truncated)
+            truncate -s -1 "$image"
+            ;;
+        *)
+            echo "unknown negative-test mutation: $mode" >&2
+            return 2
+            ;;
+    esac
+
+    if "$criu" restore -D "$negative" --shell-job --restore-detached \
+        --libdir "$plugin_dir" --log-file restore.log -v4; then
+        echo "restore unexpectedly accepted $label image" >&2
+        return 1
+    fi
+    grep -q 'Restoring FAILED' "$negative/restore.log"
+    if [[ $(cat "/proc/$original_pid/comm" 2>/dev/null || true) == i915-gem-minima ]]; then
+        echo "failed $label restore left fixture pid $original_pid alive" >&2
+        kill -KILL "$original_pid" 2>/dev/null || true
+        return 1
+    fi
+    printf 'PASS: %s image refused without a surviving partial restore\n' "$label"
+}
+
+expect_restore_failure incompatible-schema incompatible-version
+expect_restore_failure corrupt-truncated truncated
+
+printf 'PASS: CRIU restored pid=%s address=%s mmap_offset=%s\n' \
+    "$original_pid" "$original_address" "$original_offset"
