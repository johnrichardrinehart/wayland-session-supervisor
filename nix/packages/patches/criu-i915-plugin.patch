+			}
+			bindings = grown;
+			bindings[count++] = (struct i915_image_binding){
+				.vm_id = query.vm_id,
+				.flags = query.flags,
+				.object_id = query.object_id,
+				.address = query.address,
+				.size = query.size,
+			};
+			cursor = query.cursor;
+			previous_address = query.address;
+		}
+	}
+	*result = bindings;
+	*result_count = count;
