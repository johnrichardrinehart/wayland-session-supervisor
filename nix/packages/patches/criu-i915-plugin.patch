++		}
++		i915_gem_object_put(obj);
++		args->handle = handle;
++		args->mmap_type = I915_MMAP_OFFSET_WB;
++		args->mmap_offset = 0;
++		goto out;
++
++put_restore_obj:
++		i915_gem_object_put(obj);
++delete_handle:
++		drm_gem_handle_delete(file, handle);
++	} else {
++		ret = -EINVAL;
++	}
++out:
