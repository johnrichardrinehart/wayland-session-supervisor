++static u32 checkpoint_file_flags(struct drm_file *file)
++{
++	u32 flags = 0;
++
++	if (drm_is_primary_client(file))
++		flags |= I915_CRIU_FILE_PRIMARY;
++	else if (drm_is_render_client(file))
++		flags |= I915_CRIU_FILE_RENDER;
++	if (file->authenticated)
++		flags |= I915_CRIU_FILE_AUTHENTICATED;
++	if (drm_is_current_master(file))
++		flags |= I915_CRIU_FILE_MASTER;
++	if (file->atomic)
++		flags |= I915_CRIU_FILE_ATOMIC;
++	if (file->universal_planes)
++		flags |= I915_CRIU_FILE_UNIVERSAL_PLANES;
++	if (file->aspect_ratio_allowed)
++		flags |= I915_CRIU_FILE_ASPECT_RATIO;
++	if (file->stereo_allowed)
++		flags |= I915_CRIU_FILE_STEREO;
++	if (file->writeback_connectors)
++		flags |= I915_CRIU_FILE_WRITEBACK_CONNECTORS;
++	return flags;
++}
