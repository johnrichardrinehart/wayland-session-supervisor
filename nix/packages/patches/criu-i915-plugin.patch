++		mutex_unlock(&fpriv->proto_context_lock);
++	} else if (args->op == I915_CRIU_CONTEXT_CREATE_VM) {
++		struct drm_i915_gem_vm_control create = { 0 };
++
++		if (!args->id || args->flags || args->vm_id || args->priority ||
