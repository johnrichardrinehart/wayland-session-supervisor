++int i915_criu_object_ioctl(struct drm_device *dev, void *data,
++			   struct drm_file *file)
++{
++	struct drm_i915_criu_object *args = data;
++	struct drm_i915_file_private *fpriv = file->driver_priv;
++	struct drm_i915_gem_object *obj;
++	int ret = 0;
++
++	if (args->version != I915_CRIU_ABI_VERSION || args->pad ||
++	    memchr_inv(args->reserved, 0, sizeof(args->reserved)))
++		return -EINVAL;
++
++	mutex_lock(&fpriv->criu_lock);
++	if (args->op == I915_CRIU_OBJECT_QUERY) {
++		struct drm_i915_gem_mmap_offset mmap = {
++			.flags = I915_MMAP_OFFSET_WB,
++		};
++		int handle = args->handle ? args->handle + 1 : 1;
++
++		ret = check_session(fpriv, args->cookie, I915_CRIU_MODE_DUMP);
++		if (ret)
++			goto out;
++
++		spin_lock(&file->table_lock);
++		obj = idr_get_next(&file->object_idr, &handle);
++		if (obj)
++			drm_gem_object_get(&obj->base);
++		spin_unlock(&file->table_lock);
++		if (!obj) {
++			ret = -ENOENT;
++			goto out;
++		}
++
++		if (!i915_gem_object_is_shmem(obj) || obj->base.import_attach ||
++		    obj->base.dma_buf || obj->base.handle_count != 1 ||
++		    i915_gem_object_is_userptr(obj)) {
++			ret = -EOPNOTSUPP;
++			goto put_obj;
++		}
++
++		ret = i915_gem_object_wait(obj, I915_WAIT_ALL,
++					   MAX_SCHEDULE_TIMEOUT);
++		if (ret)
++			goto put_obj;
++
++		mmap.handle = handle;
++		ret = i915_gem_mmap_offset_ioctl(dev, &mmap, file);
++		if (ret)
++			goto put_obj;
++
++		args->handle = handle;
++		args->object_id = handle;
++		args->size = obj->base.size;
++		args->flags = I915_CRIU_OBJECT_SHMEM;
++		args->mmap_offset = mmap.offset;
++		args->mmap_type = I915_MMAP_OFFSET_WB;
++put_obj:
++		i915_gem_object_put(obj);
++	} else if (args->op == I915_CRIU_OBJECT_CREATE) {
++		struct drm_i915_gem_create create = { .size = args->size };
++		void *old;
++
++		ret = check_session(fpriv, args->cookie,
++				    I915_CRIU_MODE_RESTORE);
++		if (ret)
++			goto out;
++		if (args->flags != I915_CRIU_OBJECT_SHMEM || !args->object_id ||
++		    !args->size) {
++			ret = -EINVAL;
++			goto out;
++		}
++
++		ret = i915_gem_create_ioctl(dev, &create, file);
++		if (ret)
++			goto out;
++
++		old = xa_store(&fpriv->criu_restore_handles, args->object_id,
++			       xa_mk_value(create.handle), GFP_KERNEL);
++		if (xa_is_err(old) || old) {
++			drm_gem_handle_delete(file, create.handle);
++			ret = old ? -EEXIST : xa_err(old);
++			goto out;
++		}
++		args->handle = create.handle;
++		args->mmap_type = I915_MMAP_OFFSET_WB;
++		args->mmap_offset = 0;
++	} else {
++		ret = -EINVAL;
++	}
++out:
++	mutex_unlock(&fpriv->criu_lock);
++	return ret;
++}
