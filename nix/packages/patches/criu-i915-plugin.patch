++/*
++ * Experimental, versioned i915 checkpoint/restore interface.
++ *
++ * A session is transactional. Dump sessions freeze the drm_file state until
++ * COMMIT or ABORT. Restore sessions retain every newly created object until
++ * COMMIT and destroy them on ABORT. Version 2 supports idle ordinary shmem
++ * GEM objects shared between i915 file descriptions. Version 3 additionally
++ * preserves idle empty, signaled binary, and fully signaled timeline syncobjs.
++ * Version 4 preserves configured but not yet submitted contexts and empty
++ * explicit GPU VMs. Version 5 preserves idle materialized contexts using the
++ * default engine map and ordinary local object bindings at exact GPU virtual
++ * addresses. Version 6 accounts for retained i915-exported dma-buf descriptor
++ * references while refusing attachments and imported non-i915 objects. It
++ * still refuses userptr, protected content, custom engine maps, active
++ * requests, special VMA views, exported syncobjs, in-flight fences, and KMS
++ * state.
++ */
++#define I915_CRIU_ABI_VERSION 6
++
++#define I915_CRIU_SESSION_DUMP_BEGIN    1
++#define I915_CRIU_SESSION_RESTORE_BEGIN 2
++#define I915_CRIU_SESSION_COMMIT        3
++#define I915_CRIU_SESSION_ABORT         4
++
++struct drm_i915_criu_session {
++	__u32 version;
++	__u32 op;
++	__s32 target_pid;
++	__u32 flags;
++	__u64 cookie;
++	__u64 reserved[4];
++};
++
++#define I915_CRIU_OBJECT_QUERY  1
++#define I915_CRIU_OBJECT_CREATE 2
++#define I915_CRIU_OBJECT_IMPORT 3
++
++#define I915_CRIU_OBJECT_SHMEM (1u << 0)
++#define I915_CRIU_OBJECT_SHARED (1u << 0)
++
++struct drm_i915_criu_object {
++	__u32 version;
++	__u32 op;
++	__u64 cookie;
++	/* QUERY: previous handle, zero starts enumeration. CREATE: output handle. */
++	__u32 handle;
++	__u32 flags;
++	/* Opaque identity shared by every handle to one object in the image. */
++	__u64 object_id;
++	__u64 size;
++	/* One CPU mmap offset in bytes for the minimal version. */
++	__u64 mmap_offset;
++	__u32 mmap_type;
++	__u32 pad;
++	__u32 handle_count;
++	__u32 sharing_flags;
++	/* Zero when unexported; otherwise the complete dma-buf file refcount. */
++	__u32 dma_buf_refcount;
++	/* Attachments are reported for strict userspace refusal in version 6. */
++	__u32 dma_buf_attachment_count;
++	__u64 reserved[2];
++};
++
++#define I915_CRIU_DATA_READ  1
++#define I915_CRIU_DATA_WRITE 2
++
++struct drm_i915_criu_data {
++	__u32 version;
++	__u32 op;
++	__u64 cookie;
++	__u32 handle;
++	__u32 pad;
++	__u64 offset;
++	__u64 size;
++	__u64 data_ptr;
++	__u64 reserved[4];
++};
++
++#define I915_CRIU_SYNCOBJ_QUERY  1
++#define I915_CRIU_SYNCOBJ_CREATE 2
++
++#define I915_CRIU_SYNCOBJ_EMPTY           (1u << 0)
++#define I915_CRIU_SYNCOBJ_BINARY_SIGNALED (1u << 1)
++#define I915_CRIU_SYNCOBJ_TIMELINE        (1u << 2)
++
++struct drm_i915_criu_syncobj {
++	__u32 version;
++	__u32 op;
++	__u64 cookie;
++	/* Previous handle on input; next handle on output. Zero starts. */
++	__u32 handle;
++	__u32 flags;
++	/* Last fully signaled point for a timeline syncobj. */
++	__u64 point;
++	__u64 reserved[4];
++};
++
++#define I915_CRIU_CONTEXT_QUERY_VM       1
++#define I915_CRIU_CONTEXT_QUERY_CONTEXT  2
++#define I915_CRIU_CONTEXT_CREATE_VM      3
++#define I915_CRIU_CONTEXT_CREATE_CONTEXT 4
++
++#define I915_CRIU_CONTEXT_SINGLE_TIMELINE  (1u << 0)
++#define I915_CRIU_CONTEXT_NO_ERROR_CAPTURE (1u << 1)
++#define I915_CRIU_CONTEXT_BANNABLE         (1u << 2)
++#define I915_CRIU_CONTEXT_RECOVERABLE      (1u << 3)
++#define I915_CRIU_CONTEXT_PERSISTENCE      (1u << 4)
++
++struct drm_i915_criu_context {
++	__u32 version;
++	__u32 op;
++	__u64 cookie;
++	/* Previous ID on query input; next/exact ID on output/create input. */
++	__u32 id;
++	__u32 flags;
++	__u32 vm_id;
++	__s32 priority;
++	__u64 reserved[4];
++};
++
++#define I915_CRIU_BINDING_QUERY  1
++#define I915_CRIU_BINDING_CREATE 2
++
++#define I915_CRIU_BINDING_LOCAL (1u << 0)
