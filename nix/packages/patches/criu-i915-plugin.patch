+new file mode 100644
+index 0000000..d4eba8d
+--- /dev/null
++++ b/drivers/gpu/drm/i915/i915_criu.c
+@@ -0,0 +1,1059 @@
++// SPDX-License-Identifier: MIT
++/* Experimental i915 checkpoint/restore transaction, ABI version 6. */
++
++#include <linux/capability.h>
++#include <linux/dma-buf.h>
++#include <linux/dma-fence-chain.h>
++#include <linux/pid.h>
++#include <linux/ptrace.h>
++#include <linux/random.h>
++#include <linux/sched/task.h>
++
++#include <drm/drm_file.h>
++#include <drm/drm_gem.h>
++#include <drm/drm_syncobj.h>
++
++#include "i915_criu.h"
++#include "i915_drv.h"
++#include "i915_file_private.h"
++#include "gem/i915_gem_context.h"
++#include "gem/i915_gem_ioctls.h"
++#include "gem/i915_gem_object.h"
++#include "i915_request.h"
++#include "i915_vma.h"
++
++#define I915_CRIU_MODE_NONE    0
++#define I915_CRIU_MODE_DUMP    1
++#define I915_CRIU_MODE_RESTORE 2
++
++static DEFINE_MUTEX(i915_criu_object_id_lock);
++static atomic64_t i915_criu_next_object_id = ATOMIC64_INIT(0);
++
++static u64 checkpoint_object_id(struct drm_i915_gem_object *obj)
++{
++	u64 id;
++
++	mutex_lock(&i915_criu_object_id_lock);
++	id = obj->criu_id;
++	if (!id) {
++		id = atomic64_inc_return(&i915_criu_next_object_id);
++		if (!id)
++			id = atomic64_inc_return(&i915_criu_next_object_id);
++		obj->criu_id = id;
++	}
++	mutex_unlock(&i915_criu_object_id_lock);
++	return id;
++}
++
++static int authorize_dump_target(pid_t pid)
++{
++	struct task_struct *task;
++	int ret = 0;
++
++	/*
++	 * The transaction can expose only objects reachable through this exact
++	 * drm_file. Obtaining another task's descriptor and naming that task must
++	 * nevertheless satisfy the same credential and LSM checks as ptrace.
++	 */
++	if (pid <= 0)
++		return -EINVAL;
++
++	rcu_read_lock();
++	task = get_pid_task(find_vpid(pid), PIDTYPE_PID);
++	rcu_read_unlock();
++	if (!task)
++		return -ESRCH;
++
++	if (!ptrace_may_access(task, PTRACE_MODE_ATTACH_REALCREDS))
++		ret = -EACCES;
++	put_task_struct(task);
++
++	return ret;
++}
++
++static void abort_restore(struct drm_file *file)
++{
++	struct drm_i915_file_private *fpriv = file->driver_priv;
++	unsigned long index;
++	void *entry;
++
++	xa_for_each(&fpriv->criu_restore_handles, index, entry) {
++		u32 handle = xa_to_value(entry);
++
++		xa_erase(&fpriv->criu_restore_handles, index);
++		drm_gem_handle_delete(file, handle);
++	}
++	xa_for_each(&fpriv->criu_restore_syncobjs, index, entry) {
++		struct drm_syncobj *syncobj;
++		u32 handle = xa_to_value(entry);
++
++		xa_erase(&fpriv->criu_restore_syncobjs, index);
++		syncobj = xa_erase(&file->syncobj_xa, handle);
++		if (syncobj)
++			drm_syncobj_put(syncobj);
++	}
++	xa_for_each(&fpriv->criu_restore_contexts, index, entry) {
++		struct drm_i915_gem_context_destroy destroy = {
++			.ctx_id = xa_to_value(entry),
++		};
++
++		xa_erase(&fpriv->criu_restore_contexts, index);
++		i915_gem_context_destroy_ioctl(file->minor->dev, &destroy, file);
++	}
++	xa_for_each(&fpriv->criu_restore_vms, index, entry) {
++		struct drm_i915_gem_vm_control destroy = {
++			.vm_id = xa_to_value(entry),
++		};
++
++		xa_erase(&fpriv->criu_restore_vms, index);
++		i915_gem_vm_destroy_ioctl(file->minor->dev, &destroy, file);
++	}
++}
++
++void i915_criu_file_init(struct drm_file *file)
++{
++	struct drm_i915_file_private *fpriv = file->driver_priv;
++
++	mutex_init(&fpriv->criu_lock);
++	xa_init(&fpriv->criu_restore_handles);
++	xa_init(&fpriv->criu_restore_syncobjs);
++	xa_init(&fpriv->criu_restore_contexts);
++	xa_init(&fpriv->criu_restore_vms);
++}
++
++void i915_criu_file_fini(struct drm_file *file)
++{
++	struct drm_i915_file_private *fpriv = file->driver_priv;
++
++	mutex_lock(&fpriv->criu_lock);
++	if (fpriv->criu_mode == I915_CRIU_MODE_RESTORE)
++		abort_restore(file);
++	fpriv->criu_mode = I915_CRIU_MODE_NONE;
++	fpriv->criu_cookie = 0;
++	mutex_unlock(&fpriv->criu_lock);
++	xa_destroy(&fpriv->criu_restore_handles);
++	xa_destroy(&fpriv->criu_restore_syncobjs);
++	xa_destroy(&fpriv->criu_restore_contexts);
++	xa_destroy(&fpriv->criu_restore_vms);
++}
++
++static u32 context_vm_id(struct drm_i915_file_private *fpriv,
++			 struct i915_address_space *context_vm)
++{
++	struct i915_address_space *vm;
++	unsigned long id;
++
++	if (!context_vm)
++		return 0;
++	xa_for_each(&fpriv->vm_xa, id, vm)
++		if (vm == context_vm)
++			return id;
++	return U32_MAX;
++}
++
++static u32 checkpoint_user_context_flags(unsigned long user_flags,
++					 bool single_timeline)
++{
++	u32 flags = 0;
++
++	if (single_timeline)
++		flags |= I915_CRIU_CONTEXT_SINGLE_TIMELINE;
++	if (user_flags & BIT(UCONTEXT_NO_ERROR_CAPTURE))
++		flags |= I915_CRIU_CONTEXT_NO_ERROR_CAPTURE;
++	if (user_flags & BIT(UCONTEXT_BANNABLE))
++		flags |= I915_CRIU_CONTEXT_BANNABLE;
++	if (user_flags & BIT(UCONTEXT_RECOVERABLE))
++		flags |= I915_CRIU_CONTEXT_RECOVERABLE;
++	if (user_flags & BIT(UCONTEXT_PERSISTENCE))
++		flags |= I915_CRIU_CONTEXT_PERSISTENCE;
++	return flags;
++}
++
++static u32 checkpoint_proto_context_flags(const struct i915_gem_proto_context *pc)
++{
++	return checkpoint_user_context_flags(pc->user_flags,
++					     pc->single_timeline);
++}
++
++static u32 checkpoint_active_context_flags(const struct i915_gem_context *ctx)
++{
++	return checkpoint_user_context_flags(ctx->user_flags, !!ctx->syncobj);
++}
++
++static bool object_has_file_handle(struct drm_file *file,
++				   struct drm_i915_gem_object *object)
++{
++	struct drm_gem_object *candidate;
++	int handle;
++	bool found = false;
++
++	spin_lock(&file->table_lock);
++	idr_for_each_entry(&file->object_idr, candidate, handle) {
++		if (candidate == &object->base) {
++			found = true;
++			break;
++		}
++	}
++	spin_unlock(&file->table_lock);
++	return found;
++}
++
++static int validate_active_context(struct drm_i915_file_private *fpriv,
++				   struct i915_gem_context *ctx,
++				   bool require_tracked_vm)
++{
++	const unsigned long allowed_user_flags =
++		BIT(UCONTEXT_NO_ERROR_CAPTURE) | BIT(UCONTEXT_BANNABLE) |
++		BIT(UCONTEXT_RECOVERABLE) | BIT(UCONTEXT_PERSISTENCE);
++	struct i915_gem_engines_iter it;
++	struct i915_gem_engines *engines;
++	struct intel_context *ce;
++	int ret = 0;
++
++	if (ctx->uses_protected_content ||
++	    ctx->user_flags & ~allowed_user_flags ||
++	    test_bit(CONTEXT_USER_ENGINES, &ctx->flags) ||
++	    (require_tracked_vm && context_vm_id(fpriv, ctx->vm) == U32_MAX))
++		return -EOPNOTSUPP;
++
++	engines = i915_gem_context_lock_engines(ctx);
++	for_each_gem_engine(ce, engines, it) {
++		if (!intel_context_pin_if_active(ce))
++			continue;
++		intel_context_unpin(ce);
++		ret = -EBUSY;
++		break;
++	}
++	i915_gem_context_unlock_engines(ctx);
++	return ret;
++}
++
++static int validate_checkpoint_contexts(struct drm_file *file)
++{
++	const unsigned long allowed_user_flags =
++		BIT(UCONTEXT_NO_ERROR_CAPTURE) | BIT(UCONTEXT_BANNABLE) |
++		BIT(UCONTEXT_RECOVERABLE) | BIT(UCONTEXT_PERSISTENCE);
++	struct drm_i915_file_private *fpriv = file->driver_priv;
++	struct i915_gem_proto_context *pc;
++	struct i915_gem_context *ctx;
++	struct i915_address_space *vm;
++	struct i915_vma *vma;
++	unsigned long id;
++	u32 context_count = 0;
++	u32 context_max = 0;
++	u32 expected_vm = 1;
++	int ret = 0;
++
++	xa_for_each(&fpriv->context_xa, id, ctx) {
++		ret = validate_active_context(fpriv, ctx, id != 0);
++		if (ret)
++			return ret;
++		if (id == 0) {
++			if (!ctx->vm)
++				continue;
++			mutex_lock(&ctx->vm->mutex);
++			if (!list_empty(&ctx->vm->bound_list) ||
++			    !list_empty(&ctx->vm->unbound_list))
++				ret = -EOPNOTSUPP;
++			mutex_unlock(&ctx->vm->mutex);
++			if (ret)
++				return ret;
++			continue;
++		}
++		context_count++;
++		context_max = max_t(u32, context_max, id);
++	}
++
++	mutex_lock(&fpriv->proto_context_lock);
++	xa_for_each(&fpriv->proto_context_xa, id, pc) {
++		context_count++;
++		context_max = max_t(u32, context_max, id);
++		if (pc->num_user_engines != -1 || pc->user_engines ||
++		    pc->uses_protected_content || pc->pxp_wakeref ||
++		    pc->user_flags & ~allowed_user_flags ||
++		    memchr_inv(&pc->legacy_rcs_sseu, 0,
++			       sizeof(pc->legacy_rcs_sseu)) ||
++		    context_vm_id(fpriv, pc->vm) == U32_MAX) {
++			ret = -EOPNOTSUPP;
++			break;
++		}
++	}
++	mutex_unlock(&fpriv->proto_context_lock);
++	if (ret)
++		return ret;
++	if (context_count != context_max)
++		return -EOPNOTSUPP;
++
++	xa_for_each(&fpriv->vm_xa, id, vm) {
++		if (id != expected_vm++)
++			return -EOPNOTSUPP;
++		mutex_lock(&vm->mutex);
++		if (!list_empty(&vm->unbound_list)) {
++			ret = -EOPNOTSUPP;
++			goto unlock_vm;
++		}
++		list_for_each_entry(vma, &vm->bound_list, vm_link) {
++			int flags = atomic_read(&vma->flags);
++
++			if (!drm_mm_node_allocated(&vma->node) || vma->guard ||
++			    vma->size != vma->obj->base.size ||
++			    vma->gtt_view.type != I915_GTT_VIEW_NORMAL ||
++			    i915_vma_is_active(vma) ||
++			    (flags & I915_VMA_BIND_MASK) != I915_VMA_LOCAL_BIND ||
++			    flags & (I915_VMA_GLOBAL_BIND | I915_VMA_ERROR |
++				     I915_VMA_GGTT | I915_VMA_CAN_FENCE |
++				     I915_VMA_USERFAULT | I915_VMA_SCANOUT) ||
++			    !object_has_file_handle(file, vma->obj)) {
++				ret = -EOPNOTSUPP;
++				break;
++			}
++		}
++unlock_vm:
++		mutex_unlock(&vm->mutex);
++		if (ret)
++			return ret;
++	}
++	return 0;
++}
++
++static int describe_syncobj(struct drm_syncobj *syncobj, u32 *flags, u64 *point)
++{
++	struct dma_fence *fence;
++	unsigned long irqflags;
++	bool has_callbacks;
++
++	if (READ_ONCE(syncobj->file))
++		return -EXDEV;
++
++	spin_lock_irqsave(&syncobj->lock, irqflags);
++	has_callbacks = !list_empty(&syncobj->cb_list) ||
++			!list_empty(&syncobj->ev_fd_list);
++	spin_unlock_irqrestore(&syncobj->lock, irqflags);
++	if (has_callbacks)
++		return -EBUSY;
++
++	fence = drm_syncobj_fence_get(syncobj);
++	if (!fence) {
++		*flags = I915_CRIU_SYNCOBJ_EMPTY;
++		*point = 0;
++		return 0;
++	}
++	if (!dma_fence_is_signaled(fence)) {
++		dma_fence_put(fence);
++		return -EBUSY;
++	}
++	if (to_dma_fence_chain(fence)) {
++		*flags = I915_CRIU_SYNCOBJ_TIMELINE;
++		*point = fence->seqno;
++	} else {
++		*flags = I915_CRIU_SYNCOBJ_BINARY_SIGNALED;
++		*point = 0;
++	}
++	dma_fence_put(fence);
++	return 0;
++}
++
++static int describe_dma_buf(struct drm_i915_gem_object *obj,
++			    struct drm_i915_criu_object *args)
++{
++	struct dma_buf_attachment *attachment;
++	struct dma_buf *dmabuf = obj->base.dma_buf;
++	long refcount;
++	u32 attachment_count = 0;
++
++	if (!dmabuf)
++		return 0;
++
++	refcount = file_count(dmabuf->file);
++	if (refcount <= 0 || refcount > U32_MAX)
++		return -EOVERFLOW;
++	dma_resv_lock(dmabuf->resv, NULL);
++	list_for_each_entry(attachment, &dmabuf->attachments, node) {
++		if (attachment_count == U32_MAX) {
++			dma_resv_unlock(dmabuf->resv);
++			return -EOVERFLOW;
++		}
++		attachment_count++;
++	}
++	dma_resv_unlock(dmabuf->resv);
++	args->dma_buf_refcount = refcount;
++	args->dma_buf_attachment_count = attachment_count;
++	return attachment_count ? -EOPNOTSUPP : 0;
++}
++
++static int validate_syncobjs(struct drm_file *file)
++{
++	struct drm_syncobj *syncobj;
++	unsigned long index;
++	int ret = 0;
++
++	xa_for_each(&file->syncobj_xa, index, syncobj) {
++		u32 flags;
++		u64 point;
++
++		drm_syncobj_get(syncobj);
++		ret = describe_syncobj(syncobj, &flags, &point);
++		drm_syncobj_put(syncobj);
++		if (ret)
++			break;
++	}
++	return ret;
++}
++
++static int check_session(struct drm_i915_file_private *fpriv, u64 cookie,
++			 u32 mode)
++{
++	if (fpriv->criu_mode != mode)
++		return -EINVAL;
++	if (!cookie || cookie != fpriv->criu_cookie)
++		return -ESTALE;
++	return 0;
++}
