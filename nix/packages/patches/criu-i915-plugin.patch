@@ -0,0 +1,240 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+if (( EUID != 0 )); then
+    echo "run as root: sudo $0" >&2
+    exit 2
+fi
+
+repo=$(cd "$(dirname "$0")/../../.." && pwd)
+scripts="$repo/test/others/i915-criu"
+abi=$(awk '$1 == "#define" && $2 == "I915_CRIU_ABI_VERSION" { print $3 }' \
+    "$repo/contrib/i915-criu/i915_criu_uapi.h")
+if [[ ! $abi =~ ^[0-9]+$ ]]; then
+    echo "cannot derive the physical-suite ABI from i915_criu_uapi.h" >&2
+    exit 2
+fi
+image_schema=$abi
+timestamp=$(date -u +%Y%m%dT%H%M%SZ)
+suite=${I915_CRIU_SUITE_DIR:-/var/tmp/i915-criu-physical-$timestamp}
+criu=${CRIU:-/run/current-system/sw/bin/criu}
+plugin_dir=${CRIU_PLUGIN_DIR:-/run/current-system/sw/lib/criu}
+minimal_fixture=${MINIMAL_FIXTURE:-/tmp/i915-gem-minimal}
+sharing_fixture=${SHARING_FIXTURE:-/tmp/i915-gem-sharing}
+context_fixture=${CONTEXT_FIXTURE:-/tmp/i915-context-sync}
+kms_fixture=${KMS_FIXTURE:-/tmp/i915-kms-atomic}
+
+umask 077
+mkdir -p "$suite"
+chmod 0700 "$suite"
+
+return_evidence_to_invoker() {
+    if [[ -n ${SUDO_UID:-} && -n ${SUDO_GID:-} ]]; then
+        chown -R "$SUDO_UID:$SUDO_GID" "$suite"
+        chmod 0700 "$suite"
+    fi
+}
+trap return_evidence_to_invoker EXIT
+
+for required in "$criu" "$plugin_dir/i915_plugin.so" \
+    "$minimal_fixture" "$sharing_fixture" "$context_fixture" "$kms_fixture"; do
+    if [[ ! -e $required ]]; then
+        echo "required physical-suite artifact is missing: $required" >&2
+        exit 2
+    fi
+done
+
+kernel_module=$(modinfo -F filename i915)
+require_kernel_symbol() {
+    local symbol=$1
+
+    if [[ $kernel_module == *.xz ]]; then
+        xzgrep -a -q "$symbol" "$kernel_module"
+    else
+        grep -a -q "$symbol" "$kernel_module"
+    fi
+}
+for symbol in i915_criu_framebuffer_ioctl i915_criu_mapping_ioctl; do
+    if ! require_kernel_symbol "$symbol"; then
+        echo "booted i915 module lacks required ABI-$abi symbol: $symbol" >&2
+        exit 2
+    fi
+done
+
+read_parameter() {
+    local name=$1
+    cat "/sys/module/i915/parameters/$name" 2>/dev/null || printf '<unavailable>'
+}
+
+sha256_or_unavailable() {
+    local path=$1
+    if [[ -f $path ]]; then
+        sha256sum "$path" | awk '{print $1}'
+    else
+        printf '<unavailable>'
+    fi
+}
+
+linked_library() {
+    local binary=$1
+    local soname=$2
+    local output
+    local path
+
+    output=$(ldd "$binary" 2>/dev/null || true)
+    path=$(awk -v soname="$soname" '$1 == soname { found = $3 } END { print found }' \
+        <<<"$output")
+    printf '%s' "${path:-<unavailable>}"
+}
+
+effective_uc=$(journalctl -b -k --no-pager 2>/dev/null \
+    | grep 'enable_guc=.*submission:' | tail -1 || true)
+mesa_dri=$(readlink -f /run/opengl-driver/lib/dri/iris_dri.so 2>/dev/null \
+    || printf '<unavailable>')
+
+jq -n \
+    --arg timestamp "$timestamp" \
+    --argjson abi "$abi" \
+    --argjson image_schema "$image_schema" \
+    --arg kernel "$(uname -r)" \
+    --arg boot_id "$(cat /proc/sys/kernel/random/boot_id)" \
+    --arg system "$(readlink -f /run/current-system)" \
+    --arg pci "$(lspci -Dnn -s 0000:00:02.0)" \
+    --arg kernel_module "$kernel_module" \
+    --arg kernel_module_sha256 "$(sha256_or_unavailable "$kernel_module")" \
+    --arg criu "$($criu --version | head -1)" \
+    --arg plugin "$(readlink -f "$plugin_dir/i915_plugin.so")" \
+    --arg plugin_sha256 "$(sha256_or_unavailable "$plugin_dir/i915_plugin.so")" \
+    --arg niri "$(niri --version 2>/dev/null || printf '<unavailable>')" \
+    --arg niri_libgbm "$(linked_library "$(command -v niri)" libgbm.so.1)" \
+    --arg niri_libdrm "$(linked_library "$(command -v niri)" libdrm.so.2)" \
+    --arg fixture_libdrm "$(linked_library "$kms_fixture" libdrm.so.2)" \
+    --arg mesa_dri "$mesa_dri" \
+    --arg minimal_fixture_sha256 "$(sha256_or_unavailable "$minimal_fixture")" \
+    --arg sharing_fixture_sha256 "$(sha256_or_unavailable "$sharing_fixture")" \
+    --arg context_fixture_sha256 "$(sha256_or_unavailable "$context_fixture")" \
+    --arg kms_fixture_sha256 "$(sha256_or_unavailable "$kms_fixture")" \
+    --arg enable_guc "$(read_parameter enable_guc)" \
+    --arg enable_hangcheck "$(read_parameter enable_hangcheck)" \
+    --arg modeset "$(read_parameter modeset)" \
+    --arg effective_uc "${effective_uc:-<unavailable>}" \
+    '{schema:1,timestamp:$timestamp,kernel:$kernel,boot_id:$boot_id,
+      system:$system,pci:$pci,kernel_module:$kernel_module,
+      kernel_module_sha256:$kernel_module_sha256,criu:$criu,plugin:$plugin,
+      plugin_sha256:$plugin_sha256,abi:$abi,image_schema:$image_schema,niri:$niri,
+      userspace:{niri_libgbm:$niri_libgbm,niri_libdrm:$niri_libdrm,
+      fixture_libdrm:$fixture_libdrm,mesa_dri:$mesa_dri},
+      fixtures:{minimal_sha256:$minimal_fixture_sha256,
+      sharing_sha256:$sharing_fixture_sha256,
+      context_sha256:$context_fixture_sha256,kms_sha256:$kms_fixture_sha256},
+      i915:{enable_guc:$enable_guc,enable_hangcheck:$enable_hangcheck,
+      modeset:$modeset,effective_uc:$effective_uc}}' \
+    >"$suite/metadata.json"
+
+run_case() {
+    local name=$1
+    shift
+    local log="$suite/$name.log"
+
+    echo "RUN: $name"
+    if "$@" >"$log" 2>&1; then
+        echo "PASS: $name"
+    else
+        local status=$?
+        echo "FAIL: $name (status=$status); log=$log" >&2
+        tail -80 "$log" >&2
+        exit "$status"
+    fi
+}
+
+common=(CRIU="$criu" CRIU_PLUGIN_DIR="$plugin_dir")
+run_case minimal-gem env "${common[@]}" \
+    FIXTURE="$minimal_fixture" I915_CRIU_TEST_DIR="$suite/minimal-gem" \
+    "$scripts/run-minimal-criu.sh"
+run_case shared-gem env "${common[@]}" \
+    FIXTURE="$sharing_fixture" I915_CRIU_TEST_DIR="$suite/shared-gem" \
+    "$scripts/run-sharing-criu.sh"
+run_case external-sharing-refusal env "${common[@]}" \
+    FIXTURE="$sharing_fixture" I915_CRIU_EXTERNAL_PEER=1 \
+    I915_CRIU_TEST_DIR="$suite/external-sharing-refusal" \
+    "$scripts/run-sharing-criu.sh"
+run_case retained-dmabuf env "${common[@]}" \
+    FIXTURE="$sharing_fixture" I915_CRIU_RETAINED_DMABUF=1 \
+    I915_CRIU_EXPECT_UNSUPPORTED=0 \
+    I915_CRIU_TEST_DIR="$suite/retained-dmabuf" \
+    "$scripts/run-sharing-criu.sh"
+run_case external-dmabuf-refusal env "${common[@]}" \
+    FIXTURE="$sharing_fixture" I915_CRIU_EXTERNAL_DMABUF_PEER=1 \
+    I915_CRIU_TEST_DIR="$suite/external-dmabuf-refusal" \
+    "$scripts/run-sharing-criu.sh"
+run_case synchronization env "${common[@]}" \
+    FIXTURE="$context_fixture" I915_CRIU_EXPECT_UNSUPPORTED=0 \
+    I915_CRIU_SYNC_ONLY=1 I915_CRIU_TEST_DIR="$suite/synchronization" \
+    "$scripts/run-context-sync-criu.sh"
+run_case retained-sync-file env "${common[@]}" \
+    FIXTURE="$context_fixture" I915_CRIU_EXPECT_UNSUPPORTED=0 \
+    I915_CRIU_SYNC_FILE=1 I915_CRIU_TEST_DIR="$suite/retained-sync-file" \
+    "$scripts/run-context-sync-criu.sh"
+run_case external-sync-file-refusal env "${common[@]}" \
+    FIXTURE="$context_fixture" I915_CRIU_EXPECT_UNSUPPORTED=1 \
+    I915_CRIU_EXTERNAL_SYNC_FILE=1 \
+    I915_CRIU_TEST_DIR="$suite/external-sync-file-refusal" \
+    "$scripts/run-context-sync-criu.sh"
+run_case idle-context-vm env "${common[@]}" \
+    FIXTURE="$context_fixture" I915_CRIU_EXPECT_UNSUPPORTED=0 \
+    I915_CRIU_IDLE_CONTEXT=1 I915_CRIU_TEST_DIR="$suite/idle-context-vm" \
+    "$scripts/run-context-sync-criu.sh"
+run_case sync-callback-refusal env "${common[@]}" \
+    FIXTURE="$context_fixture" I915_CRIU_EXPECT_UNSUPPORTED=1 \
+    I915_CRIU_CALLBACK=1 I915_CRIU_TEST_DIR="$suite/sync-callback-refusal" \
+    "$scripts/run-context-sync-criu.sh"
+run_case context-vm-binding env "${common[@]}" \
+    FIXTURE="$context_fixture" I915_CRIU_EXPECT_UNSUPPORTED=0 \
+    I915_CRIU_TEST_DIR="$suite/context-vm-binding" \
+    "$scripts/run-context-sync-criu.sh"
+run_case custom-engine-context env "${common[@]}" \
+    FIXTURE="$context_fixture" I915_CRIU_EXPECT_UNSUPPORTED=0 \
+    I915_CRIU_CUSTOM_ENGINE=1 \
+    I915_CRIU_TEST_DIR="$suite/custom-engine-context" \
+    "$scripts/run-context-sync-criu.sh"
+run_case virtual-engine-refusal env "${common[@]}" \
+    FIXTURE="$context_fixture" I915_CRIU_EXPECT_UNSUPPORTED=1 \
+    I915_CRIU_VIRTUAL_ENGINE=1 \
+    I915_CRIU_TEST_DIR="$suite/virtual-engine-refusal" \
+    "$scripts/run-context-sync-criu.sh"
+run_case physical-kms env "${common[@]}" \
+    FIXTURE="$kms_fixture" I915_CRIU_TEST_DIR="$suite/physical-kms" \
+    "$scripts/run-kms-criu.sh"
+run_case kms-role-corruption-refusal env "${common[@]}" \
+    FIXTURE="$kms_fixture" I915_CRIU_KMS_CORRUPT_MODE=role \
+    I915_CRIU_TEST_DIR="$suite/kms-role-corruption-refusal" \
+    "$scripts/run-kms-criu.sh"
+run_case kms-count-corruption-refusal env "${common[@]}" \
