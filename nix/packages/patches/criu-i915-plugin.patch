++void i915_criu_file_init(struct drm_file *file)
++{
++	struct drm_i915_file_private *fpriv = file->driver_priv;
++
++	mutex_init(&fpriv->criu_lock);
++	xa_init(&fpriv->criu_restore_handles);
++	xa_init(&fpriv->criu_restore_syncobjs);
++	xa_init(&fpriv->criu_restore_contexts);
++	xa_init(&fpriv->criu_restore_vms);
++	xa_init(&fpriv->criu_restore_fbs);
++	xa_init(&fpriv->criu_restore_blobs);
++}
++
++void i915_criu_file_fini(struct drm_file *file)
++{
++	struct drm_i915_file_private *fpriv = file->driver_priv;
++
++	mutex_lock(&fpriv->criu_lock);
++	if (fpriv->criu_mode == I915_CRIU_MODE_RESTORE)
++		abort_restore(file);
++	fpriv->criu_mode = I915_CRIU_MODE_NONE;
++	fpriv->criu_cookie = 0;
++	mutex_unlock(&fpriv->criu_lock);
++	xa_destroy(&fpriv->criu_restore_handles);
++	xa_destroy(&fpriv->criu_restore_syncobjs);
++	xa_destroy(&fpriv->criu_restore_contexts);
++	xa_destroy(&fpriv->criu_restore_vms);
++	xa_destroy(&fpriv->criu_restore_fbs);
++	xa_destroy(&fpriv->criu_restore_blobs);
++}
