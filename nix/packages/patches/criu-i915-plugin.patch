++			ret = -ENOENT;
++			goto out_free;
++		}
++		engines[i].type = I915_GEM_ENGINE_TYPE_PHYSICAL;
++	}
++
++	mutex_lock(&fpriv->proto_context_lock);
++	pc = xa_load(&fpriv->proto_context_xa, args->id);
