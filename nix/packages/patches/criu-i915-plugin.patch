++int i915_criu_binding_ioctl(struct drm_device *dev, void *data,
++			    struct drm_file *file)
++{
++	struct drm_i915_criu_binding *args = data;
++	struct drm_i915_file_private *fpriv = file->driver_priv;
++	struct i915_address_space *vm;
++	struct drm_i915_gem_object *object;
++	struct i915_vma *vma;
++	int ret;
++
++	if (args->version != I915_CRIU_ABI_VERSION ||
++	    memchr_inv(args->reserved, 0, sizeof(args->reserved)) ||
++	    !args->vm_id)
++		return -EINVAL;
++
++	mutex_lock(&fpriv->criu_lock);
++	if (args->op == I915_CRIU_BINDING_QUERY) {
++		struct i915_vma *candidate = NULL;
++		u64 candidate_address = U64_MAX;
++
++		if (args->flags || args->object_id || args->size) {
++			ret = -EINVAL;
++			goto out;
++		}
++		ret = check_session(fpriv, args->cookie, I915_CRIU_MODE_DUMP);
++		if (ret)
++			goto out;
++		vm = xa_load(&fpriv->vm_xa, args->vm_id);
++		if (!vm) {
++			ret = -ENOENT;
++			goto out;
++		}
++		mutex_lock(&vm->mutex);
++		list_for_each_entry(vma, &vm->bound_list, vm_link) {
++			u64 address = i915_vma_offset(vma);
++
++			if ((!args->cursor || address > args->address) &&
++			    address < candidate_address) {
++				candidate = vma;
++				candidate_address = address;
++			}
++		}
++		if (candidate) {
++			args->flags = I915_CRIU_BINDING_LOCAL;
++			args->object_id = checkpoint_object_id(candidate->obj);
++			args->cursor++;
++			args->address = candidate_address;
++			args->size = candidate->size;
++		}
++		mutex_unlock(&vm->mutex);
++		ret = candidate ? 0 : -ENOENT;
++	} else if (args->op == I915_CRIU_BINDING_CREATE) {
++		void *entry;
++		u32 handle;
++		u64 pin_flags;
++
++		if (args->flags != I915_CRIU_BINDING_LOCAL || args->cursor ||
++		    !args->object_id || !args->size ||
++		    args->address & ~PIN_OFFSET_MASK ||
++		    !IS_ALIGNED(args->address, I915_GTT_PAGE_SIZE) ||
++		    !IS_ALIGNED(args->size, I915_GTT_PAGE_SIZE)) {
++			ret = -EINVAL;
++			goto out;
++		}
++		ret = check_session(fpriv, args->cookie,
++				    I915_CRIU_MODE_RESTORE);
++		if (ret)
++			goto out;
++		if (!xa_load(&fpriv->criu_restore_vms, args->vm_id)) {
++			ret = -ENOENT;
++			goto out;
++		}
++		vm = xa_load(&fpriv->vm_xa, args->vm_id);
++		entry = xa_load(&fpriv->criu_restore_handles, args->object_id);
++		if (!vm || !entry) {
++			ret = -ENOENT;
++			goto out;
++		}
++		handle = xa_to_value(entry);
++		object = i915_gem_object_lookup(file, handle);
++		if (!object) {
++			ret = -ENOENT;
++			goto out;
++		}
++		if (args->size != object->base.size) {
++			ret = -EINVAL;
++			goto put_object;
++		}
++		vma = i915_vma_instance(object, vm, NULL);
++		if (IS_ERR(vma)) {
++			ret = PTR_ERR(vma);
++			goto put_object;
++		}
++		/* PIN_VALIDATE binds without incrementing the VMA pin count. */
++		pin_flags = args->address | PIN_OFFSET_FIXED | PIN_USER |
++			    PIN_NOEVICT | PIN_VALIDATE;
++		ret = i915_vma_pin(vma, args->size, 0, pin_flags);
++		if (!ret && (i915_vma_offset(vma) != args->address ||
++			     vma->size != args->size ||
++			     !i915_vma_is_bound(vma, I915_VMA_LOCAL_BIND)))
++			ret = -EIO;
++put_object:
++		i915_gem_object_put(object);
++	} else {
++		ret = -EINVAL;
++	}
++out:
++	mutex_unlock(&fpriv->criu_lock);
++	return ret;
++}
