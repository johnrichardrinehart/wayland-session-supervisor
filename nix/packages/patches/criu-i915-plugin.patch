++static int query_sync_file(struct drm_file *file,
++			   struct drm_i915_criu_sync_file *args)
++{
++	struct file *sync_file_file;
++	struct dma_fence *fence;
++	struct drm_syncobj *syncobj;
++	unsigned long index;
++	long refcount;
++	u32 matched_handle = 0;
++	int ret = 0;
++
++	if (args->fd < 0 || args->handle || args->flags || args->fd_refcount ||
++	    args->point)
++		return -EINVAL;
++
++	/* fget() supplies one known temporary reference, excluded from the ABI. */
++	sync_file_file = fget(args->fd);
++	if (!sync_file_file)
++		return -EBADF;
++	fence = sync_file_get_fence(args->fd);
++	if (!fence) {
++		ret = -EINVAL;
++		goto out_file;
++	}
++	if (dma_fence_get_status(fence) != 1 || to_dma_fence_chain(fence)) {
++		ret = -EOPNOTSUPP;
++		goto out_fence;
++	}
++
++	xa_for_each(&file->syncobj_xa, index, syncobj) {
++		struct dma_fence *candidate = drm_syncobj_fence_get(syncobj);
++
++		if (candidate == fence) {
++			u32 flags;
++			u64 point;
++
++			ret = describe_syncobj(syncobj, &flags, &point);
++			if (!ret &&
++			    (flags != I915_CRIU_SYNCOBJ_BINARY_SIGNALED ||
++			     point))
++				ret = -EOPNOTSUPP;
++			if (!ret && matched_handle)
++				ret = -EXDEV;
++			if (!ret)
++				matched_handle = index;
++		}
++		dma_fence_put(candidate);
++		if (ret)
++			goto out_fence;
++	}
++	if (!matched_handle) {
++		ret = -EXDEV;
++		goto out_fence;
++	}
++	refcount = file_count(sync_file_file) - 1;
++	if (refcount <= 0 || refcount > U32_MAX) {
++		ret = -EOVERFLOW;
++		goto out_fence;
++	}
++	args->handle = matched_handle;
++	args->flags = I915_CRIU_SYNC_FILE_BINARY_SIGNALED;
++	args->fd_refcount = refcount;
++
++out_fence:
++	dma_fence_put(fence);
++out_file:
++	fput(sync_file_file);
++	return ret;
++}
