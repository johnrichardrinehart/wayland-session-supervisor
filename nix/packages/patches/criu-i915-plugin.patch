+static int record_dump_dmabuf_file(int file_id, uint64_t object_id)
+{
+	for (size_t i = 0; i < dump_dmabuf_file_count; i++) {
+		struct dump_dmabuf_file *file = &dump_dmabuf_files[i];
+
+		if (file->file_id != file_id)
+			continue;
+		if (file->object_id != object_id || file->fd_count == UINT32_MAX)
+			return -EINVAL;
+		file->fd_count++;
+		return 0;
+	}
+	if (dump_dmabuf_file_count == I915_MAX_RESTORE_FILES)
+		return -E2BIG;
+	dump_dmabuf_files[dump_dmabuf_file_count++] =
+		(struct dump_dmabuf_file) {
+			.file_id = file_id,
+			.object_id = object_id,
+			.fd_count = 1,
+		};
+	return 0;
+}
+
+int i915_plugin_handle_ext_file_reference(int fd, int id)
+{
+	uint64_t object_id;
+	int ret;
+
+	if (!is_dmabuf_fd(fd))
+		return -ENOTSUP;
+	ret = resolve_dmabuf_object(fd, &object_id);
+	if (ret)
+		return ret;
+	ret = record_dump_dmabuf_reference(object_id);
+	if (ret)
+		return ret;
+	return record_dump_dmabuf_file(id, object_id);
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__HANDLE_EXT_FILE_REFERENCE,
+			 i915_plugin_handle_ext_file_reference)
