+++ b/contrib/i915-criu/i915_criu_uapi.h
@@ -0,0 +1,62 @@
+/* SPDX-License-Identifier: MIT */
+#ifndef I915_CRIU_UAPI_H
+#define I915_CRIU_UAPI_H
+
+#include <stdint.h>
+#include <sys/ioctl.h>
+#include <drm/i915_drm.h>
+
+#define I915_CRIU_ABI_VERSION 1
+#define I915_CRIU_SESSION_DUMP_BEGIN 1
+#define I915_CRIU_SESSION_RESTORE_BEGIN 2
+#define I915_CRIU_SESSION_COMMIT 3
+#define I915_CRIU_SESSION_ABORT 4
+#define I915_CRIU_OBJECT_QUERY 1
+#define I915_CRIU_OBJECT_CREATE 2
+#define I915_CRIU_OBJECT_SHMEM (1u << 0)
+#define I915_CRIU_DATA_READ 1
+#define I915_CRIU_DATA_WRITE 2
+
+struct drm_i915_criu_session {
+	uint32_t version;
+	uint32_t op;
+	int32_t target_pid;
+	uint32_t flags;
+	uint64_t cookie;
+	uint64_t reserved[4];
+};
+
+struct drm_i915_criu_object {
+	uint32_t version;
+	uint32_t op;
+	uint64_t cookie;
+	uint32_t handle;
+	uint32_t flags;
+	uint64_t object_id;
+	uint64_t size;
+	uint64_t mmap_offset;
+	uint32_t mmap_type;
+	uint32_t pad;
+	uint64_t reserved[4];
+};
+
+struct drm_i915_criu_data {
+	uint32_t version;
+	uint32_t op;
+	uint64_t cookie;
+	uint32_t handle;
+	uint32_t pad;
+	uint64_t offset;
+	uint64_t size;
+	uint64_t data_ptr;
+	uint64_t reserved[4];
+};
+
+#define DRM_IOCTL_I915_CRIU_SESSION \
+	_IOWR(DRM_IOCTL_BASE, DRM_COMMAND_BASE + 0x3d, struct drm_i915_criu_session)
+#define DRM_IOCTL_I915_CRIU_OBJECT \
+	_IOWR(DRM_IOCTL_BASE, DRM_COMMAND_BASE + 0x3e, struct drm_i915_criu_object)
+#define DRM_IOCTL_I915_CRIU_DATA \
+	_IOWR(DRM_IOCTL_BASE, DRM_COMMAND_BASE + 0x3f, struct drm_i915_criu_data)
+
+#endif
