++		args->cookie = fpriv->criu_cookie;
++		break;
++	case I915_CRIU_SESSION_COMMIT:
++		if (!args->cookie || args->cookie != fpriv->criu_cookie ||
++		    fpriv->criu_mode == I915_CRIU_MODE_NONE) {
++			ret = -ESTALE;
++			break;
++		}
++		xa_destroy(&fpriv->criu_restore_handles);
++		xa_init(&fpriv->criu_restore_handles);
++		fpriv->criu_mode = I915_CRIU_MODE_NONE;
++		fpriv->criu_cookie = 0;
++		break;
++	case I915_CRIU_SESSION_ABORT:
++		if (!args->cookie || args->cookie != fpriv->criu_cookie ||
++		    fpriv->criu_mode == I915_CRIU_MODE_NONE) {
++			ret = -ESTALE;
++			break;
++		}
++		if (fpriv->criu_mode == I915_CRIU_MODE_RESTORE)
++			abort_restore(file);
++		fpriv->criu_mode = I915_CRIU_MODE_NONE;
++		fpriv->criu_cookie = 0;
++		break;
++	default:
++		ret = -EINVAL;
++	}
++	mutex_unlock(&fpriv->criu_lock);
++
++	return ret;
++}
