+    echo 'sync-only, sync-file, external-sync-file, idle-context, callback, custom-engine, and virtual-engine modes are mutually exclusive' >&2
+    exit 2
+elif [[ $callback == 1 ]]; then
+    fixture_args+=(--callback)
+elif [[ $custom_engine == 1 ]]; then
+    fixture_args+=(--custom-engine)
+elif [[ $virtual_engine == 1 ]]; then
+    fixture_args+=(--virtual-engine)
+elif [[ $sync_file == 1 ]]; then
+    fixture_args+=(--sync-file)
+    expected_pass='PASS: binary syncobj, retained sync_file identity, timeline, and GPU submission'
+elif [[ $external_sync_file == 1 ]]; then
+    fixture_args+=(--external-sync-file-peer)
+elif [[ $sync_only == 1 ]]; then
+    fixture_args+=(--sync-only)
+    expected_pass='PASS: binary syncobj, timeline, and GPU submission'
+elif [[ $idle_context == 1 ]]; then
