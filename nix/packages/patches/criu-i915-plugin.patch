+int i915_plugin_dump_file(int fd, int id)
+{
+	struct dump_object *objects = NULL;
+	struct i915_image_syncobj *syncobjs = NULL;
+	struct i915_image_context *vms = NULL;
+	struct i915_image_context *contexts = NULL;
+	struct i915_image_binding *bindings = NULL;
+	size_t count = 0;
+	size_t syncobj_count = 0;
+	size_t vm_count = 0;
+	size_t context_count = 0;
+	size_t binding_count = 0;
+	uint64_t cookie = 0;
+	int ret;
+
+	if (!is_i915_fd(fd)) {
+		uint64_t object_id;
+
+		if (!is_dmabuf_fd(fd))
+			return -ENOTSUP;
+		ret = resolve_dmabuf_object(fd, &object_id);
+		if (ret)
+			return ret;
+		for (size_t i = 0; i < dump_dmabuf_file_count; i++) {
+			if (dump_dmabuf_files[i].file_id == id &&
+			    dump_dmabuf_files[i].object_id == object_id)
+				return 0;
+		}
+		return -EINVAL;
+	}
+	if (checkpoint_pid <= 0)
+		return -EINVAL;
+
+	ret = session_ioctl(fd, I915_CRIU_SESSION_DUMP_BEGIN,
+			    checkpoint_pid, &cookie);
+	if (ret)
+		return ret;
+	ret = collect_dump_objects(fd, cookie, &objects, &count);
+	if (!ret)
+		ret = collect_dump_syncobjs(fd, cookie, &syncobjs,
+					    &syncobj_count);
+	if (!ret)
+		ret = collect_dump_contexts(fd, cookie,
+					    I915_CRIU_CONTEXT_QUERY_VM,
+					    &vms, &vm_count,
+					    I915_MAX_RESTORE_VMS);
+	if (!ret)
+		ret = collect_dump_contexts(fd, cookie,
+					    I915_CRIU_CONTEXT_QUERY_CONTEXT,
+					    &contexts, &context_count,
+					    I915_MAX_RESTORE_CONTEXTS);
+	if (!ret)
+		ret = collect_dump_bindings(fd, cookie, vms, vm_count,
+					    &bindings, &binding_count);
+	if (!ret)
+		ret = write_image(id, objects, count, syncobjs, syncobj_count,
+				  vms, vm_count, contexts, context_count,
+				  bindings, binding_count);
+	if (session_ioctl(fd, ret ? I915_CRIU_SESSION_ABORT :
+				       I915_CRIU_SESSION_COMMIT,
+			  0, &cookie) && !ret)
+		ret = -EIO;
+	free_dump_objects(objects, count);
+	xfree(syncobjs);
+	xfree(vms);
+	xfree(contexts);
+	xfree(bindings);
+	return ret;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__DUMP_EXT_FILE, i915_plugin_dump_file)
