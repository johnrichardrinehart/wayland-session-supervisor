+#define I915_IMAGE_MAGIC UINT64_C(0x4939313543524955)
+#define I915_IMAGE_VERSION 6
+#define I915_IMAGE_KIND_DRM_FILE 1
+#define I915_IMAGE_KIND_DMABUF 2
+#define I915_MAX_RESTORE_OBJECTS 256
+#define I915_MAX_RESTORE_SYNCOBJS 256
+#define I915_MAX_RESTORE_VMS 64
+#define I915_MAX_RESTORE_CONTEXTS 64
+#define I915_MAX_RESTORE_BINDINGS 1024
+#define I915_MAX_RESTORE_FILES 32
+#define I915_MAX_OBJECT_SIZE (UINT64_C(1) << 30)
+
+struct i915_image_header {
+	uint64_t magic;
+	uint32_t version;
+	uint32_t file_id;
+	uint32_t object_count;
+	uint32_t syncobj_count;
+	uint32_t vm_count;
+	uint32_t context_count;
+	uint32_t binding_count;
+	uint32_t kind;
+};
+
+struct i915_image_object {
+	uint64_t object_id;
+	uint64_t size;
+	uint64_t mmap_offset;
+	uint32_t mmap_type;
+	uint32_t flags;
+	uint32_t handle_count;
+	uint32_t sharing_flags;
+	uint32_t dma_buf_refcount;
+	uint32_t dma_buf_attachment_count;
+};
+
+struct i915_image_syncobj {
+	uint32_t handle;
+	uint32_t flags;
+	uint64_t point;
+};
+
+struct i915_image_context {
+	uint32_t id;
+	uint32_t flags;
+	uint32_t vm_id;
+	int32_t priority;
+};
+
+struct i915_image_binding {
+	uint32_t vm_id;
+	uint32_t flags;
+	uint64_t object_id;
+	uint64_t address;
+	uint64_t size;
+};
+
+struct i915_image_dmabuf {
+	uint64_t object_id;
+	uint32_t fd_count;
+	uint32_t reserved;
+};
+
+struct dump_object {
+	struct i915_image_object image;
+	void *data;
+};
+
+struct object_relationship {
+	uint64_t object_id;
+	uint32_t expected_handles;
+	uint32_t seen_handles;
+	uint32_t expected_dma_buf_refcount;
+	uint32_t seen_dma_buf_fds;
+	uint32_t verification_handle;
+	int verification_fd;
+	bool metadata_seen;
+};
+
+struct dump_dmabuf_file {
+	int file_id;
+	uint64_t object_id;
+	uint32_t fd_count;
+};
+
+struct restore_object {
+	uint64_t object_id;
+	uint64_t old_mmap_offset;
+	uint64_t new_mmap_offset;
+	uint64_t size;
+	uint32_t handle_count;
+	uint32_t sharing_flags;
+	uint32_t dma_buf_refcount;
+	uint32_t restored_dma_buf_fds;
+	uint32_t handle;
+	uint32_t restored_handles;
+	int transient_fd;
+	int fdstore_id;
+	int prime_fdstore_id;
+};
+
+struct restore_file {
+	int fdstore_id;
+	uint64_t cookie;
+	bool active;
+};
+
+struct prepared_file {
+	int file_id;
+	int fdstore_id;
+};
+
+static int checkpoint_pid = -1;
+static bool inventory_added;
+static struct object_relationship dump_relationships[I915_MAX_RESTORE_OBJECTS];
+static size_t dump_relationship_count;
+static struct dump_dmabuf_file dump_dmabuf_files[I915_MAX_RESTORE_FILES];
+static size_t dump_dmabuf_file_count;
+static struct restore_object restore_objects[I915_MAX_RESTORE_OBJECTS];
+static size_t restore_object_count;
+static struct restore_file restore_files[I915_MAX_RESTORE_FILES];
+static size_t restore_file_count;
+static struct prepared_file prepared_files[I915_MAX_RESTORE_FILES];
+static size_t prepared_file_count;
+
+static const char *render_node(void)
+{
+	const char *configured = getenv("I915_CRIU_DRM_DEVICE");
+
+	return configured && configured[0] ? configured : "/dev/dri/renderD128";
+}
+
+static bool is_i915_fd(int fd)
+{
+	drmVersionPtr version = drmGetVersion(fd);
+	bool match = version && version->name && !strcmp(version->name, "i915");
+
+	if (version)
+		drmFreeVersion(version);
+	return match;
+}
+
+static bool is_dmabuf_fd(int fd)
+{
+	struct statfs statfs;
+
+	return !fstatfs(fd, &statfs) &&
+		(uint64_t)statfs.f_type == (uint64_t)DMA_BUF_MAGIC;
+}
+
+static int image_fd(int file_id, int flags)
+{
+	char name[64];
+
+	snprintf(name, sizeof(name), "i915-criu-%d.img", file_id);
+	return openat(criu_get_image_dir(), name, flags, 0600);
+}
+
+static int write_all(int fd, const void *data, size_t size)
+{
+	const char *cursor = data;
+
+	while (size) {
+		ssize_t written = write(fd, cursor, size);
+		if (written < 0) {
+			if (errno == EINTR)
+				continue;
+			return -errno;
+		}
+		cursor += written;
+		size -= written;
+	}
+	return 0;
+}
+
+static int pwrite_all(int fd, const void *data, size_t size, off_t offset)
+{
+	const char *cursor = data;
+
+	while (size) {
+		ssize_t written = pwrite(fd, cursor, size, offset);
+		if (written < 0) {
+			if (errno == EINTR)
+				continue;
+			return -errno;
+		}
+		if (!written)
+			return -EIO;
+		cursor += written;
+		offset += written;
+		size -= written;
+	}
+	return 0;
+}
+
+static int read_all(int fd, void *data, size_t size)
+{
+	char *cursor = data;
+
+	while (size) {
+		ssize_t got = read(fd, cursor, size);
+		if (got == 0)
+			return -EIO;
+		if (got < 0) {
+			if (errno == EINTR)
+				continue;
+			return -errno;
+		}
+		cursor += got;
+		size -= got;
+	}
+	return 0;
+}
+
+static int session_ioctl(int fd, uint32_t op, int pid, uint64_t *cookie)
+{
+	struct drm_i915_criu_session session = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = op,
+		.target_pid = pid,
+		.cookie = *cookie,
+	};
+
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_SESSION, &session) < 0)
+		return -errno;
+	*cookie = session.cookie;
+	return 0;
+}
+
+static int resolve_dmabuf_object(int dmabuf_fd, uint64_t *object_id)
+{
+	struct drm_i915_criu_object query = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_OBJECT_QUERY,
+	};
+	struct drm_gem_close close_handle;
+	uint64_t cookie = 0;
+	uint32_t handle;
+	int fd;
+	int ret;
+
+	fd = open(render_node(), O_RDWR | O_CLOEXEC);
+	if (fd < 0)
+		return errno == ENOENT || errno == ENODEV ? -ENOTSUP : -errno;
+	if (!is_i915_fd(fd)) {
+		close(fd);
+		return -ENOTSUP;
+	}
+	ret = drmPrimeFDToHandle(fd, dmabuf_fd, &handle);
+	if (ret)
+		goto out;
+	close_handle = (struct drm_gem_close) { .handle = handle };
+	ret = session_ioctl(fd, I915_CRIU_SESSION_DUMP_BEGIN,
+			    checkpoint_pid, &cookie);
+	if (ret)
+		goto close_handle;
+	query.cookie = cookie;
+	query.handle = handle - 1;
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_OBJECT, &query) < 0)
+		ret = -errno;
+	else if (query.handle != handle || !query.object_id ||
+		 !(query.sharing_flags & I915_CRIU_OBJECT_SHARED))
+		ret = -EXDEV;
+	else
+		*object_id = query.object_id;
+	if (session_ioctl(fd, ret ? I915_CRIU_SESSION_ABORT :
+				       I915_CRIU_SESSION_COMMIT,
+			  0, &cookie) && !ret)
+		ret = -EIO;
+close_handle:
+	ioctl(fd, DRM_IOCTL_GEM_CLOSE, &close_handle);
+out:
+	close(fd);
+	return ret;
+}
+
+static int write_dmabuf_image(int file_id, uint64_t object_id,
+			      uint32_t fd_count)
+{
+	struct i915_image_header header = {
+		.magic = I915_IMAGE_MAGIC,
+		.version = I915_IMAGE_VERSION,
+		.file_id = file_id,
+		.kind = I915_IMAGE_KIND_DMABUF,
+	};
+	struct i915_image_dmabuf image = {
+		.object_id = object_id,
+		.fd_count = fd_count,
+	};
+	int fd = image_fd(file_id, O_WRONLY | O_CREAT | O_EXCL);
+	int ret;
+
+	if (fd < 0)
+		return fd;
+	ret = write_all(fd, &header, sizeof(header));
+	if (!ret)
+		ret = write_all(fd, &image, sizeof(image));
+	if (close(fd) && !ret)
+		ret = -errno;
+	return ret;
+}
+
+static void free_dump_objects(struct dump_object *objects, size_t count)
+{
+	for (size_t i = 0; i < count; i++)
+		xfree(objects[i].data);
+	xfree(objects);
+}
+
+static struct object_relationship *dump_relationship(uint64_t object_id)
+{
+	for (size_t i = 0; i < dump_relationship_count; i++) {
+		if (dump_relationships[i].object_id == object_id)
+			return &dump_relationships[i];
+	}
+	if (dump_relationship_count == I915_MAX_RESTORE_OBJECTS)
+		return NULL;
+	dump_relationships[dump_relationship_count] =
+		(struct object_relationship) {
+			.object_id = object_id,
+			.verification_fd = -1,
+		};
+	return &dump_relationships[dump_relationship_count++];
+}
+
+static int record_dump_relationship(int fd, uint32_t handle,
+				    uint64_t object_id,
+				    uint32_t expected_handles,
+				    uint32_t dma_buf_attachment_count)
+{
+	struct object_relationship *relationship = dump_relationship(object_id);
+
+	if (!relationship)
+		return -E2BIG;
+	if (dma_buf_attachment_count)
+		return -EOPNOTSUPP;
+	if (relationship->metadata_seen &&
+	    relationship->expected_handles != expected_handles)
+		return -EINVAL;
+	if (relationship->verification_fd < 0) {
+		relationship->verification_fd = dup(fd);
+		if (relationship->verification_fd < 0)
+			return -errno;
+		relationship->verification_handle = handle;
+	}
+	relationship->metadata_seen = true;
+	relationship->expected_handles = expected_handles;
+	relationship->seen_handles++;
+	return 0;
+}
+
+static int record_dump_dmabuf_reference(uint64_t object_id)
+{
+	struct object_relationship *relationship = dump_relationship(object_id);
+
+	if (!relationship)
+		return -E2BIG;
+	if (relationship->seen_dma_buf_fds == UINT32_MAX)
+		return -EOVERFLOW;
+	relationship->seen_dma_buf_fds++;
+	return 0;
+}
+
+static int collect_dump_objects(int fd, uint64_t cookie,
+				struct dump_object **result, size_t *result_count)
+{
+	struct dump_object *objects = NULL;
+	size_t count = 0;
+	size_t allocated_count = 0;
+	uint32_t cursor = 0;
+	int ret = 0;
+
+	for (;;) {
+		struct drm_i915_criu_object query = {
+			.version = I915_CRIU_ABI_VERSION,
+			.op = I915_CRIU_OBJECT_QUERY,
+			.cookie = cookie,
+			.handle = cursor,
+		};
+		struct drm_i915_criu_data read_data;
+		struct dump_object *grown;
+
+		if (ioctl(fd, DRM_IOCTL_I915_CRIU_OBJECT, &query) < 0) {
+			if (errno == ENOENT)
+				break;
+			ret = -errno;
+			goto err;
+		}
+		if (count == I915_MAX_RESTORE_OBJECTS) {
+			ret = -E2BIG;
+			goto err;
+		}
+
+		grown = xrealloc(objects, (count + 1) * sizeof(*objects));
+		if (!grown) {
+			free_dump_objects(objects, count);
+			return -ENOMEM;
+		}
+		objects = grown;
+		memset(&objects[count], 0, sizeof(objects[count]));
+		allocated_count = count + 1;
+		objects[count].image.object_id = query.object_id;
+		objects[count].image.size = query.size;
+		objects[count].image.mmap_offset = query.mmap_offset;
+		objects[count].image.mmap_type = query.mmap_type;
+		objects[count].image.flags = query.flags;
+		objects[count].image.handle_count = query.handle_count;
+		objects[count].image.sharing_flags = query.sharing_flags;
+		objects[count].image.dma_buf_refcount = query.dma_buf_refcount;
+		objects[count].image.dma_buf_attachment_count =
+			query.dma_buf_attachment_count;
+		ret = record_dump_relationship(fd, query.handle, query.object_id,
+					       query.handle_count,
+					       query.dma_buf_attachment_count);
+		if (ret)
+			goto err;
+		objects[count].data = xmalloc(query.size);
+		if (!objects[count].data) {
+			ret = -ENOMEM;
+			goto err;
+		}
+
+		read_data = (struct drm_i915_criu_data) {
+			.version = I915_CRIU_ABI_VERSION,
+			.op = I915_CRIU_DATA_READ,
+			.cookie = cookie,
+			.handle = query.handle,
+			.size = query.size,
+			.data_ptr = (uintptr_t)objects[count].data,
+		};
+		if (ioctl(fd, DRM_IOCTL_I915_CRIU_DATA, &read_data) < 0) {
+			ret = -errno;
+			goto err;
+		}
+		cursor = query.handle;
+		count++;
+	}
+
+	*result = objects;
+	*result_count = count;
+	return 0;
+err:
+	free_dump_objects(objects, allocated_count);
+	return ret;
+}
+
+static int collect_dump_syncobjs(int fd, uint64_t cookie,
+				 struct i915_image_syncobj **result,
+				 size_t *result_count)
+{
+	struct i915_image_syncobj *syncobjs = NULL;
+	size_t count = 0;
+	uint32_t cursor = 0;
+
+	for (;;) {
+		struct drm_i915_criu_syncobj query = {
+			.version = I915_CRIU_ABI_VERSION,
+			.op = I915_CRIU_SYNCOBJ_QUERY,
+			.cookie = cookie,
+			.handle = cursor,
+		};
+		struct i915_image_syncobj *grown;
+
+		if (ioctl(fd, DRM_IOCTL_I915_CRIU_SYNCOBJ, &query) < 0) {
+			if (errno == ENOENT)
+				break;
+			xfree(syncobjs);
+			return -errno;
+		}
+		if (count == I915_MAX_RESTORE_SYNCOBJS || query.handle <= cursor) {
+			xfree(syncobjs);
+			return -E2BIG;
+		}
+		grown = xrealloc(syncobjs, (count + 1) * sizeof(*syncobjs));
+		if (!grown) {
+			xfree(syncobjs);
+			return -ENOMEM;
+		}
+		syncobjs = grown;
+		syncobjs[count++] = (struct i915_image_syncobj) {
+			.handle = query.handle,
+			.flags = query.flags,
+			.point = query.point,
+		};
+		cursor = query.handle;
+	}
+	*result = syncobjs;
+	*result_count = count;
+	return 0;
+}
+
+static int collect_dump_contexts(int fd, uint64_t cookie, uint32_t op,
+				 struct i915_image_context **result,
+				 size_t *result_count, size_t limit)
+{
+	struct i915_image_context *states = NULL;
+	size_t count = 0;
+	uint32_t cursor = 0;
+
+	for (;;) {
+		struct drm_i915_criu_context query = {
+			.version = I915_CRIU_ABI_VERSION,
+			.op = op,
+			.cookie = cookie,
+			.id = cursor,
+		};
+		struct i915_image_context *grown;
+
+		if (ioctl(fd, DRM_IOCTL_I915_CRIU_CONTEXT, &query) < 0) {
+			if (errno == ENOENT)
+				break;
+			xfree(states);
+			return -errno;
+		}
+		if (count == limit || query.id <= cursor) {
+			xfree(states);
+			return -E2BIG;
+		}
+		grown = xrealloc(states, (count + 1) * sizeof(*states));
+		if (!grown) {
+			xfree(states);
+			return -ENOMEM;
+		}
+		states = grown;
+		states[count++] = (struct i915_image_context) {
+			.id = query.id,
+			.flags = query.flags,
+			.vm_id = query.vm_id,
+			.priority = query.priority,
+		};
+		cursor = query.id;
+	}
+	*result = states;
+	*result_count = count;
+	return 0;
+}
+
+static int collect_dump_bindings(int fd, uint64_t cookie,
+				 const struct i915_image_context *vms,
+				 size_t vm_count,
+				 struct i915_image_binding **result,
+				 size_t *result_count)
+{
+	struct i915_image_binding *bindings = NULL;
+	size_t count = 0;
+
+	for (size_t vm_index = 0; vm_index < vm_count; vm_index++) {
+		uint64_t cursor = 0;
+		uint64_t previous_address = 0;
+
+		for (;;) {
+			struct drm_i915_criu_binding query = {
+				.version = I915_CRIU_ABI_VERSION,
+				.op = I915_CRIU_BINDING_QUERY,
+				.cookie = cookie,
+				.vm_id = vms[vm_index].id,
+				.cursor = cursor,
+				.address = previous_address,
+			};
+			struct i915_image_binding *grown;
+
+			if (ioctl(fd, DRM_IOCTL_I915_CRIU_BINDING, &query) < 0) {
+				if (errno == ENOENT)
+					break;
+				xfree(bindings);
+				return -errno;
+			}
+			if (count == I915_MAX_RESTORE_BINDINGS ||
+			    query.cursor != cursor + 1 ||
+			    (cursor && query.address <= previous_address)) {
+				xfree(bindings);
+				return -E2BIG;
+			}
+			grown = xrealloc(bindings,
+					 (count + 1) * sizeof(*bindings));
+			if (!grown) {
+				xfree(bindings);
+				return -ENOMEM;
+			}
+			bindings = grown;
+			bindings[count++] = (struct i915_image_binding) {
+				.vm_id = query.vm_id,
+				.flags = query.flags,
+				.object_id = query.object_id,
+				.address = query.address,
+				.size = query.size,
+			};
+			cursor = query.cursor;
+			previous_address = query.address;
+		}
+	}
+	*result = bindings;
+	*result_count = count;
+	return 0;
+}
+
+static int write_image(int file_id, struct dump_object *objects, size_t count,
+		       const struct i915_image_syncobj *syncobjs,
+		       size_t syncobj_count,
+		       const struct i915_image_context *vms, size_t vm_count,
+		       const struct i915_image_context *contexts,
+		       size_t context_count,
+		       const struct i915_image_binding *bindings,
+		       size_t binding_count)
+{
+	struct i915_image_header header = {
+		.magic = I915_IMAGE_MAGIC,
+		.version = I915_IMAGE_VERSION,
+		.file_id = file_id,
+		.object_count = count,
+		.syncobj_count = syncobj_count,
+		.vm_count = vm_count,
+		.context_count = context_count,
+		.binding_count = binding_count,
+		.kind = I915_IMAGE_KIND_DRM_FILE,
+	};
+	int fd = image_fd(file_id, O_WRONLY | O_CREAT | O_EXCL);
+	int ret;
+
+	if (fd < 0)
+		return -errno;
+	ret = write_all(fd, &header, sizeof(header));
+	for (size_t i = 0; !ret && i < count; i++) {
+		ret = write_all(fd, &objects[i].image, sizeof(objects[i].image));
+		if (!ret)
+			ret = write_all(fd, objects[i].data, objects[i].image.size);
+	}
+	if (!ret && syncobj_count)
+		ret = write_all(fd, syncobjs,
+				syncobj_count * sizeof(*syncobjs));
+	if (!ret && vm_count)
+		ret = write_all(fd, vms, vm_count * sizeof(*vms));
+	if (!ret && context_count)
+		ret = write_all(fd, contexts,
+				context_count * sizeof(*contexts));
+	if (!ret && binding_count)
+		ret = write_all(fd, bindings,
+				binding_count * sizeof(*bindings));
+	if (close(fd) && !ret)
+		ret = -errno;
+	return ret;
+}
+
+static int i915_plugin_init(int stage)
+{
+	if (stage == CR_PLUGIN_STAGE__RESTORE &&
+	    !check_and_remove_inventory_plugin(CR_PLUGIN_DESC.name,
+				       strlen(CR_PLUGIN_DESC.name)))
+		return 0;
+
+	checkpoint_pid = -1;
+	inventory_added = false;
+	dump_relationship_count = 0;
+	dump_dmabuf_file_count = 0;
+	restore_object_count = 0;
+	restore_file_count = 0;
+	prepared_file_count = 0;
+	return 0;
+}
+
+static void abort_restore_sessions(void)
+{
+	for (size_t i = 0; i < restore_file_count; i++) {
+		if (!restore_files[i].active)
+			continue;
+		int fd = criu_plugin_fdstore_get(restore_files[i].fdstore_id);
+
+		if (fd < 0 ||
+		    session_ioctl(fd, I915_CRIU_SESSION_ABORT, 0,
+				  &restore_files[i].cookie))
+			pr_err("failed to abort i915 restore transaction\n");
+		if (fd >= 0)
+			close(fd);
+		restore_files[i].active = false;
+	}
+}
+
+static void i915_plugin_fini(int stage, int ret)
+{
+	for (size_t i = 0; i < dump_relationship_count; i++) {
+		if (dump_relationships[i].verification_fd >= 0)
+			close(dump_relationships[i].verification_fd);
+		dump_relationships[i].verification_fd = -1;
+	}
+	if (stage == CR_PLUGIN_STAGE__RESTORE && ret)
+		abort_restore_sessions();
+}
