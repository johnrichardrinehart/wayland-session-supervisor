+static int collect_dump_contexts(int fd, uint64_t cookie, uint32_t op,
+				 struct i915_image_context **result,
+				 size_t *result_count, size_t limit)
+{
+	struct i915_image_context *states = NULL;
+	size_t count = 0;
+	uint32_t cursor = 0;
+
+	for (;;) {
+		struct drm_i915_criu_engine
+			engines[I915_CRIU_MAX_CONTEXT_ENGINES] = {0};
+		struct drm_i915_criu_context query = {
+			.version = I915_CRIU_ABI_VERSION,
+			.op = op,
+			.cookie = cookie,
+			.id = cursor,
+		};
+		struct i915_image_context image;
+		struct i915_image_context *grown;
+
+		if (op == I915_CRIU_CONTEXT_QUERY_CONTEXT) {
+			query.engine_count = I915_CRIU_MAX_CONTEXT_ENGINES;
+			query.engines_ptr = (uintptr_t)engines;
+		}
+		if (ioctl(fd, DRM_IOCTL_I915_CRIU_CONTEXT, &query) < 0) {
+			if (errno == ENOENT)
+				break;
+			xfree(states);
+			return -errno;
+		}
+		if (count == limit || query.id <= cursor ||
+		    query.engine_count > I915_CRIU_MAX_CONTEXT_ENGINES ||
+		    (op == I915_CRIU_CONTEXT_QUERY_VM &&
+		     (query.engine_count || query.engines_ptr)) ||
+		    (op == I915_CRIU_CONTEXT_QUERY_CONTEXT && query.engine_count &&
+		     !(query.flags & I915_CRIU_CONTEXT_USER_ENGINES))) {
+			xfree(states);
+			return -E2BIG;
+		}
+		grown = xrealloc(states, (count + 1) * sizeof(*states));
+		if (!grown) {
+			xfree(states);
+			return -ENOMEM;
+		}
+		states = grown;
+		image = (struct i915_image_context){
+			.id = query.id,
+			.flags = query.flags,
+			.vm_id = query.vm_id,
+			.priority = query.priority,
+			.engine_count = query.engine_count,
+		};
+		if (query.engine_count)
+			memcpy(image.engines, engines,
+			       query.engine_count * sizeof(engines[0]));
+		states[count++] = image;
+		cursor = query.id;
+	}
+	*result = states;
+	*result_count = count;
+	return 0;
+}
+
+static int collect_dump_bindings(int fd, uint64_t cookie,
+				 const struct i915_image_context *vms,
+				 size_t vm_count,
+				 struct i915_image_binding **result,
+				 size_t *result_count)
+{
+	struct i915_image_binding *bindings = NULL;
+	size_t count = 0;
+
+	for (size_t vm_index = 0; vm_index < vm_count; vm_index++) {
+		uint64_t cursor = 0;
+		uint64_t previous_address = 0;
+
+		for (;;) {
+			struct drm_i915_criu_binding query = {
+				.version = I915_CRIU_ABI_VERSION,
+				.op = I915_CRIU_BINDING_QUERY,
+				.cookie = cookie,
+				.vm_id = vms[vm_index].id,
+				.cursor = cursor,
+				.address = previous_address,
+			};
+			struct i915_image_binding *grown;
+
+			if (ioctl(fd, DRM_IOCTL_I915_CRIU_BINDING, &query) < 0) {
+				if (errno == ENOENT)
+					break;
+				xfree(bindings);
+				return -errno;
+			}
+			if (count == I915_MAX_RESTORE_BINDINGS ||
+			    query.cursor != cursor + 1 ||
+			    (cursor && query.address <= previous_address)) {
+				xfree(bindings);
+				return -E2BIG;
+			}
+			grown = xrealloc(bindings,
+					 (count + 1) * sizeof(*bindings));
+			if (!grown) {
+				xfree(bindings);
