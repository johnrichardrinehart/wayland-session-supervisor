+int i915_plugin_handle_anon_device_vma(const char *name, int pid,
+				       uint64_t start, uint64_t pgoff,
+				       int *surrogate_fd)
+{
+	long page_size = sysconf(_SC_PAGESIZE);
+	int fd;
+
+	(void)start;
+	if (strcmp(name, "anon_inode:i915.gem"))
+		return 0;
+	if (page_size <= 0 || !pgoff || pgoff % (uint64_t)page_size)
+		return -EINVAL;
+	for (size_t i = 0; i < dump_vma_count; i++)
+		if (dump_vmas[i].pgoff == pgoff)
+			goto open_surrogate;
+	if (dump_vma_count == I915_MAX_RESTORE_MAPPINGS)
+		return -E2BIG;
+	dump_vmas[dump_vma_count++].pgoff = pgoff;
+open_surrogate:
+	fd = open_dump_render_node(pid);
+	if (fd < 0)
+		return fd;
+	if (!is_i915_fd(fd)) {
+		close(fd);
+		return -ENODEV;
+	}
+	*surrogate_fd = fd;
+	return 1;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__HANDLE_ANON_DEVICE_VMA,
+			i915_plugin_handle_anon_device_vma)
+
+int i915_plugin_handle_device_vma(int fd, const struct stat *st)
+{
+	(void)st;
+	if (!is_i915_fd(fd))
+		return -ENOTSUP;
+	if (!inventory_added) {
+		int ret = add_inventory_plugin(CR_PLUGIN_DESC.name);
+		if (ret)
+			return ret;
+		inventory_added = true;
+	}
+	return 0;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__HANDLE_DEVICE_VMA,
+			i915_plugin_handle_device_vma)
+
+static int record_dump_dmabuf_file(int file_id, uint64_t object_id)
+{
+	for (size_t i = 0; i < dump_dmabuf_file_count; i++) {
+		struct dump_dmabuf_file *file = &dump_dmabuf_files[i];
+
+		if (file->file_id != file_id)
+			continue;
+		if (file->object_id != object_id || file->fd_count == UINT32_MAX)
+			return -EINVAL;
+		file->fd_count++;
+		return 0;
+	}
+	if (dump_dmabuf_file_count == I915_MAX_RESTORE_FILES)
+		return -E2BIG;
+	dump_dmabuf_files[dump_dmabuf_file_count++] =
+		(struct dump_dmabuf_file){
+			.file_id = file_id,
+			.object_id = object_id,
+			.fd_count = 1,
+		};
+	return 0;
+}
+
+static int record_dump_sync_file(int file_id, int fd)
+{
+	struct dump_sync_file *file;
+
+	for (size_t i = 0; i < dump_sync_file_count; i++) {
+		file = &dump_sync_files[i];
+		if (file->file_id != file_id)
+			continue;
+		if (file->fd_count == UINT32_MAX)
+			return -EOVERFLOW;
+		file->fd_count++;
+		return 0;
+	}
+	if (dump_sync_file_count == I915_MAX_RESTORE_FILES)
+		return -E2BIG;
+	file = &dump_sync_files[dump_sync_file_count++];
+	*file = (struct dump_sync_file){
+		.file_id = file_id,
+		.retained_fd = dup(fd),
+		.fd_count = 1,
+	};
+	if (file->retained_fd < 0)
+		return -errno;
+	return 0;
+}
+
+static int record_dump_drm_file(int file_id, int fd)
+{
+	for (size_t i = 0; i < dump_drm_file_count; i++) {
+		if (dump_drm_files[i].file_id == file_id)
+			return -EEXIST;
+	}
+	if (dump_drm_file_count == I915_MAX_RESTORE_FILES)
+		return -E2BIG;
+	dump_drm_files[dump_drm_file_count] = (struct dump_drm_file){
+		.file_id = file_id,
+		.retained_fd = dup(fd),
+	};
+	if (dump_drm_files[dump_drm_file_count].retained_fd < 0)
+		return -errno;
+	dump_drm_file_count++;
+	return 0;
+}
+
+int i915_plugin_handle_ext_file_reference(int fd, int id)
+{
+	uint64_t object_id;
+	int ret;
+
+	if (is_sync_file_fd(fd))
+		return record_dump_sync_file(id, fd);
+	if (!is_dmabuf_fd(fd))
+		return -ENOTSUP;
+	ret = resolve_dmabuf_object(fd, &object_id);
+	if (ret)
+		return ret;
+	ret = record_dump_dmabuf_reference(object_id);
+	if (ret)
+		return ret;
+	return record_dump_dmabuf_file(id, object_id);
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__HANDLE_EXT_FILE_REFERENCE,
+			i915_plugin_handle_ext_file_reference)
+
+int i915_plugin_dump_file(int fd, int id)
+{
+	struct dump_object *objects = NULL;
+	struct i915_image_mapping *mappings = NULL;
+	struct i915_image_syncobj *syncobjs = NULL;
+	struct i915_image_context *vms = NULL;
+	struct i915_image_context *contexts = NULL;
+	struct i915_image_binding *bindings = NULL;
+	struct i915_image_framebuffer *framebuffers = NULL;
+	struct dump_blob *blobs = NULL;
+	struct i915_image_kms_property *kms_properties = NULL;
+	size_t count = 0;
+	size_t mapping_count = 0;
+	size_t syncobj_count = 0;
+	size_t vm_count = 0;
+	size_t context_count = 0;
+	size_t binding_count = 0;
+	size_t framebuffer_count = 0;
+	size_t blob_count = 0;
+	size_t kms_property_count = 0;
+	uint32_t file_flags = 0;
+	struct i915_device_identity identity = {0};
+	const char *stage = "classification";
+	uint64_t cookie = 0;
+	int ret;
+
+	if (!is_i915_fd(fd)) {
+		uint64_t object_id;
+
+		if (is_sync_file_fd(fd)) {
+			for (size_t i = 0; i < dump_sync_file_count; i++) {
+				if (dump_sync_files[i].file_id == id)
+					return 0;
+			}
+			return -EINVAL;
+		}
+		if (!is_dmabuf_fd(fd))
+			return -ENOTSUP;
+		ret = resolve_dmabuf_object(fd, &object_id);
+		if (ret)
+			return ret;
+		for (size_t i = 0; i < dump_dmabuf_file_count; i++) {
+			if (dump_dmabuf_files[i].file_id == id &&
+			    dump_dmabuf_files[i].object_id == object_id)
+				return 0;
+		}
+		return -EINVAL;
+	}
+	if (checkpoint_pid <= 0)
+		return -EINVAL;
+
+	stage = "session-begin";
+	ret = session_ioctl(fd, I915_CRIU_SESSION_DUMP_BEGIN,
+			    checkpoint_pid, &cookie);
+	if (ret) {
+		pr_err("i915 dump file=%d stage=%s failed: %d\n", id, stage, ret);
+		return ret == -ENOTSUP ? -ENOTRECOVERABLE : ret;
+	}
+	stage = "file-state";
+	ret = collect_dump_file_state(fd, cookie, &file_flags, &identity);
+	if (!ret) {
+		stage = "objects";
+		ret = collect_dump_objects(fd, cookie, &objects, &count);
+	}
+	if (!ret) {
+		stage = "mappings";
+		ret = collect_dump_mappings(fd, cookie, objects, count,
+					    &mappings, &mapping_count);
+	}
+	if (!ret) {
+		stage = "syncobjs";
+		ret = collect_dump_syncobjs(fd, cookie, &syncobjs,
+					    &syncobj_count);
+	}
+	if (!ret) {
+		stage = "vms";
+		ret = collect_dump_contexts(fd, cookie,
+					    I915_CRIU_CONTEXT_QUERY_VM,
+					    &vms, &vm_count,
+					    I915_MAX_RESTORE_VMS);
+	}
+	if (!ret) {
+		stage = "contexts";
+		ret = collect_dump_contexts(fd, cookie,
+					    I915_CRIU_CONTEXT_QUERY_CONTEXT,
+					    &contexts, &context_count,
+					    I915_MAX_RESTORE_CONTEXTS);
+	}
+	if (!ret) {
+		stage = "bindings";
+		ret = collect_dump_bindings(fd, cookie, vms, vm_count,
+					    &bindings, &binding_count);
+	}
+	if (!ret) {
+		stage = "framebuffers";
+		ret = collect_dump_framebuffers(fd, cookie, &framebuffers,
+						&framebuffer_count);
+	}
+	if (!ret) {
+		stage = "blobs";
+		ret = collect_dump_blobs(fd, cookie, &blobs, &blob_count);
+	}
+	if (!ret) {
+		stage = "kms-properties";
+		ret = collect_dump_kms_properties(fd, file_flags,
+						  &kms_properties,
+						  &kms_property_count);
+	}
+	if (!ret) {
+		stage = "image-write";
+		ret = write_image(id, objects, count, mappings, mapping_count,
+				  syncobjs, syncobj_count, vms, vm_count,
+				  contexts, context_count,
+				  bindings, binding_count, framebuffers,
+				  framebuffer_count, blobs, blob_count,
+				  kms_properties, kms_property_count, file_flags,
+				  &identity);
+	}
+	if (!ret)
+		stage = "session-commit";
+	if (session_ioctl(fd, ret ? I915_CRIU_SESSION_ABORT : I915_CRIU_SESSION_COMMIT,
+			  0, &cookie) &&
+	    !ret)
+		ret = -EIO;
+	free_dump_objects(objects, count);
+	xfree(mappings);
+	xfree(syncobjs);
+	xfree(vms);
+	xfree(contexts);
+	xfree(bindings);
+	xfree(framebuffers);
+	free_dump_blobs(blobs, blob_count);
+	xfree(kms_properties);
+	if (!ret) {
+		stage = "record-file";
+		ret = record_dump_drm_file(id, fd);
+	}
+	if (ret) {
+		pr_err("i915 dump file=%d stage=%s failed: %d\n", id, stage, ret);
+		if (ret == -ENOTSUP)
+			ret = -ENOTRECOVERABLE;
+	}
+	return ret;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__DUMP_EXT_FILE, i915_plugin_dump_file)
+
+static int refresh_dump_relationship(struct object_relationship *relationship)
+{
+	struct drm_i915_criu_object query = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_OBJECT_QUERY,
+		.handle = relationship->verification_handle - 1,
+	};
+	uint64_t cookie = 0;
+	int ret;
+
+	if (relationship->verification_fd < 0 ||
+	    !relationship->verification_handle)
+		return -EINVAL;
+	ret = session_ioctl(relationship->verification_fd,
+			    I915_CRIU_SESSION_DUMP_BEGIN,
+			    checkpoint_pid, &cookie);
+	if (ret)
+		goto out;
+	query.cookie = cookie;
+	if (ioctl(relationship->verification_fd,
+		  DRM_IOCTL_I915_CRIU_OBJECT, &query) < 0)
+		ret = -errno;
+	else if (query.handle != relationship->verification_handle ||
+		 query.object_id != relationship->object_id ||
+		 query.handle_count != relationship->expected_handles ||
+		 query.dma_buf_attachment_count)
+		ret = -EXDEV;
+	else
+		relationship->expected_dma_buf_refcount =
+			query.dma_buf_refcount;
+	if (session_ioctl(relationship->verification_fd,
+			  ret ? I915_CRIU_SESSION_ABORT :
+				I915_CRIU_SESSION_COMMIT,
+			  0, &cookie) &&
+	    !ret)
+		ret = -EIO;
+out:
+	close(relationship->verification_fd);
+	relationship->verification_fd = -1;
+	return ret;
+}
+
+static int patch_dump_image_refcounts(int file_id)
+{
+	struct i915_image_header header;
+	int fd = image_fd(file_id, O_RDWR);
+	int ret;
+
+	if (fd < 0)
+		return fd;
+	ret = read_all(fd, &header, sizeof(header));
+	if (ret || header.magic != I915_IMAGE_MAGIC ||
+	    header.version != I915_IMAGE_VERSION ||
+	    header.file_id != (uint32_t)file_id ||
+	    header.kind != I915_IMAGE_KIND_DRM_FILE) {
+		close(fd);
+		return ret ? ret : -EINVAL;
+	}
+	for (uint32_t i = 0; i < header.object_count; i++) {
+		struct i915_image_object object;
+		off_t offset = lseek(fd, 0, SEEK_CUR);
+		struct object_relationship *relationship;
+
+		if (offset < 0 || read_all(fd, &object, sizeof(object))) {
+			close(fd);
+			return -EIO;
+		}
+		relationship = dump_relationship(object.object_id);
+		if (!relationship || !relationship->metadata_seen) {
+			close(fd);
+			return -ENOENT;
+		}
+		object.dma_buf_refcount =
+			relationship->expected_dma_buf_refcount;
+		ret = pwrite_all(fd, &object, sizeof(object), offset);
+		if (ret || lseek(fd, object.size, SEEK_CUR) < 0) {
+			close(fd);
+			return ret ? ret : -EIO;
+		}
+	}
+	close(fd);
+	return 0;
+}
+
+static int patch_dump_images(void)
+{
+	DIR *directory;
+	struct dirent *entry;
+	int directory_fd = dup(criu_get_image_dir());
+	int ret = 0;
+
+	if (directory_fd < 0)
+		return -errno;
+	directory = fdopendir(directory_fd);
+	if (!directory) {
+		close(directory_fd);
+		return -errno;
+	}
+	while ((entry = readdir(directory))) {
+		char trailing;
+		int id;
+
+		if (sscanf(entry->d_name, "i915-criu-%d.img%c", &id,
+			   &trailing) != 1)
+			continue;
+		ret = patch_dump_image_refcounts(id);
+		if (ret)
+			break;
+	}
+	closedir(directory);
+	return ret;
+}
+
+static int query_dump_sync_file(struct dump_sync_file *file)
+{
+	bool matched = false;
+
+	for (size_t i = 0; i < dump_drm_file_count; i++) {
+		struct dump_drm_file *drm = &dump_drm_files[i];
+		struct drm_i915_criu_sync_file query = {
+			.version = I915_CRIU_ABI_VERSION,
+			.op = I915_CRIU_SYNC_FILE_QUERY,
+			.fd = file->retained_fd,
+		};
+		uint64_t cookie = 0;
+		int ret;
+
+		ret = session_ioctl(drm->retained_fd,
+				    I915_CRIU_SESSION_DUMP_BEGIN,
+				    checkpoint_pid, &cookie);
+		if (ret)
+			return ret;
+		query.cookie = cookie;
+		if (ioctl(drm->retained_fd, DRM_IOCTL_I915_CRIU_SYNC_FILE,
+			  &query) < 0)
+			ret = -errno;
+		if (session_ioctl(drm->retained_fd,
+				  ret ? I915_CRIU_SESSION_ABORT :
+					I915_CRIU_SESSION_COMMIT,
+				  0, &cookie) &&
+		    !ret)
+			ret = -EIO;
+		if (ret == -EXDEV)
+			continue;
+		if (ret)
+			return ret;
+		if (matched)
+			return -EXDEV;
+		matched = true;
+		file->source_file_id = drm->file_id;
+		file->handle = query.handle;
+		file->flags = query.flags;
+		file->expected_refcount = query.fd_refcount;
+		file->point = query.point;
+	}
+	if (!matched)
+		return -EXDEV;
+	if (file->expected_refcount != 1 + (uint64_t)file->fd_count)
+		return -EXDEV;
+	return 0;
+}
+
+int i915_plugin_finalize_devices(void)
+{
+	for (size_t i = 0; i < dump_relationship_count; i++) {
+		struct object_relationship *relationship = &dump_relationships[i];
+		uint64_t expected_dma_buf_refcount;
+
+		if (!relationship->metadata_seen) {
+			pr_err("i915 dma-buf object %#" PRIx64
+			       " has no captured GEM handle\n",
+			       relationship->object_id);
+			return -EXDEV;
+		}
+		if (refresh_dump_relationship(relationship)) {
+			pr_err("failed final i915 relationship query for object %#" PRIx64
+			       "\n",
+			       relationship->object_id);
+			return -EXDEV;
+		}
+		if (relationship->seen_handles != relationship->expected_handles) {
+			pr_err("i915 object %#" PRIx64
+			       " has %u captured handles but %u exist\n",
+			       relationship->object_id,
+			       relationship->seen_handles,
+			       relationship->expected_handles);
+			return -EXDEV;
+		}
+		expected_dma_buf_refcount = relationship->expected_dma_buf_refcount;
+		if (!expected_dma_buf_refcount &&
+		    relationship->seen_dma_buf_fds) {
+			pr_err("i915 object %#" PRIx64
+			       " has dma-buf fds but no exported dma-buf\n",
+			       relationship->object_id);
+			return -EXDEV;
+		}
+		if (expected_dma_buf_refcount &&
+		    expected_dma_buf_refcount !=
+			    1 + (uint64_t)relationship->expected_handles +
+				    relationship->seen_dma_buf_fds) {
+			pr_err("i915 object %#" PRIx64
+			       " has %u captured dma-buf fds but refcount %u is not complete\n",
+			       relationship->object_id,
+			       relationship->seen_dma_buf_fds,
+			       relationship->expected_dma_buf_refcount);
+			return -EXDEV;
+		}
+	}
+	for (size_t i = 0; i < dump_vma_count; i++) {
+		if (dump_vmas[i].resolved)
+			continue;
+		pr_err("i915 VMA offset %#" PRIx64
+		       " is not authorized by any captured DRM file\n",
+		       dump_vmas[i].pgoff);
+		return -EXDEV;
+	}
+	if (patch_dump_images())
+		return -EIO;
+	for (size_t i = 0; i < dump_dmabuf_file_count; i++) {
+		struct dump_dmabuf_file *file = &dump_dmabuf_files[i];
+		int ret = write_dmabuf_image(file->file_id, file->object_id,
+					     file->fd_count);
+
+		if (ret)
+			return ret;
+	}
+	for (size_t i = 0; i < dump_sync_file_count; i++) {
+		struct dump_sync_file *file = &dump_sync_files[i];
+		int ret = query_dump_sync_file(file);
+
+		if (ret) {
+			pr_err("i915 sync_file id %d has an incomplete or unsupported fence relationship\n",
+			       file->file_id);
+			return ret;
+		}
+		ret = write_sync_file_image(file);
+		if (ret)
+			return ret;
+	}
+	return 0;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__FINALIZE_DEVICES,
+			i915_plugin_finalize_devices)
+
+static int validate_image_object(const struct i915_image_object *image)
+{
+	if (!image->object_id || !image->size ||
+	    image->size > I915_MAX_OBJECT_SIZE ||
+	    image->flags != I915_CRIU_OBJECT_SHMEM ||
+	    image->mmap_type != I915_MMAP_OFFSET_WB ||
+	    !image->mmap_offset || !image->handle_count ||
+	    image->sharing_flags & ~I915_CRIU_OBJECT_SHARED ||
+	    image->dma_buf_attachment_count ||
+	    (image->dma_buf_refcount &&
+	     !(image->sharing_flags & I915_CRIU_OBJECT_SHARED)))
+		return -EINVAL;
+
+	for (size_t i = 0; i < restore_object_count; i++) {
+		if (restore_objects[i].object_id == image->object_id) {
+			if (restore_objects[i].old_mmap_offset != image->mmap_offset ||
+			    restore_objects[i].size != image->size ||
+			    restore_objects[i].handle_count != image->handle_count ||
+			    restore_objects[i].sharing_flags != image->sharing_flags ||
+			    restore_objects[i].dma_buf_refcount !=
+				    image->dma_buf_refcount)
+				return -EINVAL;
+			return 0;
+		}
+		if (restore_objects[i].old_mmap_offset == image->mmap_offset)
+			return -EEXIST;
+	}
+	return 0;
+}
+
+static int restore_object(int fd, uint64_t cookie,
+			  const struct i915_image_object *image,
+			  const void *contents)
+{
+	struct drm_i915_criu_object create = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_OBJECT_CREATE,
+		.cookie = cookie,
+		.flags = image->flags,
+		.object_id = image->object_id,
+		.size = image->size,
+		.handle_count = image->handle_count,
+		.sharing_flags = image->sharing_flags,
+	};
+	struct drm_i915_criu_data write_data;
+	struct drm_i915_gem_mmap_offset mmap_offset;
+
+	for (size_t i = 0; i < restore_object_count; i++) {
+		struct restore_object *existing = &restore_objects[i];
+		struct drm_i915_gem_pread pread;
+		void *verify;
+		uint32_t handle;
+		int object_fd;
+		int prime_fd;
+		int ret;
+
+		if (existing->object_id != image->object_id)
+			continue;
+		if (existing->prime_fdstore_id < 0)
+			return -EINVAL;
+		object_fd = existing->transient_fd >= 0 ? existing->transient_fd :
+							  criu_plugin_fdstore_get(existing->fdstore_id);
+		prime_fd = criu_plugin_fdstore_get(existing->prime_fdstore_id);
+		if (object_fd < 0 || prime_fd < 0) {
+			if (existing->transient_fd < 0 && object_fd >= 0)
+				close(object_fd);
+			if (prime_fd >= 0)
+				close(prime_fd);
+			return -EIO;
+		}
+		verify = xmalloc(image->size);
+		if (!verify) {
+			if (existing->transient_fd < 0)
+				close(object_fd);
+			close(prime_fd);
+			return -ENOMEM;
+		}
+		pread = (struct drm_i915_gem_pread){
+			.handle = existing->handle,
+			.size = image->size,
+			.data_ptr = (uintptr_t)verify,
+		};
+		if (ioctl(object_fd, DRM_IOCTL_I915_GEM_PREAD, &pread) < 0)
+			ret = -errno;
+		else
+			ret = memcmp(verify, contents, image->size) ? -EILSEQ : 0;
+		xfree(verify);
+		if (existing->transient_fd < 0)
+			close(object_fd);
+		if (!ret)
+			ret = drmPrimeFDToHandle(fd, prime_fd, &handle);
+		close(prime_fd);
+		if (ret)
+			return ret;
+		create.op = I915_CRIU_OBJECT_IMPORT;
+		create.handle = handle;
+		if (ioctl(fd, DRM_IOCTL_I915_CRIU_OBJECT, &create) < 0) {
+			ret = -errno;
+			struct drm_gem_close close_handle = { .handle = handle };
+			ioctl(fd, DRM_IOCTL_GEM_CLOSE, &close_handle);
+			return ret;
+		}
+		existing->restored_handles++;
+		return 0;
+	}
+
+	if (restore_object_count == I915_MAX_RESTORE_OBJECTS)
+		return -E2BIG;
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_OBJECT, &create) < 0)
+		return -errno;
+
+	write_data = (struct drm_i915_criu_data){
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_DATA_WRITE,
+		.cookie = cookie,
+		.handle = create.handle,
+		.size = image->size,
+		.data_ptr = (uintptr_t)contents,
+	};
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_DATA, &write_data) < 0)
+		return -errno;
+
+	mmap_offset = (struct drm_i915_gem_mmap_offset){
+		.handle = create.handle,
+		.flags = image->mmap_type,
+	};
+	if (ioctl(fd, DRM_IOCTL_I915_GEM_MMAP_OFFSET, &mmap_offset) < 0)
+		return -errno;
+
+	restore_objects[restore_object_count] = (struct restore_object){
+		.object_id = image->object_id,
+		.old_mmap_offset = image->mmap_offset,
+		.new_mmap_offset = mmap_offset.offset,
+		.size = image->size,
+		.handle_count = image->handle_count,
+		.sharing_flags = image->sharing_flags,
+		.dma_buf_refcount = image->dma_buf_refcount,
+		.handle = create.handle,
+		.restored_handles = 1,
+		.transient_fd = fd,
+		.fdstore_id = -1,
+		.prime_fdstore_id = -1,
+	};
+	if (image->handle_count > 1 ||
+	    image->sharing_flags & I915_CRIU_OBJECT_SHARED) {
+		int prime_fd;
+		int ret = drmPrimeHandleToFD(fd, create.handle,
+					     DRM_CLOEXEC | DRM_RDWR, &prime_fd);
+		if (ret)
+			return ret;
+		ret = criu_plugin_fdstore_add(prime_fd);
+		close(prime_fd);
+		if (ret < 0)
+			return -EIO;
+		restore_objects[restore_object_count].prime_fdstore_id = ret;
+	}
+	restore_object_count++;
+	return 0;
+}
+
+static int restore_syncobj(int fd, uint64_t cookie,
+			   const struct i915_image_syncobj *image,
+			   uint32_t previous_handle)
+{
+	const uint32_t supported = I915_CRIU_SYNCOBJ_EMPTY |
+				   I915_CRIU_SYNCOBJ_BINARY_SIGNALED |
+				   I915_CRIU_SYNCOBJ_TIMELINE;
+	struct drm_i915_criu_syncobj create = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_SYNCOBJ_CREATE,
+		.handle = image->handle,
+		.flags = image->flags,
+		.point = image->point,
+	};
+
+	if (!image->handle || image->handle <= previous_handle ||
+	    !image->flags || (image->flags & ~supported) ||
+	    (image->flags & (image->flags - 1)) ||
+	    (image->flags != I915_CRIU_SYNCOBJ_TIMELINE && image->point) ||
+	    (image->flags == I915_CRIU_SYNCOBJ_TIMELINE && !image->point))
+		return -EINVAL;
+	create.cookie = cookie;
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_SYNCOBJ, &create) < 0)
+		return -errno;
+	if (image->flags == I915_CRIU_SYNCOBJ_TIMELINE) {
+		uint32_t handle = create.handle;
+		uint64_t point = image->point;
+		struct drm_syncobj_timeline_array signal = {
+			.handles = (uintptr_t)&handle,
+			.points = (uintptr_t)&point,
+			.count_handles = 1,
+		};
+
+		if (ioctl(fd, DRM_IOCTL_SYNCOBJ_TIMELINE_SIGNAL, &signal) < 0)
+			return -errno;
+	}
+	return 0;
+}
+
+static int restore_context_state(int fd, uint64_t cookie,
+				 const struct i915_image_context *image,
+				 uint32_t op, uint32_t previous_id)
+{
+	const uint32_t supported = I915_CRIU_CONTEXT_SINGLE_TIMELINE |
+				   I915_CRIU_CONTEXT_NO_ERROR_CAPTURE |
+				   I915_CRIU_CONTEXT_BANNABLE |
+				   I915_CRIU_CONTEXT_RECOVERABLE |
+				   I915_CRIU_CONTEXT_PERSISTENCE |
+				   I915_CRIU_CONTEXT_USER_ENGINES;
+	struct drm_i915_criu_context create = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = op,
+		.cookie = cookie,
+		.id = image->id,
+		.flags = image->flags,
+		.vm_id = image->vm_id,
+		.priority = image->priority,
+		.engine_count = image->engine_count,
+		.engines_ptr = image->engine_count ?
+			(uintptr_t)image->engines : 0,
+	};
+
+	if (!image->id || image->id <= previous_id || image->pad ||
+	    image->engine_count > I915_CRIU_MAX_CONTEXT_ENGINES)
+		return -EINVAL;
+	for (uint32_t i = image->engine_count;
+	     i < I915_CRIU_MAX_CONTEXT_ENGINES; i++)
+		if (image->engines[i].engine_class ||
+		    image->engines[i].engine_instance)
+			return -EINVAL;
+	if (op == I915_CRIU_CONTEXT_CREATE_VM) {
+		if (image->flags || image->vm_id || image->priority ||
+		    image->engine_count)
+			return -EINVAL;
+	} else if (op == I915_CRIU_CONTEXT_CREATE_CONTEXT) {
+		if (image->flags & ~supported ||
+		    (image->engine_count &&
+		     !(image->flags & I915_CRIU_CONTEXT_USER_ENGINES)))
+			return -EINVAL;
+	} else {
+		return -EINVAL;
+	}
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_CONTEXT, &create) < 0)
+		return -errno;
+	return 0;
+}
+
+static int restore_binding(int fd, uint64_t cookie,
+			   const struct i915_image_binding *image,
+			   uint32_t previous_vm, uint64_t previous_address)
+{
+	struct drm_i915_criu_binding create = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_BINDING_CREATE,
+		.cookie = cookie,
+		.vm_id = image->vm_id,
+		.flags = image->flags,
+		.object_id = image->object_id,
+		.address = image->address,
+		.size = image->size,
+	};
+	bool object_found = false;
+
+	if (!image->vm_id || !image->object_id || !image->size ||
+	    image->flags != I915_CRIU_BINDING_LOCAL ||
+	    image->vm_id < previous_vm ||
+	    (image->vm_id == previous_vm && image->address <= previous_address))
+		return -EINVAL;
+	for (size_t i = 0; i < restore_object_count; i++) {
+		if (restore_objects[i].object_id == image->object_id) {
+			object_found = restore_objects[i].size == image->size;
+			break;
+		}
+	}
+	if (!object_found)
+		return -ENOENT;
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_BINDING, &create) < 0)
+		return -errno;
+	return 0;
+}
+
+static int restore_framebuffer(int fd, uint64_t cookie,
+			       const struct i915_image_framebuffer *image,
+			       uint32_t previous_id)
+{
+	struct drm_i915_criu_framebuffer create = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_FRAMEBUFFER_CREATE,
+		.cookie = cookie,
+		.id = image->id,
+		.flags = image->flags,
+		.object_id = image->object_id,
+		.width = image->width,
+		.height = image->height,
+		.pixel_format = image->pixel_format,
+		.pitch = image->pitch,
+		.offset = image->offset,
+		.modifier = image->modifier,
+	};
+
+	if (!image->id || image->id <= previous_id ||
+	    image->flags != I915_CRIU_FRAMEBUFFER_LINEAR ||
+	    !image->object_id || !image->width || !image->height ||
+	    image->pixel_format != DRM_FORMAT_XRGB8888 || !image->pitch ||
+	    image->offset || image->pad || image->modifier != DRM_FORMAT_MOD_LINEAR)
+		return -EINVAL;
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_FRAMEBUFFER, &create) < 0)
+		return -errno;
+	return 0;
+}
+
+static int restore_blob(int fd, uint64_t cookie,
+			const struct i915_image_blob *image,
+			const void *contents, uint32_t previous_id)
+{
+	struct drm_i915_criu_blob create = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_BLOB_CREATE,
+		.cookie = cookie,
+		.id = image->id,
+		.length = image->length,
+		.data_ptr = (uintptr_t)contents,
+	};
+
+	if (!image->id || image->id <= previous_id || !image->length ||
+	    image->length > I915_MAX_BLOB_SIZE)
+		return -EINVAL;
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_BLOB, &create) < 0)
+		return -errno;
+	return 0;
+}
+
+static int restore_mapping(int fd, uint64_t cookie, int file_id,
+			   const struct i915_image_mapping *image)
+{
+	struct drm_i915_criu_mapping create = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_MAPPING_CREATE,
+		.cookie = cookie,
+		.object_id = image->object_id,
+		.size = image->size,
+		.mmap_type = image->mmap_type,
+	};
+	bool object_found = false;
+
+	if (!image->object_id || !image->offset || !image->size || image->pad ||
+	    image->offset > UINT64_MAX - image->size ||
+	    image->mmap_type > I915_MMAP_OFFSET_UC ||
+	    restore_mapping_count == I915_MAX_RESTORE_MAPPINGS)
+		return -EINVAL;
+	for (size_t i = 0; i < restore_object_count; i++)
+		if (restore_objects[i].object_id == image->object_id &&
+		    restore_objects[i].size == image->size) {
+			object_found = true;
+			break;
+		}
+	if (!object_found)
+		return -ENOENT;
+	for (size_t i = 0; i < restore_mapping_count; i++) {
+		const struct restore_mapping *existing = &restore_mappings[i];
+
+		if (image->offset < existing->old_offset + existing->size &&
+		    existing->old_offset < image->offset + image->size)
+			return -EEXIST;
+	}
+	if (ioctl(fd, DRM_IOCTL_I915_CRIU_MAPPING, &create) < 0)
+		return -errno;
+	if (!create.offset || create.offset > UINT64_MAX - create.size ||
+	    create.size != image->size || create.mmap_type != image->mmap_type)
+		return -EXDEV;
+	restore_mappings[restore_mapping_count++] = (struct restore_mapping){
+		.object_id = image->object_id,
+		.old_offset = image->offset,
+		.new_offset = create.offset,
+		.size = image->size,
+		.mmap_type = image->mmap_type,
+		.file_id = file_id,
+	};
+	return 0;
+}
+
+static int remember_kms_property(int file_id,
+				 const struct i915_image_kms_property *image)
+{
+	if (!image->object_id || !image->property_id || image->reserved ||
+	    (image->object_type != DRM_MODE_OBJECT_CONNECTOR &&
+	     image->object_type != DRM_MODE_OBJECT_CRTC &&
+	     image->object_type != DRM_MODE_OBJECT_PLANE) ||
+	    restore_kms_property_count == I915_MAX_RESTORE_KMS_PROPERTIES)
+		return -EINVAL;
+	restore_kms_properties[restore_kms_property_count++] =
+		(struct restore_kms_property){
+			.file_id = file_id,
+			.image = *image,
+		};
+	return 0;
+}
+
+static int restore_file_image(int id)
+{
+	struct i915_image_header header;
+	struct restore_file *restore_file;
+	size_t mapping_base = restore_mapping_count;
+	size_t kms_property_base = restore_kms_property_count;
+	const char *stage = "image-header";
+	uint64_t resource_id = 0;
+	uint64_t cookie = 0;
+	uint32_t stage_index = 0;
+	int image;
+	int fd;
+	int ret;
+
+	image = image_fd(id, O_RDONLY);
+	if (image < 0)
+		return -ENOTSUP;
+	ret = read_all(image, &header, sizeof(header));
+	if (ret || header.magic != I915_IMAGE_MAGIC ||
+	    header.version != I915_IMAGE_VERSION || header.file_id != (uint32_t)id ||
+	    header.object_count > I915_MAX_RESTORE_OBJECTS ||
+	    header.mapping_count > I915_MAX_RESTORE_MAPPINGS ||
+	    header.syncobj_count > I915_MAX_RESTORE_SYNCOBJS ||
+	    header.vm_count > I915_MAX_RESTORE_VMS ||
+	    header.context_count > I915_MAX_RESTORE_CONTEXTS ||
+	    header.binding_count > I915_MAX_RESTORE_BINDINGS ||
+	    header.framebuffer_count > I915_MAX_RESTORE_FRAMEBUFFERS ||
+	    header.blob_count > I915_MAX_RESTORE_BLOBS ||
+	    header.kms_property_count > I915_MAX_RESTORE_KMS_PROPERTIES ||
+	    !(header.file_flags & (I915_CRIU_FILE_PRIMARY |
+				   I915_CRIU_FILE_RENDER)) ||
+	    !(header.device_identity & UINT32_C(0xffff)) ||
+	    !(header.device_identity >> 16) || header.revision > UINT8_MAX ||
+	    header.kind != I915_IMAGE_KIND_DRM_FILE) {
+		ret = ret ? ret : -EINVAL;
+		pr_err("i915 restore file=%d stage=%s failed: %d\n",
+		       id, stage, ret);
+		close(image);
+		return ret;
+	}
+
+	if (header.file_flags & I915_CRIU_FILE_PRIMARY)
+		fd = open_i915_primary();
+	else
+		fd = open(render_node(), O_RDWR | O_CLOEXEC);
+	if (fd < 0) {
+		close(image);
+		return fd == -ENODEV ? fd : -errno;
+	}
+	stage = "file-configuration";
+	ret = configure_restore_file(fd, header.file_flags);
+	if (ret) {
+		pr_err("i915 restore file=%d stage=%s failed: %d\n",
+		       id, stage, ret);
+		close(image);
+		close(fd);
+		return ret;
+	}
+	if (restore_file_count == I915_MAX_RESTORE_FILES) {
+		close(image);
+		close(fd);
+		return -E2BIG;
+	}
+
+	stage = "session-begin";
+	ret = session_ioctl(fd, I915_CRIU_SESSION_RESTORE_BEGIN, 0, &cookie);
+	if (!ret) {
+		struct drm_i915_criu_file restore = {
+			.version = I915_CRIU_ABI_VERSION,
+			.op = I915_CRIU_FILE_RESTORE,
+			.cookie = cookie,
+			.flags = header.file_flags,
+			.vendor_id = header.device_identity & UINT32_C(0xffff),
+			.device_id = header.device_identity >> 16,
+			.subsystem_vendor_id =
+				header.subsystem_identity & UINT32_C(0xffff),
+			.subsystem_device_id = header.subsystem_identity >> 16,
+			.revision = header.revision,
+		};
+
+		stage = "file-state";
+		if (ioctl(fd, DRM_IOCTL_I915_CRIU_FILE, &restore) < 0)
+			ret = -errno;
+	}
+	if (ret) {
+		pr_err("i915 restore file=%d stage=%s failed: %d\n",
+		       id, stage, ret);
+		close(image);
+		close(fd);
+		return ret;
+	}
+	for (uint32_t i = 0; i < header.object_count; i++) {
+		struct i915_image_object object;
+		void *contents;
+
+		stage = "object";
+		stage_index = i;
+		resource_id = 0;
+		ret = read_all(image, &object, sizeof(object));
+		if (!ret)
+			resource_id = object.object_id;
+		if (ret)
+			break;
+		ret = validate_image_object(&object);
+		if (ret)
+			break;
+		contents = xmalloc(object.size);
+		if (!contents) {
+			ret = -ENOMEM;
+			break;
+		}
+		ret = read_all(image, contents, object.size);
+		if (!ret)
+			ret = restore_object(fd, cookie, &object, contents);
+		xfree(contents);
+		if (ret)
+			break;
+	}
+	for (uint32_t i = 0; !ret && i < header.mapping_count; i++) {
+		struct i915_image_mapping mapping;
+
+		stage = "mapping";
+		stage_index = i;
+		resource_id = 0;
+		ret = read_all(image, &mapping, sizeof(mapping));
+		if (!ret) {
+			resource_id = mapping.object_id;
+			ret = restore_mapping(fd, cookie, id, &mapping);
+		}
+	}
+	for (uint32_t i = 0, previous = 0;
+	     !ret && i < header.syncobj_count; i++) {
+		struct i915_image_syncobj syncobj;
+
+		stage = "syncobj";
+		stage_index = i;
+		resource_id = 0;
+		ret = read_all(image, &syncobj, sizeof(syncobj));
+		if (!ret) {
+			resource_id = syncobj.handle;
+			ret = restore_syncobj(fd, cookie, &syncobj, previous);
+		}
+		if (!ret)
+			previous = syncobj.handle;
+	}
+	for (uint32_t i = 0, previous = 0;
+	     !ret && i < header.vm_count; i++) {
+		struct i915_image_context vm;
+
+		stage = "vm";
+		stage_index = i;
+		resource_id = 0;
+		ret = read_all(image, &vm, sizeof(vm));
+		if (!ret) {
+			resource_id = vm.id;
+			ret = restore_context_state(fd, cookie, &vm,
+						    I915_CRIU_CONTEXT_CREATE_VM,
+						    previous);
+		}
+		if (!ret)
+			previous = vm.id;
+	}
+	for (uint32_t i = 0, previous = 0;
+	     !ret && i < header.context_count; i++) {
+		struct i915_image_context context;
+
+		stage = "context";
+		stage_index = i;
+		resource_id = 0;
+		ret = read_all(image, &context, sizeof(context));
+		if (!ret) {
+			resource_id = context.id;
+			ret = restore_context_state(fd, cookie, &context,
+						    I915_CRIU_CONTEXT_CREATE_CONTEXT,
+						    previous);
+		}
+		if (!ret)
+			previous = context.id;
+	}
+	{
+		uint32_t previous_vm = 0;
+		uint64_t previous_address = 0;
+
+		for (uint32_t i = 0; !ret && i < header.binding_count; i++) {
+			struct i915_image_binding binding;
+
+			stage = "binding";
+			stage_index = i;
+			resource_id = 0;
+			ret = read_all(image, &binding, sizeof(binding));
+			if (!ret)
+				resource_id = binding.object_id;
+			if (!ret && binding.vm_id != previous_vm)
+				previous_address = 0;
+			if (!ret)
+				ret = restore_binding(fd, cookie, &binding,
+						      previous_vm,
+						      previous_address);
+			if (!ret) {
+				previous_vm = binding.vm_id;
+				previous_address = binding.address;
+			}
+		}
+	}
+	for (uint32_t i = 0, previous = 0;
+	     !ret && i < header.framebuffer_count; i++) {
+		struct i915_image_framebuffer framebuffer;
+
+		stage = "framebuffer";
+		stage_index = i;
+		resource_id = 0;
+		ret = read_all(image, &framebuffer, sizeof(framebuffer));
+		if (!ret) {
+			resource_id = framebuffer.id;
+			ret = restore_framebuffer(fd, cookie, &framebuffer, previous);
+		}
+		if (!ret)
+			previous = framebuffer.id;
+	}
+	for (uint32_t i = 0, previous = 0;
+	     !ret && i < header.blob_count; i++) {
+		struct i915_image_blob blob;
+		void *contents;
+
+		stage = "blob";
+		stage_index = i;
+		resource_id = 0;
+		ret = read_all(image, &blob, sizeof(blob));
+		if (!ret)
+			resource_id = blob.id;
+		if (ret)
+			break;
+		if (!blob.length || blob.length > I915_MAX_BLOB_SIZE) {
+			ret = -EINVAL;
+			break;
+		}
+		contents = xmalloc(blob.length);
+		if (!contents) {
+			ret = -ENOMEM;
+			break;
+		}
+		ret = read_all(image, contents, blob.length);
+		if (!ret)
+			ret = restore_blob(fd, cookie, &blob, contents, previous);
+		xfree(contents);
+		if (!ret)
+			previous = blob.id;
+	}
+	for (uint32_t i = 0; !ret && i < header.kms_property_count; i++) {
+		struct i915_image_kms_property property;
+
+		stage = "kms-property";
+		stage_index = i;
+		resource_id = 0;
+		ret = read_all(image, &property, sizeof(property));
+		if (!ret) {
+			resource_id = property.object_id;
+			ret = remember_kms_property(id, &property);
+		}
+	}
+	if (!ret) {
+		stage = "trailing-data";
+		stage_index = 0;
+		resource_id = 0;
+		char trailing;
+		ssize_t got;
+
+		do {
+			got = read(image, &trailing, sizeof(trailing));
+		} while (got < 0 && errno == EINTR);
+		if (got != 0)
+			ret = got < 0 ? -errno : -EINVAL;
+	}
+	close(image);
+	if (ret) {
+		pr_err("i915 restore file=%d stage=%s index=%" PRIu32
+		       " resource=%" PRIu64 " failed: %d\n",
+		       id, stage, stage_index, resource_id, ret);
+		restore_mapping_count = mapping_base;
+		restore_kms_property_count = kms_property_base;
+		session_ioctl(fd, I915_CRIU_SESSION_ABORT, 0, &cookie);
+		abort_restore_sessions();
+		close(fd);
+		return ret;
+	}
+
+	ret = criu_plugin_fdstore_add(fd);
+	if (ret < 0) {
+		restore_kms_property_count = kms_property_base;
+		session_ioctl(fd, I915_CRIU_SESSION_ABORT, 0, &cookie);
+		abort_restore_sessions();
+		close(fd);
+		return -EIO;
+	}
+	restore_file = &restore_files[restore_file_count++];
+	*restore_file = (struct restore_file){
+		.file_id = id,
+		.fdstore_id = ret,
+		.cookie = cookie,
+		.file_flags = header.file_flags,
+		.active = true,
+	};
+	for (size_t i = 0; i < restore_object_count; i++) {
+		if (restore_objects[i].transient_fd != fd)
+			continue;
+		restore_objects[i].transient_fd = -1;
+		restore_objects[i].fdstore_id = ret;
+	}
+	close(fd);
+	ret = criu_plugin_fdstore_get(restore_file->fdstore_id);
+	return ret < 0 ? -EIO : ret;
+}
+static int restore_dmabuf_image(int id)
+{
+	struct i915_image_header header;
+	struct i915_image_dmabuf image;
+	int fd;
+	int ret;
+
+	fd = image_fd(id, O_RDONLY);
+	if (fd < 0)
+		return -ENOTSUP;
+	ret = read_all(fd, &header, sizeof(header));
+	if (!ret)
+		ret = read_all(fd, &image, sizeof(image));
+	if (!ret && (header.magic != I915_IMAGE_MAGIC ||
+		     header.version != I915_IMAGE_VERSION ||
+		     header.file_id != (uint32_t)id ||
+		     header.kind != I915_IMAGE_KIND_DMABUF ||
+		     header.object_count || header.syncobj_count ||
+		     header.vm_count || header.context_count ||
+		     header.binding_count || header.framebuffer_count ||
+		     header.blob_count || header.kms_property_count ||
+		     header.file_flags || header.device_identity ||
+		     header.subsystem_identity || header.revision ||
+		     header.mapping_count || !image.object_id || !image.fd_count ||
+		     image.reserved))
+		ret = -EINVAL;
+	if (!ret) {
+		char trailing;
+		ssize_t got;
+
+		do {
+			got = read(fd, &trailing, sizeof(trailing));
+		} while (got < 0 && errno == EINTR);
+		if (got != 0)
+			ret = got < 0 ? -errno : -EINVAL;
+	}
+	close(fd);
+	if (ret)
+		return ret;
+	for (size_t i = 0; i < restore_object_count; i++) {
+		struct restore_object *object = &restore_objects[i];
+
+		if (object->object_id != image.object_id)
+			continue;
+		if (object->prime_fdstore_id < 0 ||
+		    image.fd_count > UINT32_MAX - object->restored_dma_buf_fds)
+			return -EINVAL;
+		object->restored_dma_buf_fds += image.fd_count;
+		fd = criu_plugin_fdstore_get(object->prime_fdstore_id);
+		return fd < 0 ? -EIO : fd;
+	}
+	return -ENOENT;
+}
+
+static int restore_sync_file_image(int id)
+{
+	struct i915_image_header header;
+	struct i915_image_sync_file image;
+	int image_fd_value;
+	int ret;
+
+	image_fd_value = image_fd(id, O_RDONLY);
+	if (image_fd_value < 0)
+		return -ENOTSUP;
+	ret = read_all(image_fd_value, &header, sizeof(header));
+	if (!ret)
+		ret = read_all(image_fd_value, &image, sizeof(image));
+	if (!ret && (header.magic != I915_IMAGE_MAGIC ||
+		     header.version != I915_IMAGE_VERSION ||
+		     header.file_id != (uint32_t)id ||
+		     header.kind != I915_IMAGE_KIND_SYNC_FILE ||
+		     header.object_count || header.syncobj_count ||
+		     header.vm_count || header.context_count ||
+		     header.binding_count || header.framebuffer_count ||
+		     header.blob_count || header.kms_property_count ||
+		     header.file_flags || header.device_identity ||
+		     header.subsystem_identity || header.revision ||
+		     header.mapping_count || !image.source_file_id ||
+		     !image.handle ||
+		     image.flags != I915_CRIU_SYNC_FILE_BINARY_SIGNALED ||
+		     !image.fd_count || image.point || image.reserved[0] ||
+		     image.reserved[1]))
+		ret = -EINVAL;
+	if (!ret) {
+		char trailing;
+		ssize_t got;
+
+		do {
+			got = read(image_fd_value, &trailing, sizeof(trailing));
+		} while (got < 0 && errno == EINTR);
+		if (got != 0)
+			ret = got < 0 ? -errno : -EINVAL;
+	}
+	close(image_fd_value);
+	if (ret)
+		return ret;
+
+	for (size_t i = 0; i < restore_file_count; i++) {
+		struct restore_file *file = &restore_files[i];
+		struct drm_i915_criu_sync_file create = {
+			.version = I915_CRIU_ABI_VERSION,
+			.op = I915_CRIU_SYNC_FILE_CREATE,
+			.cookie = file->cookie,
+			.fd = -1,
+			.handle = image.handle,
+			.flags = image.flags,
+			.point = image.point,
+		};
+		int fd;
+
+		if (file->file_id != (int)image.source_file_id || !file->active)
+			continue;
+		fd = criu_plugin_fdstore_get(file->fdstore_id);
+		if (fd < 0)
+			return -EIO;
+		if (ioctl(fd, DRM_IOCTL_I915_CRIU_SYNC_FILE, &create) < 0)
+			ret = -errno;
+		close(fd);
+		return ret ? ret : create.fd;
+	}
+	return -ENOENT;
+}
+
+struct restore_image {
+	int id;
+	uint32_t kind;
+	uint32_t file_flags;
+};
+
+static int read_image_kind(int id, uint32_t *kind, uint32_t *file_flags)
+{
+	struct i915_image_header header;
+	int fd = image_fd(id, O_RDONLY);
+	int ret;
+
+	if (fd < 0)
+		return fd;
+	ret = read_all(fd, &header, sizeof(header));
+	close(fd);
+	if (ret)
+		return ret;
+	if (header.magic != I915_IMAGE_MAGIC ||
+	    header.version != I915_IMAGE_VERSION ||
+	    header.file_id != (uint32_t)id ||
+	    (header.kind != I915_IMAGE_KIND_DRM_FILE &&
+	     header.kind != I915_IMAGE_KIND_DMABUF &&
+	     header.kind != I915_IMAGE_KIND_SYNC_FILE))
+		return -EINVAL;
+	*kind = header.kind;
+	*file_flags = header.file_flags;
+	return 0;
+}
+
+static int compare_restore_images(const void *left, const void *right)
+{
+	const struct restore_image *a = left;
+	const struct restore_image *b = right;
+
+	if (a->kind != b->kind)
+		return (a->kind > b->kind) - (a->kind < b->kind);
+	if (a->kind == I915_IMAGE_KIND_DRM_FILE) {
+		bool a_master = a->file_flags & I915_CRIU_FILE_MASTER;
+		bool b_master = b->file_flags & I915_CRIU_FILE_MASTER;
+
+		if (a_master != b_master)
+			return b_master - a_master;
+	}
+	return (a->id > b->id) - (a->id < b->id);
+}
+
+int i915_plugin_prepare_restore(void)
+{
+	DIR *directory;
+	struct dirent *entry;
+	struct restore_image images[I915_MAX_RESTORE_FILES];
+	size_t image_count = 0;
+	int directory_fd;
+
+	directory_fd = dup(criu_get_image_dir());
+	if (directory_fd < 0)
+		return -errno;
+	directory = fdopendir(directory_fd);
+	if (!directory) {
+		close(directory_fd);
+		return -errno;
+	}
+	while ((entry = readdir(directory))) {
+		char trailing;
+		int id;
+
+		if (sscanf(entry->d_name, "i915-criu-%d.img%c", &id,
+			   &trailing) != 1)
+			continue;
+		if (id < 0 || image_count == I915_MAX_RESTORE_FILES) {
+			closedir(directory);
+			return -E2BIG;
+		}
+		images[image_count].id = id;
+		if (read_image_kind(id, &images[image_count].kind,
+				    &images[image_count].file_flags)) {
+			closedir(directory);
+			return -EINVAL;
+		}
+		image_count++;
+	}
+	closedir(directory);
+	qsort(images, image_count, sizeof(images[0]), compare_restore_images);
+
+	for (size_t i = 0; i < image_count; i++) {
+		int fd;
+		int fdstore_id;
+
+		switch (images[i].kind) {
+		case I915_IMAGE_KIND_DRM_FILE:
+			fd = restore_file_image(images[i].id);
+			break;
+		case I915_IMAGE_KIND_DMABUF:
+			fd = restore_dmabuf_image(images[i].id);
+			break;
+		case I915_IMAGE_KIND_SYNC_FILE:
+			fd = restore_sync_file_image(images[i].id);
+			break;
+		default:
+			fd = -EINVAL;
+			break;
+		}
+
+		if (fd < 0) {
+			pr_err("failed to prepare i915 image %d: %d\n",
+			       images[i].id, fd);
+			return fd;
+		}
+		fdstore_id = criu_plugin_fdstore_add(fd);
+		close(fd);
+		if (fdstore_id < 0)
+			return -EIO;
+		prepared_files[prepared_file_count++] = (struct prepared_file){
+			.file_id = images[i].id,
+			.fdstore_id = fdstore_id,
+		};
+	}
+	for (size_t i = 0; i < restore_object_count; i++) {
+		struct restore_object *object = &restore_objects[i];
+		uint64_t expected_fds;
+
+		if (!object->dma_buf_refcount)
+			continue;
+		if (object->dma_buf_refcount < 1 + object->handle_count)
+			return -EINVAL;
+		expected_fds = object->dma_buf_refcount - 1 - object->handle_count;
+		if (expected_fds != object->restored_dma_buf_fds)
+			return -EXDEV;
+	}
+	return 0;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__PREPARE_RESTORE,
+			i915_plugin_prepare_restore)
+
+int i915_plugin_restore_file(int id)
+{
+	for (size_t i = 0; i < prepared_file_count; i++) {
+		if (prepared_files[i].file_id == id)
+			return criu_plugin_fdstore_get(prepared_files[i].fdstore_id);
+	}
+	return -ENOTSUP;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__RESTORE_EXT_FILE,
+			i915_plugin_restore_file)
+
+int i915_plugin_update_vma_map(const char *path, uint64_t addr,
+			       uint64_t old_pgoff, uint64_t *new_pgoff,
+			       int *plugin_fd)
+{
+	(void)path;
+	(void)addr;
+	for (size_t i = 0; i < restore_mapping_count; i++) {
+		const struct restore_mapping *mapping = &restore_mappings[i];
+
+		if (old_pgoff < mapping->old_offset ||
+		    old_pgoff >= mapping->old_offset + mapping->size)
+			continue;
+		for (size_t j = 0; j < restore_file_count; j++) {
+			if (restore_files[j].file_id != mapping->file_id)
+				continue;
+			*new_pgoff = mapping->new_offset +
+				     (old_pgoff - mapping->old_offset);
+			*plugin_fd = criu_plugin_fdstore_get(
+				restore_files[j].fdstore_id);
+			return *plugin_fd < 0 ? -EIO : 1;
+		}
+		return -ENOENT;
+	}
+	pr_err("i915 VMA at %#" PRIx64 " has no restored mapping record\n",
+	       old_pgoff);
+	return -EXDEV;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__UPDATE_VMA_MAP,
+			i915_plugin_update_vma_map)
+
+static bool object_has_property(drmModeObjectPropertiesPtr object,
+				uint32_t property_id)
+{
+	for (uint32_t i = 0; i < object->count_props; i++)
+		if (object->props[i] == property_id)
+			return true;
+	return false;
+}
+
+static int apply_kms_file_state(const struct restore_file *restore_file,
+				bool test_only)
+{
+	drmModeAtomicReqPtr request;
+	size_t property_count = 0;
+	uint32_t flags = DRM_MODE_ATOMIC_ALLOW_MODESET;
+	int fd;
+	int ret = 0;
+
+	if (test_only)
+		flags |= DRM_MODE_ATOMIC_TEST_ONLY;
+	fd = criu_plugin_fdstore_get(restore_file->fdstore_id);
+	if (fd < 0)
+		return -EIO;
+	request = drmModeAtomicAlloc();
+	if (!request) {
+		close(fd);
+		return -ENOMEM;
+	}
+	for (size_t i = 0; i < restore_kms_property_count; i++) {
+		const struct restore_kms_property *property =
+			&restore_kms_properties[i];
+		drmModeObjectPropertiesPtr object;
+		drmModePropertyPtr metadata;
+
+		if (property->file_id != restore_file->file_id)
+			continue;
+		for (size_t j = 0; j < i; j++) {
+			if (restore_kms_properties[j].file_id == property->file_id &&
+			    restore_kms_properties[j].image.object_id ==
+				    property->image.object_id &&
+			    restore_kms_properties[j].image.property_id ==
+				    property->image.property_id) {
+				ret = -EINVAL;
+				goto out;
+			}
+		}
+		object = drmModeObjectGetProperties(
+			fd, property->image.object_id,
+			property->image.object_type);
+		metadata = drmModeGetProperty(fd, property->image.property_id);
+		if (!object || !metadata ||
+		    !object_has_property(object, property->image.property_id) ||
+		    metadata->flags & DRM_MODE_PROP_IMMUTABLE ||
+		    ephemeral_atomic_property(metadata->name)) {
+			if (object)
+				drmModeFreeObjectProperties(object);
+			if (metadata)
+				drmModeFreeProperty(metadata);
+			ret = -EXDEV;
+			goto out;
+		}
+		drmModeFreeObjectProperties(object);
+		drmModeFreeProperty(metadata);
+		if (drmModeAtomicAddProperty(request,
+					     property->image.object_id,
+					     property->image.property_id,
+					     property->image.value) < 0) {
+			ret = -errno;
+			goto out;
+		}
+		property_count++;
+	}
+	if (property_count && drmModeAtomicCommit(fd, request, flags, NULL))
+		ret = -errno;
+out:
+	drmModeAtomicFree(request);
+	close(fd);
+	return ret;
+}
+
+static int apply_kms_state(bool test_only)
+{
+	for (size_t i = 0; i < restore_file_count; i++) {
+		int ret;
+
+		if (!(restore_files[i].file_flags & I915_CRIU_FILE_MASTER))
+			continue;
+		ret = apply_kms_file_state(&restore_files[i], test_only);
+		if (ret)
+			return ret;
+	}
+	return 0;
+}
+
+int i915_plugin_resume_devices_late(int pid)
+{
+	(void)pid;
+	for (size_t i = 0; i < restore_object_count; i++) {
+		if (restore_objects[i].restored_handles !=
+		    restore_objects[i].handle_count) {
+			pr_err("i915 object %#" PRIx64
+			       " restored %u handles but image requires %u\n",
+			       restore_objects[i].object_id,
+			       restore_objects[i].restored_handles,
+			       restore_objects[i].handle_count);
+			return -EXDEV;
+		}
+	}
+	{
+		int ret = apply_kms_state(true);
+
+		if (!ret)
+			ret = apply_kms_state(false);
+		if (ret)
+			return ret;
+	}
+	for (unsigned int master_pass = 0; master_pass < 2; master_pass++) {
+		for (size_t i = 0; i < restore_file_count; i++) {
+			bool is_master = restore_files[i].file_flags &
+					 I915_CRIU_FILE_MASTER;
+			int fd;
+			int ret;
+
+			if (!restore_files[i].active || is_master != master_pass)
+				continue;
+			fd = criu_plugin_fdstore_get(restore_files[i].fdstore_id);
+			if (fd < 0)
+				return -EIO;
+			ret = session_ioctl(fd, I915_CRIU_SESSION_COMMIT,
+					    0, &restore_files[i].cookie);
+			close(fd);
+			if (ret)
+				return ret;
+			restore_files[i].active = false;
+		}
+	}
+	return 0;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__RESUME_DEVICES_LATE,
+			i915_plugin_resume_devices_late)
diff --git a/plugins/input/Makefile b/plugins/input/Makefile
new file mode 100644
index 0000000000000000000000000000000000000000..5a42d38df49d4631a78180cf67ad9550fd0e8d3d
--- /dev/null
+++ b/plugins/input/Makefile
@@ -0,0 +1,31 @@
+PLUGIN_NAME := input_plugin
+PLUGIN_SOBJ := input_plugin.so
+PLUGIN_INCLUDE := -iquote../../include
+PLUGIN_INCLUDE += -iquote../../criu/include
+PLUGIN_INCLUDE += -iquote../../criu/arch/$(ARCH)/include/
+PLUGIN_INCLUDE += -iquote../../
+COMPEL := ../../compel/compel-host
+
+__nmk_dir ?= ../../scripts/nmk/scripts/
+include $(__nmk_dir)msg.mk
+
+PLUGIN_CFLAGS := -g -Wall -Wextra -Werror -D_GNU_SOURCE -shared -nostartfiles -fPIC
+
+all: $(PLUGIN_SOBJ)
+
+input_plugin.so: input_plugin.c
+	$(CC) $(PLUGIN_CFLAGS) $(shell $(COMPEL) includes) $^ -o $@ $(PLUGIN_INCLUDE)
+
+clean:
+	$(call msg-clean, $@)
+	$(Q) $(RM) $(PLUGIN_SOBJ)
+
+install: $(PLUGIN_SOBJ)
+	$(Q) mkdir -p $(DESTDIR)$(PLUGINDIR)
+	$(E) "  INSTALL " $(PLUGIN_NAME)
+	$(Q) install -m 755 $(PLUGIN_SOBJ) $(DESTDIR)$(PLUGINDIR)
+
+uninstall:
+	$(Q) $(RM) $(DESTDIR)$(PLUGINDIR)/$(PLUGIN_SOBJ)
+
+.PHONY: all clean install uninstall
diff --git a/plugins/input/input_plugin.c b/plugins/input/input_plugin.c
new file mode 100644
index 0000000000000000000000000000000000000000..baeb62945c45d2be8df44448df666f09de8aa3d8
--- /dev/null
+++ b/plugins/input/input_plugin.c
@@ -0,0 +1,443 @@
+// SPDX-License-Identifier: GPL-2.0
+#include <dirent.h>
+#include <errno.h>
+#include <fcntl.h>
+#include <limits.h>
+#include <stdbool.h>
+#include <stddef.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <string.h>
+#include <sys/ioctl.h>
+#include <sys/stat.h>
+#include <sys/sysmacros.h>
+#include <unistd.h>
+
+#include "criu-plugin.h"
+#include "criu-log.h"
+#include "../../contrib/input-criu/input_criu_uapi.h"
+
+#define INPUT_IMAGE_MAGIC UINT64_C(0x494e505554435249)
+#define INPUT_IMAGE_VERSION 1
+#define INPUT_MAJOR_NUMBER 13
+#define EVDEV_MINOR_BASE 64
+#define EVDEV_MINOR_COUNT 32
+#define INPUT_STRING_SIZE 256
+#define INPUT_MAX_MT_SLOTS 64
+#define INPUT_MT_FIRST ABS_MT_TOUCH_MAJOR
+#define INPUT_MT_LAST ABS_MT_TOOL_Y
+#define BITS_SIZE(max) (((max) + 8) / 8)
+
+struct input_image {
+	uint64_t magic;
+	uint32_t version;
+	uint32_t size;
+	int32_t file_id;
+	uint32_t open_mode;
+	uint32_t device_major;
+	uint32_t device_minor;
+	struct input_criu_state client;
+	struct input_id id;
+	char name[INPUT_STRING_SIZE];
+	char phys[INPUT_STRING_SIZE];
+	char uniq[INPUT_STRING_SIZE];
+	uint8_t properties[BITS_SIZE(INPUT_PROP_MAX)];
+	uint8_t events[BITS_SIZE(EV_MAX)];
+	uint8_t keys[BITS_SIZE(KEY_MAX)];
+	uint8_t relative[BITS_SIZE(REL_MAX)];
+	uint8_t absolute[BITS_SIZE(ABS_MAX)];
+	uint8_t misc[BITS_SIZE(MSC_MAX)];
+	uint8_t switches[BITS_SIZE(SW_MAX)];
+	uint8_t leds[BITS_SIZE(LED_MAX)];
+	uint8_t sounds[BITS_SIZE(SND_MAX)];
+	uint8_t force_feedback[BITS_SIZE(FF_MAX)];
+	uint8_t key_state[BITS_SIZE(KEY_MAX)];
+	uint8_t led_state[BITS_SIZE(LED_MAX)];
+	uint8_t sound_state[BITS_SIZE(SND_MAX)];
+	uint8_t switch_state[BITS_SIZE(SW_MAX)];
+	uint32_t repeat[2];
+	struct input_absinfo absinfo[ABS_CNT];
+	uint32_t mt_slot_count;
+	int32_t mt_values[INPUT_MT_LAST - INPUT_MT_FIRST + 1][INPUT_MAX_MT_SLOTS];
+	uint64_t checksum;
+};
+
+static bool bit_is_set(const uint8_t *bits, unsigned int bit)
+{
+	return bits[bit / 8] & (1U << (bit % 8));
+}
+
+static uint64_t image_checksum(const struct input_image *image)
+{
+	const uint8_t *bytes = (const uint8_t *)image;
+	uint64_t hash = UINT64_C(1469598103934665603);
+	size_t i;
+
+	for (i = 0; i < offsetof(struct input_image, checksum); i++) {
+		hash ^= bytes[i];
+		hash *= UINT64_C(1099511628211);
+	}
+	return hash;
+}
+
+static int image_fd(int file_id, int flags)
+{
+	char name[64];
+
+	if (snprintf(name, sizeof(name), "input-criu-%d.img", file_id) >=
+	    (int)sizeof(name))
+		return -ENAMETOOLONG;
+	return openat(criu_get_image_dir(), name, flags, 0600);
+}
+
+static int write_all(int fd, const void *buffer, size_t size)
+{
+	const uint8_t *cursor = buffer;
+
+	while (size) {
+		ssize_t written = write(fd, cursor, size);
+		if (written < 0) {
+			if (errno == EINTR)
+				continue;
+			return -errno;
+		}
+		if (!written)
+			return -EIO;
+		cursor += written;
+		size -= written;
+	}
+	return 0;
+}
+
+static int read_all(int fd, void *buffer, size_t size)
+{
+	uint8_t *cursor = buffer;
+
+	while (size) {
+		ssize_t got = read(fd, cursor, size);
+		if (got < 0) {
+			if (errno == EINTR)
+				continue;
+			return -errno;
+		}
+		if (!got)
+			return -EIO;
+		cursor += got;
+		size -= got;
+	}
+	return 0;
+}
+
+static int query_bits(int fd, unsigned int type, void *bits, size_t size)
+{
+	if (ioctl(fd, EVIOCGBIT(type, size), bits) < 0)
+		return -errno;
+	return 0;
+}
+
+static int query_string(int fd, unsigned long request, char *value)
+{
+	if (ioctl(fd, request, value) < 0)
+		return -errno;
+	value[INPUT_STRING_SIZE - 1] = '\0';
+	return 0;
+}
+
+static int query_mt_state(int fd, struct input_image *image)
+{
+	struct {
+		uint32_t code;
+		int32_t values[INPUT_MAX_MT_SLOTS];
+	} request;
+	unsigned int code;
+
+	if (!bit_is_set(image->absolute, ABS_MT_SLOT))
+		return 0;
+	if (image->absinfo[ABS_MT_SLOT].minimum != 0 ||
+	    image->absinfo[ABS_MT_SLOT].maximum < 0 ||
+	    image->absinfo[ABS_MT_SLOT].maximum >= INPUT_MAX_MT_SLOTS)
+		return -E2BIG;
+	image->mt_slot_count = image->absinfo[ABS_MT_SLOT].maximum + 1;
+
+	for (code = INPUT_MT_FIRST; code <= INPUT_MT_LAST; code++) {
+		if (!bit_is_set(image->absolute, code))
+			continue;
+		memset(&request, 0, sizeof(request));
+		request.code = code;
+		if (ioctl(fd, EVIOCGMTSLOTS(sizeof(request.code) +
+					     image->mt_slot_count * sizeof(int32_t)),
+			  &request) < 0)
+			return -errno;
+		memcpy(image->mt_values[code - INPUT_MT_FIRST], request.values,
+		       image->mt_slot_count * sizeof(int32_t));
+	}
+	return 0;
+}
+
+static int snapshot_input(int fd, int file_id, struct input_image *image)
+{
+	struct stat st;
+	unsigned int code;
+	int flags;
+	int ret;
+
+	memset(image, 0, sizeof(*image));
+	image->magic = INPUT_IMAGE_MAGIC;
+	image->version = INPUT_IMAGE_VERSION;
+	image->size = sizeof(*image);
+	image->file_id = file_id;
+	if (fstat(fd, &st) < 0)
+		return -errno;
+	image->device_major = major(st.st_rdev);
+	image->device_minor = minor(st.st_rdev);
+	flags = fcntl(fd, F_GETFL);
+	if (flags < 0)
+		return -errno;
+	image->open_mode = flags & O_ACCMODE;
+
+	image->client.version = EVDEV_CRIU_STATE_VERSION;
+	image->client.size = sizeof(image->client);
+	if (ioctl(fd, EVIOCGCRIUSTATE, &image->client) < 0)
+		return errno == ENOTTY ? -ENOTSUP : -errno;
+	if (image->client.flags || image->client.queued_events ||
+	    image->client.clock_id == UINT32_MAX)
+		return -EOPNOTSUPP;
+
+	if (ioctl(fd, EVIOCGID, &image->id) < 0)
+		return -errno;
+	ret = query_string(fd, EVIOCGNAME(INPUT_STRING_SIZE), image->name);
+	if (ret)
+		return ret;
+	ret = query_string(fd, EVIOCGPHYS(INPUT_STRING_SIZE), image->phys);
+	if (ret && ret != -ENOENT)
+		return ret;
+	ret = query_string(fd, EVIOCGUNIQ(INPUT_STRING_SIZE), image->uniq);
+	if (ret && ret != -ENOENT)
+		return ret;
+
+	if ((ret = query_bits(fd, 0, image->events, sizeof(image->events))) ||
+	    (ret = query_bits(fd, EV_KEY, image->keys, sizeof(image->keys))) ||
+	    (ret = query_bits(fd, EV_REL, image->relative, sizeof(image->relative))) ||
+	    (ret = query_bits(fd, EV_ABS, image->absolute, sizeof(image->absolute))) ||
+	    (ret = query_bits(fd, EV_MSC, image->misc, sizeof(image->misc))) ||
+	    (ret = query_bits(fd, EV_SW, image->switches, sizeof(image->switches))) ||
+	    (ret = query_bits(fd, EV_LED, image->leds, sizeof(image->leds))) ||
+	    (ret = query_bits(fd, EV_SND, image->sounds, sizeof(image->sounds))) ||
+	    (ret = query_bits(fd, EV_FF, image->force_feedback,
+			      sizeof(image->force_feedback))))
+		return ret;
+	if (ioctl(fd, EVIOCGPROP(sizeof(image->properties)), image->properties) < 0)
+		return -errno;
+	if (bit_is_set(image->events, EV_FF))
+		return -EOPNOTSUPP;
+
+	if (ioctl(fd, EVIOCGKEY(sizeof(image->key_state)), image->key_state) < 0 &&
+	    errno != EINVAL)
+		return -errno;
+	if (ioctl(fd, EVIOCGLED(sizeof(image->led_state)), image->led_state) < 0 &&
+	    errno != EINVAL)
+		return -errno;
+	if (ioctl(fd, EVIOCGSND(sizeof(image->sound_state)), image->sound_state) < 0 &&
+	    errno != EINVAL)
+		return -errno;
+	if (ioctl(fd, EVIOCGSW(sizeof(image->switch_state)), image->switch_state) < 0 &&
+	    errno != EINVAL)
+		return -errno;
+	if (bit_is_set(image->events, EV_REP) && ioctl(fd, EVIOCGREP, image->repeat) < 0)
+		return -errno;
+	for (code = 0; code < ABS_CNT; code++) {
+		if (bit_is_set(image->absolute, code) &&
+		    ioctl(fd, EVIOCGABS(code), &image->absinfo[code]) < 0)
+			return -errno;
+	}
+	ret = query_mt_state(fd, image);
+	if (ret)
+		return ret;
+	image->checksum = image_checksum(image);
+	return 0;
+}
+
+static bool same_identity(const struct input_image *a,
+			  const struct input_image *b)
+{
+	return !memcmp(&a->id, &b->id, sizeof(a->id)) &&
+	       !memcmp(a->name, b->name, sizeof(a->name)) &&
+	       !memcmp(a->phys, b->phys, sizeof(a->phys)) &&
+	       !memcmp(a->uniq, b->uniq, sizeof(a->uniq)) &&
+	       !memcmp(a->properties, b->properties, sizeof(a->properties)) &&
+	       !memcmp(a->events, b->events, sizeof(a->events)) &&
+	       !memcmp(a->keys, b->keys, sizeof(a->keys)) &&
+	       !memcmp(a->relative, b->relative, sizeof(a->relative)) &&
+	       !memcmp(a->absolute, b->absolute, sizeof(a->absolute)) &&
+	       !memcmp(a->misc, b->misc, sizeof(a->misc)) &&
+	       !memcmp(a->switches, b->switches, sizeof(a->switches)) &&
+	       !memcmp(a->leds, b->leds, sizeof(a->leds)) &&
+	       !memcmp(a->sounds, b->sounds, sizeof(a->sounds)) &&
+	       !memcmp(a->force_feedback, b->force_feedback,
+		       sizeof(a->force_feedback)) &&
+	       !memcmp(a->repeat, b->repeat, sizeof(a->repeat)) &&
+	       !memcmp(a->absinfo, b->absinfo, sizeof(a->absinfo));
+}
+
+static bool same_global_state(const struct input_image *a,
+			      const struct input_image *b)
+{
+	return !memcmp(a->key_state, b->key_state, sizeof(a->key_state)) &&
+	       !memcmp(a->led_state, b->led_state, sizeof(a->led_state)) &&
+	       !memcmp(a->sound_state, b->sound_state, sizeof(a->sound_state)) &&
+	       !memcmp(a->switch_state, b->switch_state, sizeof(a->switch_state)) &&
+	       a->mt_slot_count == b->mt_slot_count &&
+	       !memcmp(a->mt_values, b->mt_values, sizeof(a->mt_values));
+}
+
+static bool is_evdev_fd(int fd)
+{
+	struct stat st;
+	unsigned int maj;
+	unsigned int min;
+
+	if (fstat(fd, &st) < 0 || !S_ISCHR(st.st_mode))
+		return false;
+	maj = major(st.st_rdev);
+	min = minor(st.st_rdev);
+	return maj == INPUT_MAJOR_NUMBER && min >= EVDEV_MINOR_BASE &&
+	       min < EVDEV_MINOR_BASE + EVDEV_MINOR_COUNT;
+}
+
+static int input_plugin_init(int stage)
+{
+	(void)stage;
+	return 0;
+}
+
+static void input_plugin_fini(int stage, int ret)
+{
+	(void)stage;
+	(void)ret;
+}
+
+CR_PLUGIN_REGISTER("input_plugin", input_plugin_init, input_plugin_fini)
+
+int input_plugin_dump_file(int fd, int id)
+{
+	struct input_image image;
+	int out;
+	int ret;
+
+	if (!is_evdev_fd(fd))
+		return -ENOTSUP;
+	ret = snapshot_input(fd, id, &image);
+	if (ret) {
+		pr_err("input_plugin: evdev file %d is outside the exact empty-client subset: %d\n",
+		       id, ret);
+		return ret;
+	}
+	out = image_fd(id, O_WRONLY | O_CREAT | O_EXCL | O_CLOEXEC);
+	if (out < 0)
+		return -errno;
+	ret = write_all(out, &image, sizeof(image));
+	if (close(out) < 0 && !ret)
+		ret = -errno;
+	return ret;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__DUMP_EXT_FILE, input_plugin_dump_file)
+
+static int read_image(int id, struct input_image *image)
+{
+	uint8_t trailing;
+	ssize_t got;
+	int fd;
+	int ret;
+
+	fd = image_fd(id, O_RDONLY | O_CLOEXEC);
+	if (fd < 0)
+		return errno == ENOENT ? -ENOTSUP : -errno;
+	ret = read_all(fd, image, sizeof(*image));
+	if (!ret) {
+		got = read(fd, &trailing, sizeof(trailing));
+		if (got < 0)
+			ret = -errno;
+		else if (got)
+			ret = -E2BIG;
+	}
+	if (close(fd) < 0 && !ret)
+		ret = -errno;
+	if (ret)
+		return ret;
+	if (image->magic != INPUT_IMAGE_MAGIC ||
+	    image->version != INPUT_IMAGE_VERSION ||
+	    image->size != sizeof(*image) || image->file_id != id ||
+	    image->checksum != image_checksum(image))
+		return -EINVAL;
+	return 0;
+}
+
+int input_plugin_restore_file(int id)
+{
+	struct input_image expected;
+	struct input_image current;
+	struct input_image matched;
+	char path[64];
+	int candidate = -1;
+	int matches = 0;
+	int ret;
+	unsigned int event;
+
+	ret = read_image(id, &expected);
+	if (ret)
+		return ret;
+	for (event = 0; event < EVDEV_MINOR_COUNT; event++) {
+		int fd;
+
+		if (snprintf(path, sizeof(path), "/dev/input/event%u", event) >=
+		    (int)sizeof(path))
+			return -ENAMETOOLONG;
+		fd = open(path, expected.open_mode | O_NONBLOCK | O_CLOEXEC);
+		if (fd < 0)
+			continue;
+		ret = snapshot_input(fd, id, &current);
+		if (!ret && same_identity(&expected, &current)) {
+			matches++;
+			if (candidate >= 0)
+				close(candidate);
+			candidate = fd;
+			matched = current;
+		} else {
+			close(fd);
+		}
+	}
+	if (matches != 1) {
+		if (candidate >= 0)
+			close(candidate);
+		pr_err("input_plugin: expected one compatible evdev device for file %d, found %d\n",
+		       id, matches);
+		return matches ? -EEXIST : -ENODEV;
+	}
+	if (!same_global_state(&expected, &matched)) {
+		close(candidate);
+		pr_err("input_plugin: global input state changed for file %d\n", id);
+		return -EXDEV;
+	}
+	if (ioctl(candidate, EVIOCSCLOCKID, &expected.client.clock_id) < 0) {
+		ret = -errno;
+		close(candidate);
+		return ret;
+	}
+	memset(&current.client, 0, sizeof(current.client));
+	current.client.version = EVDEV_CRIU_STATE_VERSION;
+	current.client.size = sizeof(current.client);
+	if (ioctl(candidate, EVIOCGCRIUSTATE, &current.client) < 0) {
+		ret = -errno;
+		close(candidate);
+		return ret;
+	}
+	if (current.client.flags || current.client.queued_events ||
+	    current.client.clock_id != expected.client.clock_id ||
+	    current.client.buffer_size != expected.client.buffer_size) {
+		close(candidate);
+		return -EOPNOTSUPP;
+	}
+	return candidate;
+}
+CR_PLUGIN_REGISTER_HOOK(CR_PLUGIN_HOOK__RESTORE_EXT_FILE,
+			input_plugin_restore_file)
diff --git a/test/others/i915-criu/i915-context-sync.c b/test/others/i915-criu/i915-context-sync.c
new file mode 100644
index 0000000000000000000000000000000000000000..fc49184a7c8d6e417c77cc1eb0ee0c1d080eaec9
--- /dev/null
+++ b/test/others/i915-criu/i915-context-sync.c
@@ -0,0 +1,392 @@
+// SPDX-License-Identifier: GPL-2.0
+#define _GNU_SOURCE
+#include <errno.h>
+#include <fcntl.h>
+#include <inttypes.h>
+#include <signal.h>
+#include <stdbool.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/eventfd.h>
+#include <sys/ioctl.h>
+#include <sys/mman.h>
+#include <sys/poll.h>
+#include <sys/wait.h>
+#include <unistd.h>
+
+#include <linux/sync_file.h>
+
+#include <drm/drm.h>
+#include <drm/i915_drm.h>
+
+#define OBJECT_SIZE (4 * 4096u)
+#define TIMELINE_POINT UINT64_C(5)
+#define POST_RESTORE_POINT UINT64_C(9)
+
+static volatile sig_atomic_t resume_test;
+
+static void die(const char *what)
+{
+	perror(what);
+	exit(EXIT_FAILURE);
+}
+
+static void on_signal(int signo)
+{
+	(void)signo;
+	resume_test = 1;
+}
+
+static void xioctl(int fd, unsigned long request, void *arg, const char *what)
+{
+	if (ioctl(fd, request, arg) < 0)
+		die(what);
+}
+
+static void signal_binary(int fd, uint32_t handle)
+{
+	struct drm_syncobj_array signal = {
+		.handles = (uintptr_t)&handle,
+		.count_handles = 1,
+	};
+
+	xioctl(fd, DRM_IOCTL_SYNCOBJ_SIGNAL, &signal, "SYNCOBJ_SIGNAL");
+}
+
+static void wait_binary(int fd, uint32_t handle)
+{
+	struct drm_syncobj_wait wait = {
+		.handles = (uintptr_t)&handle,
+		.timeout_nsec = INT64_MAX,
+		.count_handles = 1,
+		.flags = DRM_SYNCOBJ_WAIT_FLAGS_WAIT_ALL,
+	};
+
+	xioctl(fd, DRM_IOCTL_SYNCOBJ_WAIT, &wait, "SYNCOBJ_WAIT");
+}
+
+static int export_sync_file(int fd, uint32_t handle)
+{
+	struct drm_syncobj_handle export = {
+		.handle = handle,
+		.flags = DRM_SYNCOBJ_HANDLE_TO_FD_FLAGS_EXPORT_SYNC_FILE,
+		.fd = -1,
+	};
+
+	xioctl(fd, DRM_IOCTL_SYNCOBJ_HANDLE_TO_FD, &export,
+	       "SYNCOBJ_HANDLE_TO_FD sync_file");
+	return export.fd;
+}
+
+static void verify_sync_file(int fd, int sync_fd)
+{
+	struct sync_file_info info = { 0 };
+	struct pollfd pollfd = { .fd = sync_fd, .events = POLLIN };
+	struct drm_syncobj_create imported = { 0 };
+	struct drm_syncobj_handle import;
+
+	if (poll(&pollfd, 1, 0) != 1 || !(pollfd.revents & POLLIN)) {
+		errno = ETIME;
+		die("restored sync_file is not signaled");
+	}
+	xioctl(sync_fd, SYNC_IOC_FILE_INFO, &info, "SYNC_IOC_FILE_INFO");
+	if (info.status != 1 || !info.num_fences) {
+		errno = EILSEQ;
+		die("restored sync_file status");
+	}
+	xioctl(fd, DRM_IOCTL_SYNCOBJ_CREATE, &imported,
+	       "imported SYNCOBJ_CREATE");
+	import = (struct drm_syncobj_handle) {
+		.handle = imported.handle,
+		.flags = DRM_SYNCOBJ_FD_TO_HANDLE_FLAGS_IMPORT_SYNC_FILE,
+		.fd = sync_fd,
+	};
+	xioctl(fd, DRM_IOCTL_SYNCOBJ_FD_TO_HANDLE, &import,
+	       "SYNCOBJ_FD_TO_HANDLE sync_file");
+	wait_binary(fd, imported.handle);
+}
+
+static void signal_timeline(int fd, uint32_t handle, uint64_t point)
+{
+	struct drm_syncobj_timeline_array signal = {
+		.handles = (uintptr_t)&handle,
+		.points = (uintptr_t)&point,
+		.count_handles = 1,
+	};
+
+	xioctl(fd, DRM_IOCTL_SYNCOBJ_TIMELINE_SIGNAL, &signal,
+	       "SYNCOBJ_TIMELINE_SIGNAL");
+}
+
+static void wait_timeline(int fd, uint32_t handle, uint64_t point)
+{
+	struct drm_syncobj_timeline_wait wait = {
+		.handles = (uintptr_t)&handle,
+		.points = (uintptr_t)&point,
+		.timeout_nsec = INT64_MAX,
+		.count_handles = 1,
+		.flags = DRM_SYNCOBJ_WAIT_FLAGS_WAIT_ALL,
+	};
+
+	xioctl(fd, DRM_IOCTL_SYNCOBJ_TIMELINE_WAIT, &wait,
+	       "SYNCOBJ_TIMELINE_WAIT");
+}
+
+static void submit(int fd, uint32_t context, uint32_t handle, void *mapping,
+		   uint64_t *gpu_address, bool *gpu_address_valid,
+		   bool require_exact_address)
+{
+	uint32_t *batch = (uint32_t *)((char *)mapping + OBJECT_SIZE - 8);
+	uint32_t saved[2] = { batch[0], batch[1] };
+	struct drm_i915_gem_exec_object2 object = {
+		.handle = handle,
+		.offset = *gpu_address,
+		.flags = require_exact_address ? EXEC_OBJECT_PINNED : 0,
+	};
+	struct drm_i915_gem_execbuffer2 execbuf = {
+		.buffers_ptr = (uintptr_t)&object,
+		.buffer_count = 1,
+		.batch_start_offset = OBJECT_SIZE - 8,
+		.batch_len = 8,
+		.flags = I915_EXEC_RENDER,
+		.rsvd1 = context,
+	};
+	struct drm_i915_gem_wait wait = {
+		.bo_handle = handle,
+		.timeout_ns = 5 * INT64_C(1000000000),
+	};
+
+	batch[0] = 0x05000000;
+	batch[1] = 0;
+	fprintf(stderr, "SUBMIT context=%u gpu_address=%#" PRIx64 " exact=%u\n",
+		context, *gpu_address, require_exact_address);
+	xioctl(fd, DRM_IOCTL_I915_GEM_EXECBUFFER2, &execbuf, "EXECBUFFER2 context");
+	fprintf(stderr, "SUBMITTED context=%u gpu_address=%#" PRIx64 "\n",
+		context, (uint64_t)object.offset);
+	if (require_exact_address && object.offset != *gpu_address) {
+		errno = EADDRNOTAVAIL;
+		die("EXECBUFFER2 changed restored GPU address");
+	}
+	*gpu_address = object.offset;
+	*gpu_address_valid = true;
+	xioctl(fd, DRM_IOCTL_I915_GEM_WAIT, &wait, "GEM_WAIT context");
+	fprintf(stderr, "QUIESCED context=%u\n", context);
+	batch[0] = saved[0];
+	batch[1] = saved[1];
+}
+
+int main(int argc, char **argv)
+{
+	struct sigaction action = { .sa_handler = on_signal };
+	bool explicit_sync_only = argc == 2 && !strcmp(argv[1], "--sync-only");
+	bool sync_file_mode = argc == 2 && !strcmp(argv[1], "--sync-file");
+	bool external_sync_file = argc == 2 &&
+		!strcmp(argv[1], "--external-sync-file-peer");
+	bool sync_only = explicit_sync_only || sync_file_mode || external_sync_file;
+	bool idle_context = argc == 2 && !strcmp(argv[1], "--idle-context");
+	bool callback = argc == 2 && !strcmp(argv[1], "--callback");
+	bool custom_engine = argc == 2 && !strcmp(argv[1], "--custom-engine");
+	bool virtual_engine = argc == 2 && !strcmp(argv[1], "--virtual-engine");
+	struct drm_i915_gem_vm_control vm = { 0 };
+	struct drm_i915_gem_context_create context = { 0 };
+	struct drm_i915_gem_context_param context_vm;
+	struct drm_i915_gem_create object = { .size = OBJECT_SIZE };
+	struct drm_i915_gem_mmap_offset mmap_offset;
+	struct drm_syncobj_create binary = { 0 };
+	struct drm_syncobj_create timeline = { 0 };
+	void *mapping;
+	uint64_t gpu_address = 0;
+	bool gpu_address_valid = false;
+	int callback_fd = -1;
+	int sync_file_fd = -1;
+	int sync_file_dup = -1;
+	pid_t external_sync_file_pid = 0;
+	int fd;
+
+	if (argc > 2 || (argc == 2 && !sync_only && !idle_context &&
+				 !callback && !custom_engine && !virtual_engine)) {
+		fprintf(stderr, "usage: %s [--sync-only|--sync-file|--external-sync-file-peer|--idle-context|--callback|--custom-engine|--virtual-engine]\n",
+			argv[0]);
+		return EXIT_FAILURE;
+	}
+	fd = open("/dev/dri/renderD128", O_RDWR | O_CLOEXEC);
+	if (fd < 0)
+		die("open render node");
+	if (!sync_only && !callback) {
+		xioctl(fd, DRM_IOCTL_I915_GEM_VM_CREATE, &vm, "GEM_VM_CREATE");
+		if (custom_engine || virtual_engine) {
+			I915_DEFINE_CONTEXT_ENGINES_LOAD_BALANCE(balance, 1) = {
+				.base.name = I915_CONTEXT_ENGINES_EXT_LOAD_BALANCE,
+				.engine_index = 0,
+				.num_siblings = 1,
+				.engines = { { I915_ENGINE_CLASS_RENDER, 0 } },
+			};
+			I915_DEFINE_CONTEXT_PARAM_ENGINES(engines, 1) = { 0 };
+			struct drm_i915_gem_context_create_ext_setparam set_engines = {
+				.base.name = I915_CONTEXT_CREATE_EXT_SETPARAM,
+				.param = {
+					.param = I915_CONTEXT_PARAM_ENGINES,
+					.value = (uintptr_t)&engines,
+					.size = sizeof(engines),
+				},
+			};
+			struct drm_i915_gem_context_create_ext create = {
+				.flags = I915_CONTEXT_CREATE_FLAGS_USE_EXTENSIONS,
+				.extensions = (uintptr_t)&set_engines,
+			};
+
+			if (virtual_engine) {
+				engines.extensions = (uintptr_t)&balance;
+				engines.engines[0].engine_class =
+					I915_ENGINE_CLASS_INVALID;
+				engines.engines[0].engine_instance =
+					I915_ENGINE_CLASS_INVALID_NONE;
+			} else {
+				engines.engines[0].engine_class =
+					I915_ENGINE_CLASS_RENDER;
+				engines.engines[0].engine_instance = 0;
+			}
+			xioctl(fd, DRM_IOCTL_I915_GEM_CONTEXT_CREATE_EXT, &create,
+			       "GEM_CONTEXT_CREATE_EXT engines");
+			context.ctx_id = create.ctx_id;
+		} else {
+			xioctl(fd, DRM_IOCTL_I915_GEM_CONTEXT_CREATE, &context,
+			       "GEM_CONTEXT_CREATE");
+		}
+		context_vm = (struct drm_i915_gem_context_param) {
+			.ctx_id = context.ctx_id,
+			.param = I915_CONTEXT_PARAM_VM,
+			.value = vm.vm_id,
+		};
+		xioctl(fd, DRM_IOCTL_I915_GEM_CONTEXT_SETPARAM, &context_vm,
+		       "GEM_CONTEXT_SETPARAM VM");
+	}
+	xioctl(fd, DRM_IOCTL_I915_GEM_CREATE, &object, "GEM_CREATE");
+	mmap_offset = (struct drm_i915_gem_mmap_offset) {
+		.handle = object.handle,
+		.flags = I915_MMAP_OFFSET_WB,
+	};
+	xioctl(fd, DRM_IOCTL_I915_GEM_MMAP_OFFSET, &mmap_offset,
+	       "GEM_MMAP_OFFSET");
+	mapping = mmap(NULL, OBJECT_SIZE, PROT_READ | PROT_WRITE, MAP_SHARED,
+		       fd, mmap_offset.offset);
+	if (mapping == MAP_FAILED)
+		die("mmap GEM object");
+
+	xioctl(fd, DRM_IOCTL_SYNCOBJ_CREATE, &binary, "binary SYNCOBJ_CREATE");
+	xioctl(fd, DRM_IOCTL_SYNCOBJ_CREATE, &timeline,
+	       "timeline SYNCOBJ_CREATE");
+	if (callback) {
+		struct drm_syncobj_eventfd registration;
+
+		callback_fd = eventfd(0, EFD_CLOEXEC);
+		if (callback_fd < 0)
+			die("eventfd");
+		registration = (struct drm_syncobj_eventfd) {
+			.handle = binary.handle,
+			.fd = callback_fd,
+		};
+		xioctl(fd, DRM_IOCTL_SYNCOBJ_EVENTFD, &registration,
+		       "SYNCOBJ_EVENTFD");
+	} else {
+		signal_binary(fd, binary.handle);
+	}
+	if (sync_file_mode || external_sync_file) {
+		sync_file_fd = export_sync_file(fd, binary.handle);
+		if (sync_file_mode) {
+			sync_file_dup = dup(sync_file_fd);
+			if (sync_file_dup < 0)
+				die("dup sync_file");
+		}
+	}
+	if (external_sync_file) {
+		int ready_pipe[2];
+		pid_t intermediary;
+		int status;
+
+		if (pipe2(ready_pipe, O_CLOEXEC))
+			die("external sync_file pipe2");
+		intermediary = fork();
+		if (intermediary < 0)
+			die("external sync_file fork");
+		if (!intermediary) {
+			pid_t grandchild;
+
+			close(ready_pipe[0]);
+			grandchild = fork();
+			if (grandchild < 0)
+				die("external sync_file grandchild fork");
+			if (grandchild)
+				_exit(EXIT_SUCCESS);
+			if (munmap(mapping, OBJECT_SIZE))
+				die("external sync_file munmap");
+			close(fd);
+			close(callback_fd);
+			external_sync_file_pid = getpid();
+			if (write(ready_pipe[1], &external_sync_file_pid,
+				  sizeof(external_sync_file_pid)) !=
+			    sizeof(external_sync_file_pid))
+				die("external sync_file ready");
+			close(ready_pipe[1]);
+			for (;;)
+				pause();
+		}
+		close(ready_pipe[1]);
+		if (read(ready_pipe[0], &external_sync_file_pid,
+			 sizeof(external_sync_file_pid)) !=
+		    sizeof(external_sync_file_pid))
+			die("external sync_file pid");
+		close(ready_pipe[0]);
+		if (waitpid(intermediary, &status, 0) != intermediary ||
+		    !WIFEXITED(status) || WEXITSTATUS(status)) {
+			fprintf(stderr, "external sync_file intermediary failed\n");
+			return EXIT_FAILURE;
+		}
+	}
+	signal_timeline(fd, timeline.handle, TIMELINE_POINT);
+	if (!idle_context && !sync_only && !callback && !virtual_engine)
+		submit(fd, context.ctx_id, object.handle, mapping, &gpu_address,
+		       &gpu_address_valid, false);
+
+	if (sigaction(SIGUSR1, &action, NULL) < 0)
+		die("sigaction");
+	printf("READY pid=%d context=%u vm=%u binary=%u timeline=%u sync_file=%d external_sync_file=%d address=%p mmap_offset=%#" PRIx64 " gpu_address=%#" PRIx64 " gpu_address_valid=%u\n",
+	       getpid(), context.ctx_id, vm.vm_id, binary.handle,
+	       timeline.handle, sync_file_fd, external_sync_file_pid, mapping,
+	       (uint64_t)mmap_offset.offset, gpu_address, gpu_address_valid);
+	fflush(stdout);
+	while (!resume_test)
+		pause();
+
+	if (callback || virtual_engine || external_sync_file) {
+		fprintf(stderr, "unsupported mode must be refused before resume\n");
+		return EXIT_FAILURE;
+	}
+	fprintf(stderr, "RESUMED pid=%d\n", getpid());
+	wait_binary(fd, binary.handle);
+	fprintf(stderr, "BINARY-SIGNALED handle=%u\n", binary.handle);
+	if (sync_file_mode) {
+		verify_sync_file(fd, sync_file_fd);
+		verify_sync_file(fd, sync_file_dup);
+		fprintf(stderr, "SYNC-FILE-SIGNALED fds=%d,%d\n",
+			sync_file_fd, sync_file_dup);
+	}
+	wait_timeline(fd, timeline.handle, TIMELINE_POINT);
+	fprintf(stderr, "TIMELINE-SIGNALED handle=%u point=%" PRIu64 "\n",
+		timeline.handle, (uint64_t)TIMELINE_POINT);
+	submit(fd, context.ctx_id, object.handle, mapping, &gpu_address,
+	       &gpu_address_valid, gpu_address_valid);
+	signal_timeline(fd, timeline.handle, POST_RESTORE_POINT);
+	wait_timeline(fd, timeline.handle, POST_RESTORE_POINT);
+	if (sync_file_mode)
+		puts("PASS: binary syncobj, retained sync_file identity, timeline, and GPU submission");
+	else if (sync_only)
+		puts("PASS: binary syncobj, timeline, and GPU submission");
+	else if (idle_context)
+		puts("PASS: idle context, explicit VM, binary syncobj, timeline, and GPU submission");
+	else
+		puts("PASS: materialized context, explicit VM, exact GPU address, binary syncobj, timeline, and GPU submission");
+	return EXIT_SUCCESS;
+}
diff --git a/test/others/i915-criu/i915-gem-minimal.c b/test/others/i915-criu/i915-gem-minimal.c
new file mode 100644
index 0000000000000000000000000000000000000000..f770602df39ddb68463b52a7b8637d3d19841db8
--- /dev/null
+++ b/test/others/i915-criu/i915-gem-minimal.c
@@ -0,0 +1,247 @@
+// SPDX-License-Identifier: GPL-2.0
+#define _GNU_SOURCE
+#include <errno.h>
+#include <fcntl.h>
+#include <inttypes.h>
+#include <signal.h>
+#include <stdbool.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/ioctl.h>
+#include <sys/mman.h>
+#include <unistd.h>
+
+#include <drm/i915_drm.h>
+#include "../../../contrib/i915-criu/i915_criu_uapi.h"
+
+#define OBJECT_SIZE (4 * 4096u)
+#define PATTERN_SEED UINT64_C(0x915c7100d15ea5e)
+
+static volatile sig_atomic_t resume_test;
+
+static void on_signal(int signo)
+{
+	(void)signo;
+	resume_test = 1;
+}
+
+static void die(const char *what)
+{
+	perror(what);
+	exit(EXIT_FAILURE);
+}
+
+static void xioctl(int fd, unsigned long request, void *arg, const char *what)
+{
+	if (ioctl(fd, request, arg) < 0)
+		die(what);
+}
+
+static uint64_t pattern_word(size_t index)
+{
+	uint64_t value = PATTERN_SEED ^ (uint64_t)index * UINT64_C(0x9e3779b97f4a7c15);
+	value ^= value >> 29;
+	value *= UINT64_C(0xbf58476d1ce4e5b9);
+	return value ^ (value >> 31);
+}
+
+static void fill_pattern(void *mapping, size_t size)
+{
+	uint64_t *words = mapping;
+
+	for (size_t i = 0; i < size / sizeof(*words); i++)
+		words[i] = pattern_word(i);
+}
+
+static void verify_pattern(const void *mapping, size_t size)
+{
+	const uint64_t *words = mapping;
+
+	for (size_t i = 0; i < size / sizeof(*words); i++) {
+		uint64_t expected = pattern_word(i);
+		if (words[i] != expected) {
+			fprintf(stderr, "pattern mismatch at %zu: %#" PRIx64 " != %#" PRIx64 "\n",
+				i, words[i], expected);
+			exit(EXIT_FAILURE);
+		}
+	}
+}
+
+static void exercise_gpu(int fd, uint32_t handle, void *mapping, uint64_t size)
+{
+	uint32_t *batch = (uint32_t *)((char *)mapping + size - 8);
+	uint32_t saved[2] = { batch[0], batch[1] };
+	struct drm_i915_gem_exec_object2 object = { .handle = handle };
+	struct drm_i915_gem_execbuffer2 execbuf = {
+		.buffers_ptr = (uintptr_t)&object,
+		.buffer_count = 1,
+		.batch_start_offset = size - 8,
+		.batch_len = 8,
+		.flags = I915_EXEC_RENDER,
+	};
+	struct drm_i915_gem_wait wait = {
+		.bo_handle = handle,
+		.timeout_ns = -1,
+	};
+
+	batch[0] = 0x05000000; /* MI_BATCH_BUFFER_END */
+	batch[1] = 0;
+	xioctl(fd, DRM_IOCTL_I915_GEM_EXECBUFFER2, &execbuf, "post-restore EXECBUFFER2");
+	xioctl(fd, DRM_IOCTL_I915_GEM_WAIT, &wait, "post-restore GEM_WAIT");
+	batch[0] = saved[0];
+	batch[1] = saved[1];
+	verify_pattern(mapping, size);
+}
+
+static uint32_t create_object(int fd, uint64_t size)
+{
+	struct drm_i915_gem_create create = { .size = size };
+	xioctl(fd, DRM_IOCTL_I915_GEM_CREATE, &create, "GEM_CREATE");
+	return create.handle;
+}
+
+static void *map_object(int fd, uint32_t handle, uint64_t size, uint64_t *offset_out)
+{
+	struct drm_i915_gem_mmap_offset mmap_offset = {
+		.handle = handle,
+		.flags = I915_MMAP_OFFSET_WB,
+	};
+	void *mapping;
+
+	xioctl(fd, DRM_IOCTL_I915_GEM_MMAP_OFFSET, &mmap_offset, "GEM_MMAP_OFFSET");
+	mapping = mmap(NULL, size, PROT_READ | PROT_WRITE, MAP_SHARED, fd, mmap_offset.offset);
+	if (mapping == MAP_FAILED)
+		die("mmap GEM object");
+	*offset_out = mmap_offset.offset;
+	return mapping;
+}
+
+static void exercise_transaction(int source_fd, uint32_t source_handle,
+				 const void *source_mapping)
+{
+	struct drm_i915_criu_session dump = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_SESSION_DUMP_BEGIN,
+		.target_pid = getpid(),
+	};
+	struct drm_i915_criu_object object = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_OBJECT_QUERY,
+	};
+	struct drm_i915_criu_data data = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_DATA_READ,
+	};
+	uint8_t *image = malloc(OBJECT_SIZE);
+	int restored_fd;
+
+	if (!image)
+		die("malloc object image");
+
+	xioctl(source_fd, DRM_IOCTL_I915_CRIU_SESSION, &dump, "CRIU DUMP_BEGIN");
+	object.cookie = dump.cookie;
+	xioctl(source_fd, DRM_IOCTL_I915_CRIU_OBJECT, &object, "CRIU OBJECT_QUERY");
+	if (object.handle != source_handle || object.size != OBJECT_SIZE ||
+	    object.flags != I915_CRIU_OBJECT_SHMEM) {
+		fprintf(stderr, "unexpected object description\n");
+		exit(EXIT_FAILURE);
+	}
+
+	data.cookie = dump.cookie;
+	data.handle = object.handle;
+	data.size = object.size;
+	data.data_ptr = (uintptr_t)image;
+	xioctl(source_fd, DRM_IOCTL_I915_CRIU_DATA, &data, "CRIU DATA_READ");
+	if (memcmp(image, source_mapping, OBJECT_SIZE)) {
+		fprintf(stderr, "checkpoint image differs from mapped object\n");
+		exit(EXIT_FAILURE);
+	}
+
+	dump.op = I915_CRIU_SESSION_COMMIT;
+	xioctl(source_fd, DRM_IOCTL_I915_CRIU_SESSION, &dump, "CRIU dump COMMIT");
+
+	restored_fd = open("/dev/dri/renderD128", O_RDWR | O_CLOEXEC);
+	if (restored_fd < 0)
+		die("open restore render node");
+
+	struct drm_i915_criu_session restore = {
+		.version = I915_CRIU_ABI_VERSION,
+		.op = I915_CRIU_SESSION_RESTORE_BEGIN,
+	};
+	xioctl(restored_fd, DRM_IOCTL_I915_CRIU_SESSION, &restore, "CRIU RESTORE_BEGIN");
+
+	object.op = I915_CRIU_OBJECT_CREATE;
+	object.cookie = restore.cookie;
+	object.handle = 0;
+	object.mmap_offset = 0;
+	xioctl(restored_fd, DRM_IOCTL_I915_CRIU_OBJECT, &object, "CRIU OBJECT_CREATE");
+
+	data.op = I915_CRIU_DATA_WRITE;
+	data.cookie = restore.cookie;
+	data.handle = object.handle;
+	xioctl(restored_fd, DRM_IOCTL_I915_CRIU_DATA, &data, "CRIU DATA_WRITE");
+
+	uint64_t restored_offset;
+	void *restored_mapping = map_object(restored_fd, object.handle, object.size,
+					    &restored_offset);
+	verify_pattern(restored_mapping, object.size);
+	munmap(restored_mapping, object.size);
+
+	restore.op = I915_CRIU_SESSION_ABORT;
+	xioctl(restored_fd, DRM_IOCTL_I915_CRIU_SESSION, &restore, "CRIU restore ABORT");
+
+	struct drm_i915_gem_busy busy = { .handle = object.handle };
+	if (ioctl(restored_fd, DRM_IOCTL_I915_GEM_BUSY, &busy) == 0 || errno != ENOENT) {
+		fprintf(stderr, "restore ABORT did not remove handle %u\n", object.handle);
+		exit(EXIT_FAILURE);
+	}
+
+	close(restored_fd);
+	free(image);
+}
+
+int main(int argc, char **argv)
+{
+	bool exercise = argc == 2 && !strcmp(argv[1], "--exercise-criu-api");
+	struct sigaction action = { .sa_handler = on_signal };
+	uint64_t mmap_offset;
+	uint32_t handle;
+	void *mapping;
+	int fd;
+
+	fd = open("/dev/dri/renderD128", O_RDWR | O_CLOEXEC);
+	if (fd < 0)
+		die("open /dev/dri/renderD128");
+
+	handle = create_object(fd, OBJECT_SIZE);
+	mapping = map_object(fd, handle, OBJECT_SIZE, &mmap_offset);
+	fill_pattern(mapping, OBJECT_SIZE);
+	verify_pattern(mapping, OBJECT_SIZE);
+
+	if (exercise) {
+		exercise_transaction(fd, handle, mapping);
+		puts("PASS: i915 CRIU transaction and rollback");
+		return EXIT_SUCCESS;
+	}
+
+	if (sigaction(SIGUSR1, &action, NULL) < 0)
+		die("sigaction");
+	printf("READY pid=%d handle=%u address=%p mmap_offset=%#" PRIx64 "\n",
+	       getpid(), handle, mapping, mmap_offset);
+	fflush(stdout);
+	while (!resume_test)
+		pause();
+
+	verify_pattern(mapping, OBJECT_SIZE);
+	struct drm_i915_gem_set_domain domain = {
+		.handle = handle,
+		.read_domains = I915_GEM_DOMAIN_CPU,
+		.write_domain = I915_GEM_DOMAIN_CPU,
+	};
+	xioctl(fd, DRM_IOCTL_I915_GEM_SET_DOMAIN, &domain, "post-restore SET_DOMAIN");
+	exercise_gpu(fd, handle, mapping, OBJECT_SIZE);
+	puts("PASS: mapping address, contents, CPU access, and GPU execution");
+	return EXIT_SUCCESS;
+}
