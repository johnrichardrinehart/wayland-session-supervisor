++static u32 context_vm_id(struct drm_i915_file_private *fpriv,
++			 struct i915_address_space *context_vm)
++{
++	struct i915_address_space *vm;
++	unsigned long id;
++
++	if (!context_vm)
++		return 0;
++	xa_for_each(&fpriv->vm_xa, id, vm)
++		if (vm == context_vm)
++			return id;
++	return U32_MAX;
++}
++
++static u32 checkpoint_user_context_flags(unsigned long user_flags,
++					 bool single_timeline)
++{
++	u32 flags = 0;
++
++	if (single_timeline)
++		flags |= I915_CRIU_CONTEXT_SINGLE_TIMELINE;
++	if (user_flags & BIT(UCONTEXT_NO_ERROR_CAPTURE))
++		flags |= I915_CRIU_CONTEXT_NO_ERROR_CAPTURE;
++	if (user_flags & BIT(UCONTEXT_BANNABLE))
++		flags |= I915_CRIU_CONTEXT_BANNABLE;
++	if (user_flags & BIT(UCONTEXT_RECOVERABLE))
++		flags |= I915_CRIU_CONTEXT_RECOVERABLE;
++	if (user_flags & BIT(UCONTEXT_PERSISTENCE))
++		flags |= I915_CRIU_CONTEXT_PERSISTENCE;
++	return flags;
++}
++
++static u32
++checkpoint_proto_context_flags(const struct i915_gem_proto_context *pc)
++{
++	u32 flags = checkpoint_user_context_flags(pc->user_flags,
++						 pc->single_timeline);
++
++	if (pc->num_user_engines >= 0)
++		flags |= I915_CRIU_CONTEXT_USER_ENGINES;
++	return flags;
++}
++
++static u32 checkpoint_active_context_flags(const struct i915_gem_context *ctx)
++{
++	u32 flags = checkpoint_user_context_flags(ctx->user_flags, !!ctx->syncobj);
++
++	if (test_bit(CONTEXT_USER_ENGINES, &ctx->flags))
++		flags |= I915_CRIU_CONTEXT_USER_ENGINES;
++	return flags;
++}
++
++static bool object_has_file_handle(struct drm_file *file,
++				   struct drm_i915_gem_object *object)
++{
++	struct drm_gem_object *candidate;
++	int handle;
++	bool found = false;
++
++	spin_lock(&file->table_lock);
++	idr_for_each_entry(&file->object_idr, candidate, handle) {
++		if (candidate == &object->base) {
++			found = true;
++			break;
++		}
++	}
++	spin_unlock(&file->table_lock);
++	return found;
++}
++
++static int validate_active_context(struct drm_i915_file_private *fpriv,
++				   struct i915_gem_context *ctx,
++				   bool require_tracked_vm)
++{
++	const unsigned long allowed_user_flags =
++		BIT(UCONTEXT_NO_ERROR_CAPTURE) | BIT(UCONTEXT_BANNABLE) |
++		BIT(UCONTEXT_RECOVERABLE) | BIT(UCONTEXT_PERSISTENCE);
++	struct i915_gem_engines *engines;
++	bool user_engines;
++	unsigned int i;
++	int ret = 0;
++
++	if (ctx->uses_protected_content ||
++	    ctx->user_flags & ~allowed_user_flags ||
++	    (require_tracked_vm && context_vm_id(fpriv, ctx->vm) == U32_MAX))
++		return -EOPNOTSUPP;
++
++	user_engines = test_bit(CONTEXT_USER_ENGINES, &ctx->flags);
++	engines = i915_gem_context_lock_engines(ctx);
++	if (user_engines &&
++	    (!engines || engines->num_engines > I915_CRIU_MAX_CONTEXT_ENGINES)) {
++		ret = -EOPNOTSUPP;
++		goto out_engines;
++	}
++	for (i = 0; engines && i < engines->num_engines; i++) {
++		struct intel_context *ce = engines->engines[i];
++
++		if (!ce)
++			continue;
++		if (user_engines &&
++		    (intel_engine_is_virtual(ce->engine) ||
++		     memchr_inv(&ce->sseu, 0, sizeof(ce->sseu)))) {
++			ret = -EOPNOTSUPP;
++			break;
++		}
++		if (!intel_context_pin_if_active(ce))
++			continue;
++		intel_context_unpin(ce);
++		ret = -EBUSY;
++		break;
++	}
++out_engines:
++	i915_gem_context_unlock_engines(ctx);
++	return ret;
++}
++
++static int
++validate_proto_context_engines(const struct i915_gem_proto_context *pc)
++{
++	int i;
++
++	if (pc->num_user_engines < 0)
++		return pc->user_engines ? -EOPNOTSUPP : 0;
++	if (pc->num_user_engines > I915_CRIU_MAX_CONTEXT_ENGINES)
++		return -EOPNOTSUPP;
++	for (i = 0; i < pc->num_user_engines; i++) {
++		const struct i915_gem_proto_engine *engine = &pc->user_engines[i];
++
++		if (engine->type == I915_GEM_ENGINE_TYPE_INVALID) {
++			if (engine->engine || engine->num_siblings || engine->width ||
++			    engine->siblings ||
++			    memchr_inv(&engine->sseu, 0, sizeof(engine->sseu)))
++				return -EOPNOTSUPP;
++		} else if (engine->type == I915_GEM_ENGINE_TYPE_PHYSICAL) {
++			if (!engine->engine || engine->num_siblings || engine->width ||
++			    engine->siblings ||
++			    memchr_inv(&engine->sseu, 0, sizeof(engine->sseu)))
++				return -EOPNOTSUPP;
++		} else {
++			return -EOPNOTSUPP;
++		}
++	}
++	return 0;
++}
++
++static int validate_checkpoint_contexts(struct drm_file *file)
++{
++	const unsigned long allowed_user_flags =
++		BIT(UCONTEXT_NO_ERROR_CAPTURE) | BIT(UCONTEXT_BANNABLE) |
++		BIT(UCONTEXT_RECOVERABLE) | BIT(UCONTEXT_PERSISTENCE);
++	struct drm_i915_file_private *fpriv = file->driver_priv;
++	struct i915_gem_proto_context *pc;
++	struct i915_gem_context *ctx;
++	struct i915_address_space *vm;
++	struct i915_vma *vma;
++	unsigned long id;
++	u32 context_count = 0;
++	u32 context_max = 0;
++	u32 expected_vm = 1;
++	int ret = 0;
++
++	xa_for_each(&fpriv->context_xa, id, ctx) {
++		ret = validate_active_context(fpriv, ctx, id != 0);
++		if (ret)
++			return ret;
++		if (id == 0) {
++			if (!ctx->vm)
++				continue;
++			mutex_lock(&ctx->vm->mutex);
++			if (!list_empty(&ctx->vm->bound_list) ||
++			    !list_empty(&ctx->vm->unbound_list))
++				ret = -EOPNOTSUPP;
++			mutex_unlock(&ctx->vm->mutex);
++			if (ret)
++				return ret;
++			continue;
++		}
++		context_count++;
++		context_max = max_t(u32, context_max, id);
++	}
++
++	mutex_lock(&fpriv->proto_context_lock);
++	xa_for_each(&fpriv->proto_context_xa, id, pc) {
++		context_count++;
++		context_max = max_t(u32, context_max, id);
++		if (pc->uses_protected_content || pc->pxp_wakeref ||
++		    pc->user_flags & ~allowed_user_flags ||
++		    memchr_inv(&pc->legacy_rcs_sseu, 0,
++			       sizeof(pc->legacy_rcs_sseu)) ||
++		    context_vm_id(fpriv, pc->vm) == U32_MAX) {
++			ret = -EOPNOTSUPP;
++			break;
++		}
++		ret = validate_proto_context_engines(pc);
++		if (ret)
++			break;
++	}
++	mutex_unlock(&fpriv->proto_context_lock);
++	if (ret)
++		return ret;
++	if (context_count != context_max)
++		return -EOPNOTSUPP;
++
++	xa_for_each(&fpriv->vm_xa, id, vm) {
++		if (id != expected_vm++)
++			return -EOPNOTSUPP;
++		mutex_lock(&vm->mutex);
++		if (!list_empty(&vm->unbound_list)) {
++			ret = -EOPNOTSUPP;
++			goto unlock_vm;
++		}
++		list_for_each_entry(vma, &vm->bound_list, vm_link) {
++			int flags = atomic_read(&vma->flags);
++
++			if (!drm_mm_node_allocated(&vma->node) || vma->guard ||
++			    vma->size != vma->obj->base.size ||
++			    vma->gtt_view.type != I915_GTT_VIEW_NORMAL ||
++			    i915_vma_is_active(vma) ||
++			    (flags & I915_VMA_BIND_MASK) !=
++				    I915_VMA_LOCAL_BIND ||
++			    flags & (I915_VMA_GLOBAL_BIND | I915_VMA_ERROR |
++				     I915_VMA_GGTT | I915_VMA_CAN_FENCE |
++				     I915_VMA_USERFAULT | I915_VMA_SCANOUT) ||
++			    !object_has_file_handle(file, vma->obj)) {
++				ret = -EOPNOTSUPP;
++				break;
++			}
++		}
++unlock_vm:
++		mutex_unlock(&vm->mutex);
++		if (ret)
++			return ret;
++	}
++	return 0;
++}
++
++static int describe_syncobj(struct drm_syncobj *syncobj, u32 *flags, u64 *point)
++{
++	struct dma_fence *fence;
++	unsigned long irqflags;
++	bool has_callbacks;
++
++	if (READ_ONCE(syncobj->file))
++		return -EXDEV;
++
++	spin_lock_irqsave(&syncobj->lock, irqflags);
++	has_callbacks = !list_empty(&syncobj->cb_list) ||
++			!list_empty(&syncobj->ev_fd_list);
++	spin_unlock_irqrestore(&syncobj->lock, irqflags);
++	if (has_callbacks)
++		return -EBUSY;
++
++	fence = drm_syncobj_fence_get(syncobj);
++	if (!fence) {
++		*flags = I915_CRIU_SYNCOBJ_EMPTY;
++		*point = 0;
++		return 0;
++	}
++	if (!dma_fence_is_signaled(fence)) {
++		dma_fence_put(fence);
++		return -EBUSY;
++	}
++	if (to_dma_fence_chain(fence)) {
++		*flags = I915_CRIU_SYNCOBJ_TIMELINE;
++		*point = fence->seqno;
++	} else {
++		*flags = I915_CRIU_SYNCOBJ_BINARY_SIGNALED;
++		*point = 0;
++	}
++	dma_fence_put(fence);
++	return 0;
++}
++
++static int describe_dma_buf(struct drm_i915_gem_object *obj,
++			    struct drm_i915_criu_object *args)
++{
++	struct dma_buf_attachment *attachment;
++	struct dma_buf *dmabuf = obj->base.dma_buf;
++	long refcount;
++	u32 attachment_count = 0;
++
++	if (!dmabuf)
++		return 0;
++
++	refcount = file_count(dmabuf->file);
++	if (refcount <= 0 || refcount > U32_MAX)
++		return -EOVERFLOW;
++	dma_resv_lock(dmabuf->resv, NULL);
++	list_for_each_entry(attachment, &dmabuf->attachments, node) {
++		if (attachment_count == U32_MAX) {
++			dma_resv_unlock(dmabuf->resv);
++			return -EOVERFLOW;
++		}
++		attachment_count++;
++	}
++	dma_resv_unlock(dmabuf->resv);
++	args->dma_buf_refcount = refcount;
++	args->dma_buf_attachment_count = attachment_count;
++	return attachment_count ? -EOPNOTSUPP : 0;
++}
++
++static int validate_syncobjs(struct drm_file *file)
++{
++	struct drm_syncobj *syncobj;
++	unsigned long index;
++	int ret = 0;
++
++	xa_for_each(&file->syncobj_xa, index, syncobj) {
++		u32 flags;
++		u64 point;
++
++		drm_syncobj_get(syncobj);
++		ret = describe_syncobj(syncobj, &flags, &point);
++		drm_syncobj_put(syncobj);
++		if (ret)
++			break;
++	}
++	return ret;
++}
++
++static u64 i915_criu_reset_epoch(struct drm_i915_private *i915)
++{
++	u64 epoch = i915_reset_count(&i915->gpu_error);
++	unsigned int class;
++
++	/* Engine resets do not necessarily advance the global reset counter. */
++	for (class = 0;
++	     class < ARRAY_SIZE(i915->gpu_error.reset_engine_count); class++)
++		epoch += atomic_read(&i915->gpu_error.reset_engine_count[class]);
++	return epoch;
++}
++
++static int check_session(struct drm_i915_file_private *fpriv, u64 cookie,
++			 u32 mode)
++{
++	if (fpriv->criu_mode != mode)
++		return -EINVAL;
++	if (!cookie || cookie != fpriv->criu_cookie)
++		return -ESTALE;
