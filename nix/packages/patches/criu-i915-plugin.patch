+#!/usr/bin/env bash
+set -euo pipefail
+
+if (( EUID != 0 )); then
+    echo "run as root: sudo $0" >&2
+    exit 2
+fi
+
+repo=$(cd "$(dirname "$0")/../../.." && pwd)
+work=${I915_CRIU_TEST_DIR:-/tmp/i915-criu-minimal}
+criu=${CRIU:-/run/current-system/sw/bin/criu}
+plugin_dir=${CRIU_PLUGIN_DIR:-}
+plugin_args=()
+[[ -n $plugin_dir ]] && plugin_args+=(--libdir "$plugin_dir")
+cc=${CC:-gcc}
+fixture="$work/i915-gem-minimal"
+fixture_source=${FIXTURE:-/tmp/i915-gem-minimal}
+images="$work/images"
+log="$work/fixture.log"
+
+cleanup() {
+    if [[ -n ${fixture_pid:-} ]]; then
+        kill -KILL "$fixture_pid" 2>/dev/null || true
+    fi
+}
+trap cleanup EXIT
+rm -rf "$work"
+mkdir -p "$images"
+
+if [[ -x $fixture_source ]]; then
+    cp "$fixture_source" "$fixture"
+elif command -v "$cc" >/dev/null; then
+    "$cc" -std=c11 -Wall -Wextra -Werror -I"$repo" \
+        "$repo/test/others/i915-criu/i915-gem-minimal.c" -o "$fixture"
+else
+    echo "no prebuilt fixture at $fixture_source and compiler $cc is unavailable" >&2
+    exit 2
+fi
+
+"$fixture" >"$log" 2>&1 &
+fixture_pid=$!
+for _ in $(seq 1 100); do
+    grep -q '^READY ' "$log" && break
+    kill -0 "$fixture_pid"
+    sleep 0.05
+done
+grep -q '^READY ' "$log"
+original_pid=$fixture_pid
+original_address=$(sed -n 's/.* address=\([^ ]*\).*/\1/p' "$log")
+original_offset=$(sed -n 's/.* mmap_offset=\([^ ]*\).*/\1/p' "$log")
+
+"$criu" dump -t "$original_pid" -D "$images" --shell-job \
+    "${plugin_args[@]}" --log-file dump.log -v4
+wait "$fixture_pid" 2>/dev/null || true
+fixture_pid=
+
+test -s "$images"/i915-criu-*.img
+"$criu" restore -D "$images" --shell-job --restore-detached \
+    "${plugin_args[@]}" --log-file restore.log -v4
+fixture_pid=$original_pid
+kill -USR1 "$fixture_pid"
+
+for _ in $(seq 1 100); do
+    grep -q '^PASS: mapping address, contents, CPU access, and GPU execution$' "$log" && break
+    kill -0 "$fixture_pid" 2>/dev/null || true
+    sleep 0.05
+done
+grep -q '^PASS: mapping address, contents, CPU access, and GPU execution$' "$log"
+for _ in $(seq 1 100); do
+    [[ $(cat "/proc/$fixture_pid/comm" 2>/dev/null || true) != i915-gem-minima ]] && break
+    sleep 0.05
+done
+if [[ $(cat "/proc/$fixture_pid/comm" 2>/dev/null || true) == i915-gem-minima ]]; then
+    echo "restored fixture pid $fixture_pid did not exit" >&2
+    exit 1
+fi
+fixture_pid=
+
+expect_restore_failure() {
+    local label=$1
+    local mode=$2
+    local negative="$work/negative-$label"
+    local image
+
+    cp -a "$images" "$negative"
+    rm -f "$negative/restore.log"
+    image=$(printf '%s\n' "$negative"/i915-criu-*.img)
+    case "$mode" in
+        incompatible-version)
+            printf '\007\000\000\000' | dd of="$image" bs=1 seek=8 conv=notrunc status=none
+            ;;
+        truncated)
+            truncate -s -1 "$image"
+            ;;
+        *)
+            echo "unknown negative-test mutation: $mode" >&2
+            return 2
+            ;;
+    esac
+
+    if "$criu" restore -D "$negative" --shell-job --restore-detached \
+        "${plugin_args[@]}" --log-file restore.log -v4; then
+        echo "restore unexpectedly accepted $label image" >&2
+        return 1
+    fi
+    grep -Eq 'Failed to prepare restore plugins|Restoring FAILED' \
+        "$negative/restore.log"
+    if [[ $(cat "/proc/$original_pid/comm" 2>/dev/null || true) == i915-gem-minima ]]; then
+        echo "failed $label restore left fixture pid $original_pid alive" >&2
+        kill -KILL "$original_pid" 2>/dev/null || true
+        return 1
+    fi
+    printf 'PASS: %s image refused without a surviving partial restore\n' "$label"
+}
+
+expect_restore_failure incompatible-schema incompatible-version
+expect_restore_failure corrupt-truncated truncated
+
+printf 'PASS: CRIU restored pid=%s address=%s mmap_offset=%s\n' \
+    "$original_pid" "$original_address" "$original_offset"
diff --git a/test/others/i915-criu/run-physical-suite.sh b/test/others/i915-criu/run-physical-suite.sh
new file mode 100755
index 000000000..67a23ea22
--- /dev/null
+++ b/test/others/i915-criu/run-physical-suite.sh
@@ -0,0 +1,134 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+if (( EUID != 0 )); then
+    echo "run as root: sudo $0" >&2
+    exit 2
+fi
+
+repo=$(cd "$(dirname "$0")/../../.." && pwd)
+scripts="$repo/test/others/i915-criu"
+timestamp=$(date -u +%Y%m%dT%H%M%SZ)
+suite=${I915_CRIU_SUITE_DIR:-/var/tmp/i915-criu-physical-$timestamp}
+criu=${CRIU:-/run/current-system/sw/bin/criu}
+plugin_dir=${CRIU_PLUGIN_DIR:-/run/current-system/sw/lib/criu}
+minimal_fixture=${MINIMAL_FIXTURE:-/tmp/i915-gem-minimal}
+sharing_fixture=${SHARING_FIXTURE:-/tmp/i915-gem-sharing}
+context_fixture=${CONTEXT_FIXTURE:-/tmp/i915-context-sync}
+
+umask 077
+mkdir -p "$suite"
+chmod 0700 "$suite"
+
+return_evidence_to_invoker() {
+    if [[ -n ${SUDO_UID:-} && -n ${SUDO_GID:-} ]]; then
+        chown -R "$SUDO_UID:$SUDO_GID" "$suite"
+        chmod 0700 "$suite"
+    fi
+}
+trap return_evidence_to_invoker EXIT
+
+for required in "$criu" "$plugin_dir/i915_plugin.so" \
+    "$minimal_fixture" "$sharing_fixture" "$context_fixture"; do
+    if [[ ! -e $required ]]; then
+        echo "required physical-suite artifact is missing: $required" >&2
+        exit 2
+    fi
+done
+
+kernel_module=$(modinfo -F filename i915)
+if [[ $kernel_module == *.xz ]]; then
+    xzgrep -a -q 'i915_criu_binding_ioctl' "$kernel_module"
+else
+    grep -a -q 'i915_criu_binding_ioctl' "$kernel_module"
+fi
+
+read_parameter() {
+    local name=$1
+    cat "/sys/module/i915/parameters/$name" 2>/dev/null || printf '<unavailable>'
+}
+
+jq -n \
+    --arg timestamp "$timestamp" \
+    --arg kernel "$(uname -r)" \
+    --arg boot_id "$(cat /proc/sys/kernel/random/boot_id)" \
+    --arg system "$(readlink -f /run/current-system)" \
+    --arg pci "$(lspci -Dnn -s 0000:00:02.0)" \
+    --arg kernel_module "$kernel_module" \
+    --arg criu "$($criu --version | head -1)" \
+    --arg plugin "$(readlink -f "$plugin_dir/i915_plugin.so")" \
+    --arg niri "$(niri --version 2>/dev/null || printf '<unavailable>')" \
+    --arg enable_guc "$(read_parameter enable_guc)" \
+    --arg enable_hangcheck "$(read_parameter enable_hangcheck)" \
+    --arg modeset "$(read_parameter modeset)" \
+    '{schema:1,timestamp:$timestamp,kernel:$kernel,boot_id:$boot_id,
+      system:$system,pci:$pci,kernel_module:$kernel_module,criu:$criu,
+      plugin:$plugin,abi:6,image_schema:6,niri:$niri,i915:{enable_guc:$enable_guc,
+      enable_hangcheck:$enable_hangcheck,modeset:$modeset}}' \
+    >"$suite/metadata.json"
+
+run_case() {
+    local name=$1
+    shift
+    local log="$suite/$name.log"
+
+    echo "RUN: $name"
+    if "$@" >"$log" 2>&1; then
+        echo "PASS: $name"
+    else
+        local status=$?
+        echo "FAIL: $name (status=$status); log=$log" >&2
+        tail -80 "$log" >&2
+        exit "$status"
+    fi
+}
+
+common=(CRIU="$criu" CRIU_PLUGIN_DIR="$plugin_dir")
+run_case minimal-gem env "${common[@]}" \
+    FIXTURE="$minimal_fixture" I915_CRIU_TEST_DIR="$suite/minimal-gem" \
+    "$scripts/run-minimal-criu.sh"
+run_case shared-gem env "${common[@]}" \
+    FIXTURE="$sharing_fixture" I915_CRIU_TEST_DIR="$suite/shared-gem" \
+    "$scripts/run-sharing-criu.sh"
+run_case external-sharing-refusal env "${common[@]}" \
+    FIXTURE="$sharing_fixture" I915_CRIU_EXTERNAL_PEER=1 \
+    I915_CRIU_TEST_DIR="$suite/external-sharing-refusal" \
+    "$scripts/run-sharing-criu.sh"
+run_case retained-dmabuf env "${common[@]}" \
+    FIXTURE="$sharing_fixture" I915_CRIU_RETAINED_DMABUF=1 \
+    I915_CRIU_EXPECT_UNSUPPORTED=0 \
+    I915_CRIU_TEST_DIR="$suite/retained-dmabuf" \
+    "$scripts/run-sharing-criu.sh"
+run_case external-dmabuf-refusal env "${common[@]}" \
+    FIXTURE="$sharing_fixture" I915_CRIU_EXTERNAL_DMABUF_PEER=1 \
+    I915_CRIU_TEST_DIR="$suite/external-dmabuf-refusal" \
+    "$scripts/run-sharing-criu.sh"
+run_case synchronization env "${common[@]}" \
+    FIXTURE="$context_fixture" I915_CRIU_EXPECT_UNSUPPORTED=0 \
+    I915_CRIU_SYNC_ONLY=1 I915_CRIU_TEST_DIR="$suite/synchronization" \
+    "$scripts/run-context-sync-criu.sh"
+run_case idle-context-vm env "${common[@]}" \
+    FIXTURE="$context_fixture" I915_CRIU_EXPECT_UNSUPPORTED=0 \
+    I915_CRIU_IDLE_CONTEXT=1 I915_CRIU_TEST_DIR="$suite/idle-context-vm" \
+    "$scripts/run-context-sync-criu.sh"
+run_case sync-callback-refusal env "${common[@]}" \
+    FIXTURE="$context_fixture" I915_CRIU_EXPECT_UNSUPPORTED=1 \
+    I915_CRIU_CALLBACK=1 I915_CRIU_TEST_DIR="$suite/sync-callback-refusal" \
+    "$scripts/run-context-sync-criu.sh"
+run_case context-vm-binding env "${common[@]}" \
+    FIXTURE="$context_fixture" I915_CRIU_EXPECT_UNSUPPORTED=0 \
+    I915_CRIU_TEST_DIR="$suite/context-vm-binding" \
+    "$scripts/run-context-sync-criu.sh"
+run_case custom-engine-refusal env "${common[@]}" \
+    FIXTURE="$context_fixture" I915_CRIU_EXPECT_UNSUPPORTED=1 \
+    I915_CRIU_CUSTOM_ENGINE=1 \
+    I915_CRIU_TEST_DIR="$suite/custom-engine-refusal" \
+    "$scripts/run-context-sync-criu.sh"
+
+jq -n --arg timestamp "$timestamp" --arg suite "$suite" \
+    '{schema:1,timestamp:$timestamp,suite:$suite,verdict:"pass",
+      cases:["minimal-gem","shared-gem","external-sharing-refusal",
+      "retained-dmabuf","external-dmabuf-refusal","synchronization",
+      "idle-context-vm","sync-callback-refusal",
+      "context-vm-binding","custom-engine-refusal"]}' >"$suite/verdict.json"
+printf 'PASS: physical i915 suite evidence=%s\n' "$suite"
diff --git a/test/others/i915-criu/run-sharing-criu.sh b/test/others/i915-criu/run-sharing-criu.sh
new file mode 100755
index 000000000..5dea1d004
--- /dev/null
+++ b/test/others/i915-criu/run-sharing-criu.sh
@@ -0,0 +1,146 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+if (( EUID != 0 )); then
+    echo "run as root: sudo $0" >&2
+    exit 2
+fi
+
+repo=$(cd "$(dirname "$0")/../../.." && pwd)
+work=${I915_CRIU_TEST_DIR:-/tmp/i915-criu-sharing}
+criu=${CRIU:-/run/current-system/sw/bin/criu}
+plugin_dir=${CRIU_PLUGIN_DIR:-}
+plugin_args=()
+[[ -n $plugin_dir ]] && plugin_args+=(--libdir "$plugin_dir")
+expect_unsupported=${I915_CRIU_EXPECT_UNSUPPORTED:-0}
+external_peer=${I915_CRIU_EXTERNAL_PEER:-0}
+retained_dmabuf=${I915_CRIU_RETAINED_DMABUF:-0}
+external_dmabuf=${I915_CRIU_EXTERNAL_DMABUF_PEER:-0}
+cc=${CC:-gcc}
+fixture="$work/i915-gem-sharing"
+fixture_source=${FIXTURE:-/tmp/i915-gem-sharing}
+images="$work/images"
+log="$work/fixture.log"
+
+cleanup() {
+    if [[ -n ${fixture_pid:-} ]]; then
+        kill -KILL "$fixture_pid" 2>/dev/null || true
+    fi
+    if [[ -n ${child_pid:-} ]]; then
+        kill -KILL "$child_pid" 2>/dev/null || true
+    fi
+    if [[ -n ${external_dmabuf_pid:-} && $external_dmabuf_pid != 0 ]]; then
+        kill -KILL "$external_dmabuf_pid" 2>/dev/null || true
+    fi
+}
+trap cleanup EXIT
+rm -rf "$work"
+mkdir -p "$images"
+
+if [[ -x $fixture_source ]]; then
+    cp "$fixture_source" "$fixture"
+elif command -v "$cc" >/dev/null; then
+    "$cc" -std=c11 -Wall -Wextra -Werror -I"$repo" \
+        "$repo/test/others/i915-criu/i915-gem-sharing.c" -o "$fixture"
+else
+    echo "no prebuilt fixture at $fixture_source and compiler $cc is unavailable" >&2
+    exit 2
+fi
+
+fixture_args=()
+if (( external_peer + retained_dmabuf + external_dmabuf > 1 )); then
+    echo 'external-peer, retained-dmabuf, and external-dmabuf-peer modes are mutually exclusive' >&2
+    exit 2
+elif [[ $external_peer == 1 ]]; then
+    fixture_args+=(--external-peer)
+    expect_unsupported=1
+elif [[ $retained_dmabuf == 1 ]]; then
+    fixture_args+=(--retained-dmabuf)
+elif [[ $external_dmabuf == 1 ]]; then
+    fixture_args+=(--external-dmabuf-peer)
+    expect_unsupported=1
+fi
+"$fixture" "${fixture_args[@]}" >"$log" 2>&1 &
+fixture_pid=$!
+for _ in $(seq 1 100); do
+    grep -q '^READY ' "$log" && break
+    kill -0 "$fixture_pid"
+    sleep 0.05
+done
+grep -q '^READY ' "$log"
+original_pid=$fixture_pid
+original_address=$(sed -n 's/^READY .* address=\([^ ]*\).*/\1/p' "$log")
+child_pid=$(sed -n 's/^READY .* child=\([0-9]*\).*/\1/p' "$log")
+external_dmabuf_pid=$(sed -n 's/^READY .* external_dmabuf=\([0-9]*\).*/\1/p' "$log")
+child_address=$(sed -n 's/^CHILD .* address=\([^ ]*\).*/\1/p' "$log")
+
+if [[ $expect_unsupported == 1 ]]; then
+    set +e
+    "$criu" dump -t "$original_pid" -D "$images" --shell-job \
+        "${plugin_args[@]}" --log-file dump.log -v4
+    dump_status=$?
+    set -e
+    if (( dump_status == 0 || dump_status >= 128 )); then
+        echo "sharing dump did not fail safely: status=$dump_status" >&2
+        exit 1
+    fi
+    grep -q 'Dumping FAILED' "$images/dump.log"
+    if [[ $external_peer == 1 ]]; then
+        grep -q 'captured handles but .* exist' "$images/dump.log"
+        printf 'PASS: external sharing peer refused before dump completion (status=%s)\n' \
+            "$dump_status"
+    elif [[ $external_dmabuf == 1 ]]; then
+        grep -q 'captured dma-buf fds but refcount .* is not complete' \
+            "$images/dump.log"
+        printf 'PASS: external dma-buf peer refused before dump completion (status=%s)\n' \
+            "$dump_status"
+    else
+        printf 'PASS: unsupported sharing dump refused without a CRIU crash (status=%s)\n' \
+            "$dump_status"
+    fi
+    exit 0
+fi
+
+"$criu" dump -t "$original_pid" -D "$images" --shell-job \
+    "${plugin_args[@]}" --log-file dump.log -v4
+wait "$fixture_pid" 2>/dev/null || true
+fixture_pid=
+for _ in $(seq 1 200); do
+    [[ $(cat "/proc/$child_pid/comm" 2>/dev/null || true) != i915-gem-sharin ]] && break
+    sleep 0.05
+done
+if [[ $(cat "/proc/$child_pid/comm" 2>/dev/null || true) == i915-gem-sharin ]]; then
+    echo "dumped child pid $child_pid was not reaped before restore" >&2
+    exit 1
+fi
+
+i915_images=("$images"/i915-criu-*.img)
+(( ${#i915_images[@]} >= 2 ))
+for image in "${i915_images[@]}"; do
+    test -s "$image"
+done
+"$criu" restore -D "$images" --shell-job --restore-detached \
+    "${plugin_args[@]}" --log-file restore.log -v4
+fixture_pid=$original_pid
+kill -USR1 "$fixture_pid"
+
+for _ in $(seq 1 100); do
+    grep -q '^PASS: two-process dma-buf identity, mappings, CPU sharing, and GPU execution$' "$log" && break
+    kill -0 "$fixture_pid" 2>/dev/null || true
+    sleep 0.05
+done
+grep -q '^PASS: two-process dma-buf identity, mappings, CPU sharing, and GPU execution$' "$log"
+for pid in "$original_pid" "$child_pid"; do
+    for _ in $(seq 1 100); do
+        [[ $(cat "/proc/$pid/comm" 2>/dev/null || true) != i915-gem-sharin ]] && break
+        sleep 0.05
+    done
+    if [[ $(cat "/proc/$pid/comm" 2>/dev/null || true) == i915-gem-sharin ]]; then
+        echo "restored sharing fixture pid $pid did not exit" >&2
+        exit 1
+    fi
+done
+fixture_pid=
+
+printf 'PASS: CRIU restored parent=%s child=%s parent_address=%s child_address=%s\n' \
+    "$original_pid" "$child_pid" "$original_address" "$child_address"
